{% if settings.enable_cart_countdown != false and settings.gcd_date != blank or settings.gcd_enable_set_to %}
<script>
  document.addEventListener("DOMContentLoaded", function () {
    kik_cart_init_timer();
    document.addEventListener("shopify:section:load", function () {
      kik_cart_init_timer();
    });
    function kik_cart_init_timer() {
      const ms_sec = 1000,
            ms_min = ms_sec * 60,
            ms_hr  = ms_min * 60,
            ms_day = ms_hr * 24;

      const timerWrapper = document.querySelector(".kik_cart_timer_an.{{ section.id }}");
      if (!timerWrapper) return;
      // Shared key with the global Sale Countdown -> the cart stays in sync with
      // the Top Bar / Count Down section / product Promo Sale.
      const CART_STORAGE_KEY = timerWrapper.getAttribute("data-storage-key") || "kik_global_sale_start";

      const isEnabledSetTo = timerWrapper.getAttribute("data-enable-set-to") === "true";
      const hoursToSet     = parseInt(timerWrapper.getAttribute("data-set-hours")) || 24;

      let targetTimestamp;

      if (isEnabledSetTo) {
        const localStartTime = localStorage.getItem(CART_STORAGE_KEY);
        let startTime;
        if (localStartTime) {
          startTime = parseInt(localStartTime);
        } else {
          startTime = new Date().getTime();
          localStorage.setItem(CART_STORAGE_KEY, startTime);
        }
        targetTimestamp = startTime + (hoursToSet * ms_hr);
      } else {
        const rawDate   = timerWrapper.getAttribute("data-time");
        targetTimestamp = new Date(rawDate).getTime();
      }

      if (window.kik_cart_interval_{{ section.id | replace: '-', '_' }}) {
        clearInterval(window.kik_cart_interval_{{ section.id | replace: '-', '_' }});
      }

      function cartUpdateDisplay() {
        const currentTime = new Date().getTime();
        let gap = targetTimestamp - currentTime;

        if (gap < 0) {
          {% if settings.gcd_action_timer == "resets_itself" %}
            const newNow = new Date().getTime();
            localStorage.setItem(CART_STORAGE_KEY, newNow);
            targetTimestamp = newNow + (hoursToSet * ms_hr);
            gap = targetTimestamp - newNow;
          {% else %}
            const cart_text_countdown = document.querySelector("#cart_drawer_countdown");
            timerWrapper.style.display = "none";
            if (cart_text_countdown) {
              cart_text_countdown.style.display = "none";
            }
            clearInterval(window.kik_cart_interval_{{ section.id | replace: '-', '_' }});
            return;
          {% endif %}
        }

        const d = Math.floor(gap / ms_day);
        const h = Math.floor((gap % ms_day) / ms_hr);
        const m = Math.floor((gap % ms_hr)  / ms_min);
        const s = Math.floor((gap % ms_min) / ms_sec);

        timerWrapper.querySelectorAll(".cart_days").forEach(el    => el.innerText = d);
        timerWrapper.querySelectorAll(".cart_hours").forEach(el   => el.innerText = h);
        timerWrapper.querySelectorAll(".cart_minutes").forEach(el => el.innerText = m);
        timerWrapper.querySelectorAll(".cart_seconds").forEach(el => el.innerText = s);
      }

      window.kik_cart_interval_{{ section.id | replace: '-', '_' }} = setInterval(cartUpdateDisplay, 1000);
      cartUpdateDisplay();
    }
  });
</script>
{% endif %}