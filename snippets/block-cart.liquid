
<style>
  .c-cart-delivery {
    padding: 0 10px;
    padding-top: 5px;
    padding-bottom: 5px;
    color: #000000;
    font-size: 12px;
    width: 100%;
    text-align: center;
    /* display: inline-flex; */
    align-items: center;
    justify-content: center;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
}
.c-cart-delivery span {
    display: flex;
    align-items: center;
    grid-gap: 8px;
    justify-content: center;
}
.site-header__cart .mini-cart-content svg,
.site-header__cart .mini-cart-content .icon {
    width: {{ settings.icons_size }}px;
    height: {{ settings.icons_size }}px;
    fill: transparent;
}
.js-mini-cart-content .js-qty .js-qty__adjust svg,
.js-mini-cart-content .js-qty .js-qty__adjust svg path{
fill:var(--g-chrome-text, #000);
}
.site-header__cart .mini-cart-content .with_stroke svg path,
.site-header__cart .mini-cart-content .with_stroke svg circle{
stroke: var(--icon-color)
}
.c-cart-delivery>span:nth-child(2) {
    padding: 0 28px;
}
.c-cart-delivery{
background:{{ settings.checkout_icons_background }}!important;
border-radius:{{ settings.checkout_icons_radius }}px!important;
}
@media (max-width: 768px) {
    .c-cart-delivery {
        font-size: 12px;
    }
    .c-cart-delivery span {
    font-size: 12px;
            grid-gap: 2px;
}
.c-cart-delivery>span:nth-child(2) {
    padding: 0 10px;
}
}
.kik_cart_timer_c p{
    text-align: center;
    margin: 0;
    margin-bottom: 0px;
    font-weight: 600;
    font-size: 12px;
}
.list--inline{
  display:flex;
  gap:6px;
}
.cart-drawer-countdown-item li{
display:flex;
flex-direction:column;
align-items:center;
justify-content:center;
gap:2px;
{% if settings.countdown_box_text_color != blank and settings.countdown_box_text_color != "rgba(0,0,0,0)" %}
border:1px solid {{ settings.countdown_box_border }};
{% else %}
border:1px solid {{ settings.branding_color }};
{% endif %}
border-radius:{{ settings.radius_allimg_range }}px;
height:44px;
width:44px;
background:{{ settings.countdown_box_background }};
{% if settings.countdown_box_text_color != blank and settings.countdown_box_text_color != "rgba(0,0,0,0)" %}
  color:{{ settings.countdown_box_text_color }};
{% endif %}
}
.cart-drawer-countdown-item li .countdown-time{
    font-size: 20px;
    line-height: 1;
}
.cart-drawer-countdown-item li .countdown-text{
    font-size: 10px;
    line-height: 1;
}
@media (max-width:768px){
.cart-drawer-countdown-item li{
height:42px;
width:42px;
}
.cart-drawer-countdown-item li .countdown-time{
    font-size: 16px;
    line-height: 1;
}
.cart-drawer-countdown-item li .countdown-text{
    font-size: 9px;
    line-height: 1;
}
}
</style>
{% liquid
  assign icon_cart = section.settings.icon_cart
  case icon_cart
  when 'text'
    assign stylecart = 'text-cart d-lg-inline-flex d-none'
    assign iconclass = 'text-indicator'
  when 'number'
    assign stylecart = 'number-cart hide'
    assign iconclass = 'text-indicator'
  when 'icon-text'
    assign stylecart = 'text-icon-cart pl-3'
    assign iconclass = 'site-header__cart-indicator'
  else
    assign stylecart = 'icon__fallback-text'
    assign iconclass = 'site-header__cart-indicator'
  endcase
%}
{%- assign cartdraw = settings.cartdraw -%}
{%- if cartdraw -%}
  {{ 'cart-draw.css' | asset_url | stylesheet_tag }}
  <span  class="site-header__link site-header__cart js-mini-cart {% unless template contains 'cart' %}  cardraw {% endunless %}  " data-cartmini="{{ cartdraw }}">
    <span class="js-toggle-cart header-cart-{{ section.settings.icon_cart }}" title="{{ 'cart.general.title' | t }}">
      <span class="position-relative">
      {%- if icon_cart == 'icon' or icon_cart == 'icon-text' -%}
        {%- render 'icon-cart' -%}
      {%- endif -%}
      <span class="js-cart-count {{ iconclass }}">{{ cart.item_count }}</span>
      </span>
      <span class="{{ stylecart }}">{{ 'layout.cart.title' | t }}</span>
    </span>
    <div class="mini-cart-content shadow text-center p-0 d-flex flex-column">
      <div class="mini-cart-header ">
        <div class=" text-left d-flex justify-content-between align-items-center border-bottom pb-1 pt-1 px-4 ">
            <div class="d-flex align-items-center">
              <span>{{ 'layout.cart.title' | t }}</span>
              <span class="js-cart-count site-header__cart-indicator ml-2">{{ cart.item_count }}</span>
            </div>
              {% if settings.enable_cart_countdown != false and settings.gcd_date != blank or settings.gcd_enable_set_to %}
                <div class="kik_cart_timer_c">
                {% if settings.data_countdown_title != blank %}
                  <p id="cart_drawer_countdown">{{ settings.data_countdown_title }}</p>
                {% else %}
                  <p id="cart_drawer_countdown">{{ 'general.cart.countdown_title' | t  }}</p>
                {% endif %}
                <div
                  class="kik_cart_timer_an {{ section.id }}"
                  data-time="{{ settings.gcd_date }}"
                  data-enable-set-to="{{ settings.gcd_enable_set_to }}"
                  data-set-hours="{{ settings.gcd_set_to | default: '24' }}"
                  data-storage-key="kik_global_sale_start"
                >
                  <div id="cart_drawer_countdown" class="cart-drawer-countdown-item">
                    <ul class="list--inline">
                      <li><span class="cart_days countdown-time"></span><span class="countdown-text">{{ 'general.months.days' | t }}</span></li>
                      <li><span class="cart_hours countdown-time"></span><span class="countdown-text">{{ 'general.months.hours' | t }}</span></li>
                      <li><span class="cart_minutes countdown-time"></span><span class="countdown-text">{{ 'general.months.minutes' | t }}</span></li>
                      <li><span class="cart_seconds countdown-time"></span><span class="countdown-text">{{ 'general.months.seconds' | t }}</span></li>
                    </ul>
                  </div>
                </div>
              </div>
              {% endif %}
            <div class="modal-header">
                <button type="button" class="close" aria-label="close"></button>
            </div>
        </div>

        {% assign total_savings = 0 %}

        {% for item in cart.items %}
          {% if item.variant.compare_at_price and item.variant.compare_at_price > item.variant.price %}
            {% assign savings = item.variant.compare_at_price | minus: item.variant.price | times: item.quantity %}
            {% assign total_savings = total_savings | plus: savings %}
          {% endif %}
        {% endfor %}

        {% assign total_savings = total_savings | plus: cart.total_discount %}

{% if settings.show_discount_information %}
  {% comment %}
  {% if total_savings > 0 %}
   {% endcomment %}
    {% if settings.discount_information_text != blank %}
      {% assign discount_template = settings.discount_information_text %}
    {% else %}
      {% assign discount_template = 'cart.general.saving_congrats_html' | t: amount: '{DISCOUNT}' %}
    {% endif %}
    <div class="discount-information" style="background:{{ settings.discount_information_background }}">
      <p class="discount-information-text-display" 
         style="color:{{ settings.discount_information_color }}"
         data-template="{{ discount_template }}">
        {% if settings.discount_information_text != blank %}
          {% assign discount_text = settings.discount_information_text | replace: '{DISCOUNT}', '|||DISCOUNT|||' %}
          {% assign text_parts = discount_text | split: '|||DISCOUNT|||' %}
          {{ text_parts[0] }}<span style="font-weight: 600;">{{ total_savings | money_with_currency }}</span>{{ text_parts[1] }}
        {% else %}
          {{ 'cart.general.saving_congrats_html' | t: amount: '<span style="font-weight: 600;">' | append: total_savings | money_with_currency | append: '</span>' }}
        {% endif %}
      </p>
    </div>
  {% endif %}


        {% comment %}
        {% if settings.show_discount_information %}
          {% if total_savings > 0 %}
            <div class="discount-information" style="background:{{ settings.discount_information_background }}">
              <p class="discount-information-text-display" 
                style="color:{{ settings.discount_information_color }}"
                data-template="{% if settings.discount_information_text != blank %}{{ settings.discount_information_text | escape }}{% else %}Congrats, you're saving {DISCOUNT} on your first order{% endif %}">
                {% if settings.discount_information_text != blank %}
                  {% assign discount_text = settings.discount_information_text | replace: '{DISCOUNT}', '|||DISCOUNT|||' %}
                  {% assign text_parts = discount_text | split: '|||DISCOUNT|||' %}
                  {{ text_parts[0] }}<span style="font-weight: 600;">{{ total_savings | money_with_currency }}</span>{{ text_parts[1] }}
                {% else %}
                  Congrats, you're saving <span style="font-weight: 600;">{{ total_savings | money_with_currency }}</span> on your first order
                {% endif %}
              </p>
            </div>
          {% endif %}
        {% endif %}
        {% endcomment %}


        {% if settings.show_review_information %}
          <div class="review-information" style="background:{% if settings.review_gradient_background %}{{ settings.review_information_gradient_background }}{% else %}{{ settings.review_information_background }}{% endif %}; padding: 10px;">
            <div style="display: flex; align-items: center;">
              <div style="display: flex; margin-right: 10px; position: relative;">
                  <div style="width: 30px; height: 30px; border-radius: 50%; padding: 2px; background:{% if settings.review_gradient_background %}{{ settings.review_information_gradient_background }}{% else %}{{ settings.review_information_background }}{% endif %}; margin-left: -15px; position: relative; z-index: 1;">
                    <div style="width: 100%; height: 100%; border-radius: 50%; overflow: hidden;">
                      <img 
                        alt="image-customer-1" 
                        src="{% if settings.review_image_information_1 != blank %}{{ settings.review_image_information_1 | image_url: width: 5760 }} {% else %} https://images.unsplash.com/photo-1494790108377-be9c29b29330?q=80&w=2070&auto=format&fit=crop {% endif %}"
                        style="width: 100%; height: 100%; object-fit: cover;">
                    </div>
                  </div>
                  <div style="width: 30px; height: 30px; border-radius: 50%; padding: 2px; background:{% if settings.review_gradient_background %}{{ settings.review_information_gradient_background }}{% else %}{{ settings.review_information_background }}{% endif %}; margin-left: -15px; position: relative; z-index: 2;">
                    <div style="width: 100%; height: 100%; border-radius: 50%; overflow: hidden;">
                      <img 
                        alt="image-customer-2" 
                        src="{% if settings.review_image_information_2 != blank %}{{ settings.review_image_information_2 | image_url: width: 5760 }} {% else %} https://images.unsplash.com/photo-1494790108377-be9c29b29330?q=80&w=2070&auto=format&fit=crop {% endif %}"
                        style="width: 100%; height: 100%; object-fit: cover;">
                    </div>
                  </div>
                <div style="width: 30px; height: 30px; border-radius: 50%; padding: 2px; background:{% if settings.review_gradient_background %}{{ settings.review_information_gradient_background }}{% else %}{{ settings.review_information_background }}{% endif %}; margin-left: -15px; position: relative; z-index: 3;">
                  <div style="width: 100%; height: 100%; border-radius: 50%; overflow: hidden;">
                    <img 
                      alt="image-customer-3" 
                      src="{% if settings.review_image_information_3 != blank %}{{ settings.review_image_information_3 | image_url: width: 5760 }} {% else %}https://images.unsplash.com/photo-1438761681033-6461ffad8d80?q=80&w=2070&auto=format&fit=crop{% endif %}"
                      style="width: 100%; height: 100%; object-fit: cover;">
                  </div>
                </div>
              </div>
              <p style="color:{{ settings.review_information_color }}; font-weight: 600; margin: 0;">
                {% if settings.review_information_text != blank %}
                  {{ settings.review_information_text }}
                {% else %}
                  {% comment %}
                  Join <span style="font-weight: 600;">10,000+</span> happy customers
                  {% endcomment %}
                   {{ 'general.cart.reviews_title' | t }}
                {% endif %}
              </p>
            </div>
          </div>
        {% endif %}
        
        <div class="js-cart-bottom px-4 mt-2">
        {%- render 'free-shipping' -%}
        </div>
      </div>

        <div id="growls-default" class="cart_growl_default hide px-4">
          <div class="growl growl-warning growl-large">
            <div class="growl-close">×</div>
            <div class="growl-title"></div>
            <div class="growl-message cart_badge_icon">Sorry but there is only <span></span> left.</div>
          </div>
        </div>
        <div class="mini-cart-message px-4"></div>
        <div class="mini-cart-scroll px-4">
          <div class="js-mini-cart-content pt-2" data-sizeimg="{{ settings.size_image_grid }}">
            {% comment %}
            {% for item in cart.items %}
              <div class="mini-cart-item">
                <a class="mini-cart-image " href="{{ item.product.url }}?variant={{ item.variant.id }}">
                  <span class="d-block mini-cart-img square">
                    <img src="{{ item.product.featured_image | image_url: width: 200 }}">
                  </span>
                </a>
                <div class="mini-cart-meta">
                  <div class="mb-1">
                    <a href="{{ item.product.url }}?variant={{ item.variant.id }}">{{ item.product.title }} - {{ item.variant.title }}</a>
                  </div>
                  <span>€19,99</span> x 3 <div class="d-flex align-items-center mt-2 justify-content-between">
                    <div class="js-qty mt-1">
                      <input data-line="1" type="text" min="0" class="change-minicart js-qty__input" pattern="[0-9]*" value="{{ item.quantity }}" data-max="{{ item.variant.inventory_quantity  }}">
                      <button type="button" class="js-qty__adjust js-qty__minus" aria-label="Reduce item quantity by one">
                        <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-minus" viewBox="0 0 22 3">
                          <path fill="#000" d="M21.5.5v2H.5v-2z" fill-rule="evenodd"></path>
                        </svg>
                        <span class="icon__fallback-text">−</span>
                      </button>
                      <button type="button" class="js-qty__adjust js-qty__plus" aria-label="Increase item quantity by one">
                        <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-plus" viewBox="0 0 22 21">
                          <path d="M12 11.5h9.5v-2H12V0h-2v9.5H.5v2H10V21h2v-9.5z" fill="#000" fill-rule="evenodd"></path>
                        </svg>
                        <span class="icon__fallback-text">+</span>
                      </button>
                    </div>
                    <button class="btn js-remove-mini-cart link pr-0" data-id="57893354766685">Remove</button>
                  </div>
                </div>
              </div>

            {% endfor %}
            {% endcomment %}
          </div>
          {% if settings.e_upsellcart %}
            <div class="drawer-crossell px-lg-4">
              <div class="drawer-crossell-inner pt-lg-3">
              {%- if settings.title_upsell != blank -%}
                <h6 class="text-left mb-lg-4 mb-3 pb-1 pt-3">{{ settings.title_upsell }}</h6>
              {% else %}
                <h6 class="text-left mb-lg-4 mb-3 pb-1 pt-3"> {{ 'general.cart.title_upsell' | t }}</h6>
              {%- endif -%}
              
                <div class="product-recommendations-cart position-relative">
                  <div class="recommend-loading" ></div>
                <div
                  class="product-recommendations-in"
                  data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}"
                >
                  <div class="flex-lg-column flex-row d-flex drawer-crossell-product flex-nowrap mb-0 gap-4">
                  {% if settings.cart_collection != blank %}
                        {%- for product in settings.cart_collection.products -%}
                        <div class="drawer-crossell__item">
                          {%- render 'product-grid-buywith', product: product, size_image_grid : 'auto' -%}
                        </div>
                      {%- endfor -%}
                  {% else %}
                  {%- if recommendations.performed? and recommendations.products_count > 0 -%}
                      {%- for product in recommendations.products -%}
                        <div class="drawer-crossell__item">
                          {%- render 'product-grid-buywith', product: product, size_image_grid : 'auto' -%}
                        </div>
                      {%- endfor -%}
                  {%- endif -%}
                  {% endif %}
                  </div>
                </div>
              </div>
            </div>
            </div>
          {% endif %}
        </div>
      <footer class="mini-cart-footer js-cart-bottom pb-1 px-4">
          <div class="mini-cart-total font-family-1">
            {%- if settings.e_notecart -%}
            <div class="d-flex align-items-center mb-3 pb-3 border-bottom block-addon gap-5 ">
              {%- if settings.e_notecart -%}
              <div class="block-notecart block-addon__box">
                <div class="small txt-body edit-notecart font-family-2 d-flex align-items-center" title="{{ 'cart.general.note_title' | t }}">
                  {% render 'icon-note' %}
                  <span>{{ 'cart.general.note_title' | t }}</span>
                </div>
                <div class="js-note-cart text-left block-addon__box--wrap">
                  <label for="cart__note" class="mb-3"> {{ 'cart.general.note_label' | t }}</label>
                  <textarea name="note" id="cart__note"  class="cart__note mb-3">{{ cart.note }}</textarea>
                  <button class="cart-notes-submit btn btn-theme"> {{ 'cart.general.save' | t }}</button>
                  <button class="link cart-note-close btn ml-2"> {{ 'cart.general.close' | t }}</button>
                </div>
              </div>
              {%- endif -%}
              {% assign product_gift = settings.product_gift %}
              {%- if settings.gift_wrapping_enable and product_gift != blank -%}
                <div class="giftwrap block-addon__box">
                  <div class="open-gift cursor small txt-body  d-flex align-items-center" > 
                  {% render 'icon-gift' %} <span> {{ 'cart.gift.title' | t }}</span>
                  </div>
                  <div class="boxgift block-addon__box--wrap" >
                    <div class="boxgif__wrap d-flex flex-column align-items-center">
                      <svg aria-hidden="true" focusable="false" role="presentation" class="" viewBox="0 0 64 64"><defs><style>.a{fill:none;stroke:var(--g-chrome-text, #000);stroke-width:2px}</style></defs><path class="a" d="M9 20.23h46v8.68H9zM13.34 28.91h36.89v24.3H13.34zM27.82 20.66v32.98M35.91 20.88v32.98M20.52 11.43a3.73 3.73 0 0 0-.74 2.87 4.57 4.57 0 0 0 .8 2.27C22 18.09 25.15 20 32 20.23a12 12 0 0 0-2.43-7 7.52 7.52 0 0 0-5.66-3.12 4 4 0 0 0-3.39 1.32z"/><path class="a" d="M43.37 11.43a3.73 3.73 0 0 1 .74 2.87 4.48 4.48 0 0 1-.8 2.27c-1.42 1.52-4.57 3.41-11.42 3.66a12.08 12.08 0 0 1 2.43-7A7.56 7.56 0 0 1 40 10.14a4 4 0 0 1 3.37 1.29z"/></svg>
                      <p class="font-family-2 mt-3 mb-4">{{ 'cart.gift.description' | t }} {{ product_gift.price | money }}</p>
                      <div class="d-flex justify-content-center align-items-center gap-3">
                        <a class="add-gift__btn add-gift btn btn-theme" href="{{ product_gift.url }}" data-id="{{ product_gift.selected_or_first_available_variant.id }}">
                          <div class="product-card__loading spinner-border" role="status"></div>
                          <span>{{ 'cart.gift.save' | t }}</span></a>
                        <button class="close-gift__btn btn link" >{{ 'cart.gift.close' | t }}</button>
                      </div>
                    </div>
                  </div>
                </div>
              {%- endif -%}
              {%- if settings.coupon_code_enable and template != 'cart' -%}
              <div class="block-coupon block-addon__box">
                <div class="small txt-body edit-discountcode font-family-2 d-flex align-items-center js-open-addon" title="{{ 'cart.general.coupon_title' | t }}">
                {% render 'icon-discount' %}
                  <span>{{ 'general.cart.coupon_code_title' | t }}</span>
                </div>
                <discount-code class="open-add-on block-addon__box--wrap">
                  <style>.card-coupon > summary{ list-style:none; cursor:pointer; } .card-coupon > summary::-webkit-details-marker{ display:none; }</style>
                  {%- if settings.coupon_code_title != blank -%}
                  <div id="list-coupon" class="mb-4 text-left">
                    <details class="card-coupon">
                      <summary class="card-header-coupon" id="headcoupon1">
                        <h6 class="mb-0">
                          <span class="heading-coupon d-flex align-items-center position-relative py-3">
                            {{ settings.coupon_code_title }}
                            <span class="coupon-icon">
                              <i class="icon-plus"></i>
                              </span>
                          </span>
                        </h6>
                      </summary>
                      <div class="pb-3">
                        {{ settings.coupon_code_content }}
                      </div>
                    </details>
                  </div>
                {% else %}
                   <div id="list-coupon" class="mb-4 text-left">
                    <details class="card-coupon">
                      <summary class="card-header-coupon" id="headcoupon1">
                        <h6 class="mb-0">
                          <span class="heading-coupon d-flex align-items-center position-relative py-3">
                            {{ 'general.cart.coupon_code_title' | t }}
                            <span class="coupon-icon">
                              <i class="icon-plus"></i>
                              </span>
                          </span>
                        </h6>
                      </summary>
                      {% if settings.coupon_code_content != blank %}
                      <div class="pb-3">
                        {{ settings.coupon_code_content }}
                      </div>
                      {% endif %}
                    </details>
                  </div>
                {%- endif -%}
                <div class="d-flex flex-column align-items-center">
                  <div class=" mb-4 w-100 text-left">
                    <label class="mb-3" for="discount-code-input">{{ 'cart.general.coupon_title' | t }}</label>
                    <input class="form-control" type="text" id="discount-code-input" autocomplete="on" value="">
                  </div>
                  <div class="d-flex w-100 gap-3">
                    <button id="apply-discount-btn" class="btn btn-theme btn-close-addon">{{ 'cart.general.save' | t }}</button>
                    <button class="link discount-close btn btn-close-addon"> {{ 'cart.general.close' | t }}</button>
                  </div>
                </div>
                </discount-code>
              </div>
              <script>
                class DiscountCode extends HTMLElement {
                    constructor() {
                      super();
                      this.couponCodeValue = document.getElementById('discount-code-input'); 
                      this.btnApply = document.getElementById('apply-discount-btn');
                      this.checkCode();
                      this.btnApply.addEventListener('click', this.saveCode.bind(this));
                    }
                    checkCode(){
                      if (localStorage.getItem('couponCode')){
                        this.couponCodeValue.value = localStorage.getItem('couponCode');  
                        //this.couponCodeValue.classList.add('has-value');
                      }
                    }
                    saveCode(){
                      this.valCode = this.couponCodeValue.value;
                      localStorage.setItem('couponCode', this.valCode );
                      fetch(`/discount/${this.valCode}`)
                            .then((response) => response.text())
                            .then((responseText) => {
                        });
                    }
                  }
                  customElements.define('discount-code', DiscountCode);
              </script>
             {%- endif -%}
             {%  comment %}
              {%- if settings.shipping_calculator  and template != 'cart' -%}
                <div class="block-addon__box">
                  <div class="small txt-body font-family-2 d-flex align-items-center js-open-addon" title="{{ 'cart.general.calc_title' | t }}">
                    {% render 'icon-shipping' %}
                    <span>{{ 'cart.general.calc_title' | t }}</span>
                  </div>
                    <div class="open-add-on block-addon__box--wrap" >
                    {% render 'shipping-calc' %}
                  </div>
                </div>
              {%- endif -%}
              {% endcomment %}
            </div>
