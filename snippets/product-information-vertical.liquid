<style>
  .nav-tab-info-vertical summary.card-header{ cursor: pointer; list-style: none; }
  .nav-tab-info-vertical summary.card-header::-webkit-details-marker{ display: none; }
  .nav-tab-info-vertical summary .card-link i{ transition: transform .2s ease; }
  .nav-tab-info-vertical details:not([open]) > summary .card-link i{ transform: rotate(0deg) !important; }
  .nav-tab-info-vertical details[open] > summary .card-link i{ transform: rotate(90deg) !important; }
  .nav-tab-info-vertical details[open] > summary.card-header .card-link{ color: var(--g-main); }
  .nav-tab-info-vertical details[open] .card-body{ animation: pivReveal .25s ease; }
  @keyframes pivReveal{ from{ opacity: 0; transform: translateY(-6px); } to{ opacity: 1; transform: none; } }
</style>
<div id="accordion" class="nav-tab-info-vertical">
    <details class="card" name="product-info-accordion">
      <summary class="card-header">
        <span class="card-link">{% render 'icon-arrow-right' %} {{ gtab_des | default: 'Description' }}</span>
      </summary>
      <div class="card-body px-0">
          {{ product.description }}
      </div>
    </details>
    {% if stab_title1 != blank %}
    <details class="card" name="product-info-accordion">
      <summary class="card-header">
        <span class="card-link">{% render 'icon-arrow-right' %} {{ stab_title1 }}</span>
      </summary>
      <div class="card-body px-0">
        {{ stab_content1 }}
      </div>
    </details>
    {% endif %}
    {% if stab_title2 != blank %}
    <details class="card" name="product-info-accordion">
      <summary class="card-header">
        <span class="card-link">{% render 'icon-arrow-right' %} {{ stab_title2 }}</span>
      </summary>
      <div class="card-body px-0">
        {{ stab_content2 }}
      </div>
    </details>
    {% endif %}
    {% if stab_title3 != blank %}
    <details class="card" name="product-info-accordion">
      <summary class="card-header">
        <span class="card-link">{% render 'icon-arrow-right' %} {{ stab_title3 }}</span>
      </summary>
      <div class="card-body px-0">
        {{ stab_content3 }}
      </div>
    </details>
    {% endif %}
    {% if stab_title4 != blank %}
    <details class="card" name="product-info-accordion">
      <summary class="card-header">
        <span class="card-link">{% render 'icon-arrow-right' %}  {{ stab_title4 }}</span>
      </summary>
      <div class="card-body px-0">
        {{ stab_content4 }}
      </div>
    </details>
    {% endif %}
    {% if gtab_review_enable %}
    <details class="card" name="product-info-accordion">
      <summary class="card-header">
        <span class="card-link">{% render 'icon-arrow-right' %} {{ gtab_review }}</span>
      </summary>
      <div class="card-body px-0">
          <div id="shopify-product-reviews" data-id="{{ product.id }}">{{ product.metafields.spr.reviews }}</div>
      </div>
    </details>
    {% endif %}
  </div>
