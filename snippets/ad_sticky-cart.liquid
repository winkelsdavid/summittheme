  <script>
    var sitckyHeight = document.querySelector('.sticky-cart-wr');
    var rootElement = document.querySelector(':root');
    rootElement.style.setProperty("--height-sticky", sitckyHeight.offsetHeight + "px");

    triggerCart = function (e){
      var elementButton = e.getAttribute('data-buttonid');
      document.getElementById(elementButton).click();
    }

    triggerOption = function (e){
      var index = e.selectedIndex;
      var value = e.value;
      var elementRadio = document.getElementById(e.getAttribute('data-radio'));
      var elementSelect = document.getElementById(e.getAttribute('data-selectbox'));

      //     Swatch variant
      if (elementRadio !== null){
        elementRadio.getElementsByTagName('input')[index].click();
      }

      //     dropdown variant
      if (elementSelect !== null){
        elementSelect.value  = value;
        elementSelect.dispatchEvent(new Event('change'));
      }
    }
   function updateDeliveryDate() {
  const deliveryElement2 = document.getElementById("delivery-date_2");
  if (!deliveryElement2) return;

  const daysToAdd2 = parseInt(deliveryElement2.dataset.days, 10);
  if (isNaN(daysToAdd2)) return;

  const deliveryDate2 = new Date();
  deliveryDate2.setDate(deliveryDate2.getDate() + daysToAdd2);

  const options2 = { month: 'long', day: 'numeric' };
  const formattedDate2 = deliveryDate2.toLocaleDateString('en-EN', options2);

  deliveryElement2.innerText = `${formattedDate2}`;
}

// Initial run
document.addEventListener("DOMContentLoaded", updateDeliveryDate);

// Re-run on Shopify theme editor events
document.addEventListener("shopify:section:load", updateDeliveryDate);
document.addEventListener("shopify:section:select", updateDeliveryDate);

  </script>
{%- endif -%}