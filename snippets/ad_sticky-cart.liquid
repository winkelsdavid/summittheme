{%- if section.settings.enable -%}
{%- assign current_variant = product.selected_or_first_available_variant -%}
  <!-- sticky-cart.liquid -->
  <style>
    :root{
      {% if section.settings.mix_1_2 != blank and  section.settings.mix_1_2 != "rgba(0,0,0,0)" %}
      --sticky-cart-mix: {{ section.settings.mix_1_2 }};
      {% else %}
      --sticky-cart-mix: {{ settings.branding_color }};
      {% endif %}
      --sticky-cart-mix2: {{ section.settings.mix_2_2 }};
      {% if section.settings.text_cl_2 != blank and  section.settings.text_cl_2 != "rgba(0,0,0,0)" %}
      --sticky-cart-text: {{ section.settings.text_cl_2 }};
      {% else %}
      --sticky-cart-text: {{ settings.color_body_text }};
      {% endif %}
      {% if section.settings.cart_bg_2 != blank and  section.settings.cart_bg_2 != "rgba(0,0,0,0)" %}
      --sticky-cart-bg: {{ section.settings.cart_bg_2 }};
      {% else %}
      --sticky-cart-bg: {{ settings.branding_color }};
      {% endif %}
      {% if section.settings.star_1_2 != blank and  section.settings.star_1_2 != "rgba(0,0,0,0)" %}
      --sticky-cart-cl_2: {{ section.settings.star_1_2 }};
      {%  else %}
      --sticky-cart-cl_2:{{ settings.branding_color }};
      {% endif %}
      --sticky-cart-cl: {{ section.settings.cart_cl_2 }};
      --sticky-cart-cl-hover: {{ section.settings.cart_cl_hover_2 }};
      }
  </style>
  <style>
    #PBarNextFrameWrapper{
      display:none!important;
    }
    .template-product{
      padding-bottom:var(--height-sticky);
    }
    .sticky-cart-wr{
      position: fixed;
      width: 100%;
      padding:9px 0;
      bottom: 0;
      z-index: 997;
      background: var(--sticky-cart-mix);
        left:0;
        -webkit-transition: all ease .45s;
        -o-transition: all ease .45s;
        transition: all ease .45s;
        -webkit-transform: translateY(100%);
        -ms-transform: translateY(100%);
        transform: translateY(100%);
        }
        .cart_items{
              display: -webkit-box;
              display: -ms-flexbox;
              display: flex;
              -webkit-box-pack: center;
              -ms-flex-pack: center;
              justify-content: center;
              -webkit-box-align: center;
              -ms-flex-align: center;
              align-items: center;
              -ms-flex-wrap: wrap;
              flex-wrap: wrap;
              position: relative;
              column-gap: 1rem;
        }
        @media (max-width:499px){
        .cart_items{
          margin:0 auto;
        }
        }
            .wsp-whatsapp {
        bottom: 6.5rem!important;
    }
        @media (max-width: 768px) {
    .wsp-whatsapp {
        bottom: 10.5rem!important;
    }
}
        @media (max-width:768px){
         .sticky-cart-wr.desktop{
          display:none!important;
        }
        }
        @media (min-width:768.1px){
        .sticky-cart-wr.mobile{
         display:none!important;
        }
      }
    .sticky-cart-wr.active{
      -webkit-transform: translateY(0);
      -ms-transform: translateY(0);
      transform: translateY(0);
    }
    .sticky-cart-wr.active .svg-cart{
      opacity: 0;
      display: none;
    }
    .sticky-cart-wr.disable{
      -webkit-transform: translateY(100%) !important;
      -ms-transform: translateY(100%) !important;
      transform: translateY(100%) !important;
    }
    .sticky-add-to-cart__ratings {
    display: flex;
    align-items: center;
    margin-bottom: 3px;
}
.sticky-add-to-cart__stars {
    display: flex;
    margin-right: 8px;
    color:var(--sticky-cart-cl);
}
.sticky-add-to-cart__rating-text{
color:var(--sticky-cart-text);
}
.sticky-add-to-cart__stars .star{
color:var(--sticky-cart-cl_2);
}
.sticky-add-to-cart__shipping {
    display: flex;
    align-items: center;
            flex-wrap:wrap;
        justify-content:center;
    color:var(--sticky-cart-text);
     font-size:{{ section.settings.delivery_size }}px;
}
.delivery-icon{
    color:var(--sticky-cart-cl);
        display: inline-flex;
    margin-right: 5px;
}
.delivery-icon svg{
  width:{{ section.settings.shipping_icon_width }}px;
  height:{{ section.settings.shipping_icon_width }}px;
}
    .sticky-cart-wr.disable .svg-cart{
      opacity: 1;
      display: block;
      margin:0 auto;
      fill:none;
    }
    #js-sticky-btn{
      border-color:var(--sticky-cart-bg) ;
      color:var(--sticky-cart-cl);
      background:var(--sticky-cart-bg);
    }

     {% if section.settings.enable_animation %}
              #js-sticky-btn:after{
              background-image: linear-gradient(90deg,transparent,hsla(0,0%,100%,.3),transparent);
              content: "";
              height: 100%;
              left: -150%;
              position: absolute;
              top: 0;
              transform: skew(20deg);
              width: 150%;
              animation: leftToRightShade {{ section.settings.animation_delay }}s cubic-bezier(.01,.56,1,1) infinite forwards;
              animation-delay:{{ section.settings.animation_delay }}s;
              }
        {% endif %}


    #js-sticky-btn:hover{
      color:var(--sticky-cart-cl-hover);
      {% unless settings.enable_button_hover %}
        background: var(--g-main);
      {% endunless %}
    }
    #js-sticky-prd{
      display: -webkit-box;
      display: -ms-flexbox;
      display: flex;
      -webkit-box-pack: center;
      -ms-flex-pack: center;
      justify-content: center;
      -webkit-box-align: center;
      -ms-flex-align: center;
      align-items: center;
      -ms-flex-wrap: wrap;
      flex-wrap: wrap;
      position:relative;
      column-gap: 4px;
      justify-content:space-between;
    }
    #js-sticky-prd h3{
      font-size: var(--g-font-size);
      max-width: 300px;
      overflow: hidden;
      -o-text-overflow: ellipsis;
      text-overflow: ellipsis;
      white-space: nowrap;
      --g-color-heading:var(--sticky-cart-text);
      color:var(--sticky-cart-text);
      text-transform: capitalize;
      letter-spacing: 0;
    }
    #js-sticky-price {
      color:var(--sticky-cart-text);
    }
    #js-sticky-img{
      height:65px;
      width: 65px;
      object-fit: cover;
      background-color:var(--color-item-product);
    }
    .sticky-cart-select{
      /*background:var(--sticky-cart-mix2);*/
      border:1px solid var(--sticky-cart-text);
      font-size: 12px;
      border-radius: var(--g-font-radius-btn);
      position: relative;
    }
    .sticky-cart-select label{
      position: absolute;
      top:4px;
      left: 16px;
      font-size: 10px;
      color:var(--sticky-cart-text);
    }
    .sticky-cart-select select{
      background: transparent;
      font-weight:400;
      padding: 8px;
      font-size: 13px;
      padding:20px 16px 4px 16px;
      min-width: 80px;
      color:var(--sticky-cart-text);
    }
    
    #js-sticky-quantity{
      max-width: 70px;
      font-weight: bold;
      text-align: center;
      padding: 10px;
    }

    #js-sticky-close{
      display: flex;
      width: 40px;
      height: 40px;
      border: none;
      top: 0;
      left: -50px;
      line-height: 38px;
      text-align: center;
      position: absolute;
      color:var(--sticky-cart-mix);;
      border-radius: 5px;
      filter: brightness(0.8);
      opacity:0;
      border-radius: 50%;
      top: 50%;
      margin-top: -20px;
      align-items: center;
      justify-content: center;
    }
    #js-sticky-close .icon{margin:0 auto;}
    .active #js-sticky-close{opacity:1}
    .active.disable #js-sticky-close{opacity:.6;top:-70px;margin-top: 0;}
    #js-sticky-close .icon-close+.icon{display:none}
    .disable #js-sticky-close .icon-close{display:none}
    .disable #js-sticky-close .icon-close+.icon{display:block}
    @media (max-width:1200px){
      #js-sticky-prd{
        justify-content:center;
        }
    }
    @media (max-width:540px) {
      #js-sticky-prd{
        padding:0 20px;
      }
      .sticky-unvariant #js-sticky-prd{
        gap:0;
      }
      .sticky-add-to-cart__shipping{
        flex-wrap:wrap;
        justify-content:center;
        width:100%;
        font-size:{{ section.settings.delivery_size_mobile }}px;

      }
      #js-sticky-btn{
        font-size: 12px;
        letter-spacing: 0;
        padding-left: 24px;
        padding-right: 24px;
        flex:1;
      }
      #js-sticky-prd{
    flex-wrap: wrap;
    row-gap: 5px;
    justify-content: space-between;
    }
    #js-sticky-btn{
    flex:0 0 100%;
    width:100%;
    margin:0!important;
    }
    }
  </style>
<div id="js-anchor-sticky-cart"></div>
  <div class="sticky-cart-wr shadow d-flex {% if product.has_only_default_variant %} sticky-unvariant {% endif %} {{ section.settings.enable_2_on }}" >
    <div id="js-sticky-prd" class="container align-self-center">
      <div class="cart_items">
      {%- assign img_url = product.featured_image | image_url: width: 1 | replace: 'width=1', 'width=180' -%}
      <img  id="js-sticky-img" src="{{ product.featured_image | image_url: width: 180 }}" 
        class="lazyload d-none d-lg-block"
        loading="lazy"
        data-src="{{ img_url }}"
        data-widths="[180 ,360, 540]"
        width="{{ product.featured_image.width }}"
        height="{{ product.featured_image.height }}"/>
      <div class="d-none d-lg-flex flex-column">
