              <span class="sticky-add-to-cart__rating-text">{% if section.settings.stars_text != blank %}{{ section.settings.stars_text }}{% else %}{{ 'general.sticky_cart.stars_text' | t }}{% endif %}</span>
            </div>
        {% endif %}
      <h3 class="m-0 font-family-2">{{ product.title }} <span id="js-sticky-title">{%- unless product.has_only_default_variant -%}- {{ current_variant.title }}{%- endunless -%}</span></h3>
      <div id="js-sticky-price" class="product-card__price">
        {{ current_variant.price | money }}
      </div>
      </div>
      <div class="sticky-cart-selectors d-flex  pl-lg-2 pr-lg-4 text-center gap-3">
        {%- unless product.has_only_default_variant -%}
        {%- for option in product.options_with_values -%}
        {% unless option.name == 'default' %}
        <div class="sticky-cart-select">
          <label>{{ option.name }}</label>
          <select data-name="{{ option.name }}"
                  onchange="triggerOption(this)"
                  id="js-sticky-option-{{ forloop.index }}"
                  data-radio="ProductSelect-option-{{ forloop.index0 }}"
                  data-selectbox="SingleOptionSelector-{{ forloop.index0 }}">
            {% for value in option.values %}
            <option value="{{ value | escape }}" {% if option.selected_value == value %} selected="selected"{% endif %}>{{ value }}</option>
            {% endfor %}
          </select>
        </div>
        {%- endunless -%}
        {%- endfor -%}
        {%- endunless -%}
      </div>
      </div>
      <div class="c_button_text_sticky">
        {%  if section.settings.add_shipping_timer %}
     <div class="sticky-add-to-cart__shipping" style="">
      {% if section.settings.pulsating_dot %}
        <div class="ring-container" style="--bk:{{ section.settings.dot_color }}">
            <div class="ringring" ></div>
            <div class="circle"></div>
        </div>
      {% else %}
        <span class="delivery-icon" style="display: inline-flex; margin-right: 5px;">
          {% if section.settings.Shipping_icon != blank %}
                <img src="{{ section.settings.Shipping_icon | img_url:"100x" }}" style="width:{{ section.settings.shipping_icon_width }}px">
          {% else %}
                  {% render 'list-svg', icon : section.settings.icon_svg %}
              {% endif %}
        </span>
      {% endif %}
        <span class="delivery-text" style="margin-right: 4px;">
            {% if section.settings.shipping_text != blank %}{{ section.settings.shipping_text }}{% else %}{{ 'general.sticky_cart.shipping_text' | t }}{% endif %}
        </span>
        <span class="shipping_data_s" id="delivery-date_2" data-days="{{ section.settings.delivery_in }}"></span>
      </div>
    {%  endif %}
      {% if section.settings.enable_2_button_function == "add_cart" %}
      <button id="js-sticky-btn" {% unless current_variant.available %}disabled="disabled"{% endunless %}
              class="btn btn-theme my-2" 
              onclick="triggerCart(this)" 
              data-buttonid="AddToCart-{{ section.id }}">
              {% if section.settings.atc_text != blank %}
                {{ section.settings.atc_text }}
              {% else %}
              {%- unless current_variant.available -%}
              {{ 'products.product.sold_out' | t }}
              {%- else -%}
              {{ 'products.product.add_to_cart' | t }}
              {%- endunless -%}
              {% endif %}
      </button>
    {% else %}
    <a href="#" id="js-sticky-btn" class="btn btn-theme my-2" >
       {% if section.settings.atc_text != blank %}
                {{ section.settings.atc_text }}
              {% else %}
              {%- unless current_variant.available -%}
              {{ 'products.product.sold_out' | t }}
              {%- else -%}
              {{ 'products.product.add_to_cart' | t }}
              {%- endunless -%}
              {% endif %}
    </a>
    {% endif %}
