<!-- productOption.liquid -->

{%- if product_selector != 'select' -%}
  {%- liquid
    assign isColor = false
    assign optionName = option.name
    assign option_index = loop

    # Farb-Option erkennen: 'color'/'colour' (case-insensitiv) ODER die frei
    # konfigurierbaren Keywords aus den Theme-Settings (z.B. 'Farbe').
    assign optionName_dc = option.name | downcase
    assign kw1 = settings.contain_color | downcase
    assign kw2 = settings.contain_color_2 | downcase
    if optionName_dc contains 'color' or optionName_dc contains 'colour'
      assign isColor = true
    elsif kw1 != blank and optionName_dc contains kw1
      assign isColor = true
    elsif kw2 != blank and optionName_dc contains kw2
      assign isColor = true
    endif

    # Anzeige-Art: Variant Image Round/Square = runde/eckige Swatch-Form.
    assign is_image_mode = false
    if product_selector == 'image_round' or product_selector == 'image_square'
      assign is_image_mode = true
    endif

    # Variante A: NUR Farb-Optionen werden zu Swatches. Nicht-Farb-Optionen
    # (z.B. Groesse) bleiben immer normale Buttons — ein Bild-Swatch ergibt dort
    # keinen Sinn. Die Fuellung einer Farb-Option entscheidet "Enable Swatch
    # Color" (sw_color_product):  an -> Palettenfarbe (Product Swatch Hex),
    # aus -> Variantenbild (Produktfoto). Die Anzeige-Art gibt nur die Form vor.
    assign swatch_as_image = false
    if isColor
      if sw_color_product == false
        assign swatch_as_image = true
      endif
    endif

    # Fieldset-Klassen: Swatch-Klassen nur fuer Farb-Optionen; Form aus
    # Anzeige-Art (Bild-Modus) sonst aus "Type Color".
    assign fs_class = 'single-option-radio'
    if isColor
      assign fs_class = fs_class | append: ' single-color ' | append: size_color
      if siblings_collection != blank and enable_sibling
        assign fs_class = fs_class | append: ' d-none'
      endif
      if is_image_mode
        if product_selector == 'image_round'
          assign fs_class = fs_class | append: ' round-color'
        else
          assign fs_class = fs_class | append: ' square-color'
        endif
      else
        if type_color == 'circle'
          assign fs_class = fs_class | append: ' round-color'
        elsif type_color == 'square'
          assign fs_class = fs_class | append: ' square-color'
        else
          assign fs_class = fs_class | append: ' square-color-txt'
        endif
      endif
    endif
  -%}
<fieldset class="{{ fs_class }}"
          name="{{ option.name | handleize }}"
          id="ProductSelect-option-{{ optionName }}-{{ forloop.index0 }}">

  {%- for value in option.values -%}
    {%- liquid
      assign variant_label_state = true
      if product.options.size == 1
        unless product.variants[forloop.index0].available
          assign variant_label_state = false
        endunless
      endif
      assign currenVariant = false
      for variant in product.variants
        assign vOption = 'option' | append: option_index
        if value == variant[vOption]
          assign currenVariant = variant
          break
        endif
      endfor
      assign v_image = currenVariant.featured_image | default: currenVariant.image

      # Bild-gefuellter Farb-Swatch (Enable Swatch Color aus): nie leer lassen —
      # hat die Variante kein eigenes Bild, aufs Produkt-Hauptbild zurueckfallen.
      if swatch_as_image and v_image == blank
        assign v_image = product.featured_image
      endif

      # Palettenfarbe fuer diesen Wert aus Product Swatch (settings.color_swatch_config).
      assign value_handle = value | escape | handle
      assign palette_config = settings.color_swatch_config | newline_to_br | split: '<br />'
      assign lowercase_value = value | downcase
      assign style_property = '--swatch-bg: ' | append: lowercase_value
      for item in palette_config
        assign parts = item | split: ':'
        assign name = parts.first | downcase | strip
        if lowercase_value == name
          assign val = parts.last | strip
          if val contains '#'
            assign style_property = '--swatch-bg: ' | append: val
          elsif images[val] != blank
            assign image = images[val] | image_url: width: 72
            assign style_property = '--swatch-bg: url(' | append: image | append: ')'
          endif
          break
        endif
      endfor

      # Variante A: Farb-Option mit "Enable Swatch Color" AUS -> statt Palettenfarbe
      # das Variantenbild als Fuellung nehmen (ueberschreibt die Palette).
      if swatch_as_image and v_image
        assign vimg = v_image | image_url: width: 100
        assign style_property = '--swatch-bg: url(' | append: vimg | append: ')'
      endif

      assign label_class = ''
      if isColor
        assign label_class = 'st-color-' | append: value_handle | append: ' st-tooltip-top'
      endif
      unless variant_label_state
        assign label_class = label_class | append: ' disabled'
      endunless
      assign label_class = label_class | strip
    -%}

  <input type="radio"
        {% if option.selected_value == value -%} checked="checked"{%- endif %}
        {% unless variant_label_state -%} disabled="disabled"{%- endunless %}
         value="{{ value | escape }}"
         data-index="option{{ option_index }}"
         name="{{ option.name | handleize }}"
         class="single-option-selector-{{ section.id }} single-option-selector__radio{% unless variant_label_state %} disabled{% endunless %}"
         id="ProductSelect-option-{{ option.name | handleize }}-{{ value_handle }}">
    <label{% if label_class != blank %} class="{{ label_class }}"{% endif %}
      {%- if isColor %} title="{{ value | escape }}" style="{{ style_property }}"{% endif %}
          for="ProductSelect-option-{{ option.name | handleize }}-{{ value_handle }}">
      {%- if isColor -%}
        <span class="st-color-{{ value_handle }} st-color" style="{{ style_property }}"></span>
        <span class="">{{ value | escape }}</span>
      {%- else -%}
        {{ value | escape }}
      {%- endif -%}
    </label>
  {%- endfor -%}
</fieldset>
{%- else -%}
<select class="single-option-selector single-option-selector-{{ section.id }} product-form__input"
        id="SingleOptionSelector-{{ forloop.index0 }}"
        data-name="{{ option.name }}"
        data-index="option{{ loop }}">
  {%- for value in option.values -%}
  <option value="{{ value | escape }}"{% if option.selected_value == value %} selected="selected"{% endif %}>{{ value }}</option>
  {%- endfor -%}
</select>
{%- endif -%}
