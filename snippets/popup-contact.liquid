<dialog class="modal" id="jsContact">
  <div class="modal-dialog modal-dialog-form-product  modal-dialog-centered" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <button type="button" class="close" data-dismiss="modal">{%- render 'icon-close' -%}</button>
      </div>
        <div class="modal-body">
            <div class="d-flex flex-column">
            {%- form 'contact', class: 'isolate', id: 'contact_form-product' -%}
            {{ form.errors | default_errors }}
                <div class="text-center mb-5">
                    <h3>{{ 'contact.product.title_question' | t }}</h3>
                    <p>{{ 'contact.product.des_question' | t }}</p>
                </div>
                <div class="px-0 px-lg-4 pb-4">
                    <input class="field__input form-control hidden hide" type="text" id="ContactProduct-name" name="{{ product.title }}" value="" placeholder="">
                    <div class="field form-group">
                        <input class="field__input form-control" autocomplete="name" type="text" id="ContactFormProduct-name" name="contact[{{ 'contact.form.name' | t }}]" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}" placeholder="{{ 'contact.form.name' | t }}">
                        <label class="field__label" for="ContactFormProduct-name">{{ 'contact.form.name' | t }}</label>
                    </div>
                    <div class="field field--with-error form-group">
                        <input
                            autocomplete="email"
                            type="email"
                            id="ContactFormProduct-email"
                            class="field__input form-control"
                            name="contact[email]"
                            spellcheck="false"
                            autocapitalize="off"
                            value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                            aria-required="true"
                            {% if form.errors contains 'email' %}
                            aria-invalid="true"
                            aria-describedby="ContactFormProduct-email-error"
                            {% endif %}
                            placeholder="{{ 'contact.form.email' | t }}"
                        >
                        <label class="field__label" for="ContactFormProduct-email">{{ 'contact.form.email' | t }} <span aria-hidden="true">*</span></label>
                        {%- if form.errors contains 'email' -%}
                            <small class="contact__field-error" id="ContactFormProduct-email-error">
                            <span class="visually-hidden">{{ form.errors | default_errors }}</span>
                            <span class="form__message">{{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}</span>
                            </small>
                        {%- endif -%}
                    </div>
                    <div class="field form-group">
                    <input type="tel" id="ContactFormProduct-phone" class="field__input form-control" autocomplete="tel" name="contact[{{ 'contact.form.phone' | t }}]" pattern="[0-9\-]*" value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}" placeholder="{{ 'contact.form.phone' | t }}">
                    <label class="field__label" for="ContactFormProduct-phone">{{ 'contact.form.phone' | t }}</label>
                    </div>
                    <div class="field form-group">
                    <textarea
                        rows="10"
                        id="ContactFormProduct-body"
                        class="text-area field__input form-control form-control-area"
                        name="contact[{{ 'contact.form.message' | t }}]"
                        placeholder="{{ 'contact.form.message' | t }}"
                    >
                        {{- form.body -}}
                    </textarea>
                    <label class="form__label field__label" for="ContactFormProduct-body">{{ 'contact.form.message' | t }}</label>
                    </div>
                    <div class="contact__button text-center">
                        <button type="submit" class="button btn btn-theme">
                            {{ 'contact.form.send' | t }}
                        </button>

                    </div>
                </div>
            {%- endform -%}
            </div>
        </div>
    </div>
  </div>
</dialog>

{%- comment -%}
  Native <dialog> sizing/centering for #jsContact (was Bootstrap .modal.fade).
  The global dialog.modal reset (border/padding/background/margin/width +
  ::backdrop + :not([open])) lives globally and is NOT duplicated here.
  Only the per-modal geometry that Bootstrap's vendor CSS used to provide is
  reproduced: .modal-dialog-centered flex-centering + the inherited generic
  .modal-dialog max-width (960px @>=992, Bootstrap's 500px default below).
{%- endcomment -%}
<style>
  dialog.modal#jsContact[open] {
    display: flex;
    flex-direction: column;
    max-width: 100%;
    max-height: 100%;
  }
  dialog.modal#jsContact .modal-dialog {
    width: auto;
    margin: 0.5rem auto;
  }
  dialog.modal#jsContact .modal-dialog.modal-dialog-centered {
    display: flex;
    align-items: center;
    min-height: calc(100% - 1rem);
  }
  @media (min-width: 576px) {
    dialog.modal#jsContact .modal-dialog {
      max-width: 500px;
      margin: 1.75rem auto;
    }
    dialog.modal#jsContact .modal-dialog.modal-dialog-centered {
      min-height: calc(100% - 3.5rem);
    }
  }
  @media (min-width: 992px) {
    dialog.modal#jsContact .modal-dialog.modal-dialog-form-product {
      max-width: 960px;
    }
  }
</style>
