{%- if settings.enable_compare -%}
  <!-- popup-compare.liquid -->
  <style>
    /* Per-modal sizing/centering for native <dialog> (global reset lives in theme.css/native-ui).
       Reproduces Bootstrap .modal-dialog-centered + .modal-dialog--compare max-width (theme.css 6925). */
    dialog.modal .modal-dialog {
      display: flex;
      align-items: center;
      min-height: calc(100% - 1rem);
      margin: 0.5rem auto;
    }
    @media (min-width: 992px) {
      dialog.modal .modal-dialog.modal-dialog--compare {
        max-width: 960px;
        min-height: calc(100% - 3.5rem);
        margin: 1.75rem auto;
      }
    }
  </style>
  <dialog class="modal" id="jsCompare">
    <div class="modal-dialog modal-dialog--compare modal-dialog-centered" role="document">
      <div class="modal-content">
        <div class="modal-header p-0">
          <button type="button" class="close" data-dismiss="modal">{%- render 'icon-close' -%}
          </button>
        </div>
        <div class="modal-body p-0">
          <div class="row justify-content-center js-compare-content my-5"></div>
        </div>
      </div>
    </div>
  </dialog>
{%- endif -%}