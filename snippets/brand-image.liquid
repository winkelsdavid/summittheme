{%- comment -%}
  B1 brand-image — Bild mit Metaobject-Fallback.
  Params:
    handle    (Pflicht) section.type  ODER  section.type--block.type
    instance  (Pflicht) das Instanz-Setting (section.settings.x / block.settings.x)
    slot      (Section-Level) 1..12 — Position des Settings in Schema-Reihenfolge
    position  (Block-Level)   Positions-Nr. des Blocks GLEICHEN Typs (1-basiert)
    logo_fallback (optional)  true → shop.brand.logo als Letzt-Fallback
    class / sizes / width / alt (optional; width default 1600)
    attr_width (optional)  HTML-width-Attribut fuers <img> — Pflicht, wenn der
                           Instanz-Pfad attribut-dimensioniert ist (z.B. width="45");
                           ohne CSS-Sizing waechst das Fallback sonst auf
                           Containerbreite (img{max-width:100%} global)
    style (optional)       Inline-Style-Passthrough (z.B. --width-CSS-Vars)
{%- endcomment -%}
{%- liquid
  assign img = instance
  if img == blank
    if position != blank
      assign n = metaobjects.section_fallback[handle]['pool_size'].value | times: 1
      if n < 1
        assign n = 1
      endif
      assign idx = position | minus: 1 | modulo: n | plus: 1
    else
      assign idx = slot | default: 1 | times: 1
    endif
    assign fname = 'image_' | append: idx
    assign img = metaobjects.section_fallback[handle][fname].value
  endif
  if img == blank and logo_fallback == true
    assign img = shop.brand.logo
  endif
  assign w = width | default: 1600
-%}
{%- if img != blank -%}
  {%- if attr_width != blank and style != blank -%}
    {{ img | image_url: width: w | image_tag: loading: 'lazy', class: class, sizes: sizes, alt: alt, width: attr_width, style: style }}
  {%- elsif attr_width != blank -%}
    {{ img | image_url: width: w | image_tag: loading: 'lazy', class: class, sizes: sizes, alt: alt, width: attr_width }}
  {%- elsif style != blank -%}
    {{ img | image_url: width: w | image_tag: loading: 'lazy', class: class, sizes: sizes, alt: alt, style: style }}
  {%- else -%}
    {{ img | image_url: width: w | image_tag: loading: 'lazy', class: class, sizes: sizes, alt: alt }}
  {%- endif -%}
{%- endif -%}
