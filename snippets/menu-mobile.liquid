<style>
  /* Native <details> migration for drawer sub-menus (was Bootstrap collapse).
     Design mapped 1:1 from header-oncss.liquid (.drawer__nav-toggle--open/--close,
     .meganav--drawer) and header-css.liquid (.collapse:not(.show)). */

  /* Let the <details> dissolve so its <summary> (toggle) and the submenu <div>
     lay out exactly like the old <button> + sibling .collapse div did. */
  .drawer__nav-disclosure {
    display: contents;
  }

  /* Summary = the old toggle button. Remove the native disclosure marker and
     keep it interactive/right-aligned like .drawer__nav-toggle-btn (margin-left:auto). */
  .drawer__nav-disclosure > summary.drawer__nav-toggle-btn {
    cursor: pointer;
    list-style: none;
  }
  .drawer__nav-disclosure > summary.drawer__nav-toggle-btn::-webkit-details-marker {
    display: none;
  }
  .drawer__nav-disclosure > summary.drawer__nav-toggle-btn::marker {
    content: "";
  }

  /* Submenu wrapper breaks onto its own full-width line below the link row,
     replicating the original sibling .collapse.meganav--drawer placement. */
  .drawer__nav-disclosure > .meganav--drawer {
    flex: 0 0 100%;
    width: 100%;
  }

  /* +/- icon visibility, mapped from the old .collapsed state of the button:
       closed (was .collapsed)        -> Plus  (--open)  visible, Minus (--close) hidden
       open   (was no .collapsed)     -> Minus (--close) visible, Plus  (--open)  hidden */
  .drawer__nav-disclosure:not([open]) > summary .drawer__nav-toggle--open {
    display: block;
  }
  .drawer__nav-disclosure:not([open]) > summary .drawer__nav-toggle--close {
    display: none;
  }
  .drawer__nav-disclosure[open] > summary .drawer__nav-toggle--open {
    display: none;
  }
  .drawer__nav-disclosure[open] > summary .drawer__nav-toggle--close {
    display: block;
  }
</style>
<div id="NavDrawer" class="drawer drawer--left">
  <div class="drawer__inner">
    <div class="modal-header js-drawer-close py-4">
        <button type="button" class="close" ></button>
    </div>
    <ul class="drawer__nav menu-mobile-footer-content">
      {%- for link in linklists[settings.main_linklist].links -%}
        {%- assign child_list_handle = link.title | handleize -%}
        {%- if link.links != blank -%}
          <li class="drawer__nav-item">
            <div class="drawer__nav-has-sublist">
              <a href="{{ link.url }}" class="drawer__nav-link drawer__nav-link--top-level drawer__nav-link--split" id="DrawerLabel-{{ child_list_handle }}" {% if link.active %} aria-current="page"{% endif %}>
                {%- render 'processMenuTitle' , itemName: link.title -%}
                {%- render 'processMenuLabel' , itemName: link.title -%}
              </a>
              <details class="drawer__nav-disclosure">
                <summary class="text-link drawer__nav-toggle-btn" aria-label="{%- render 'processMenuTitle' , itemName: link.title -%}">
                  <span class="drawer__nav-toggle--open">
                    {%- render 'icon-plus' -%}
                  </span>
                  <span class="drawer__nav-toggle--close">
                    {%- render 'icon-minus' -%}
                  </span>
                </summary>
                <div class="meganav meganav--drawer" id="DrawerLinklist-{{ child_list_handle }}" aria-labelledby="DrawerLabel-{{ child_list_handle }}" role="navigation">
                  <ul class="meganav__nav">
                    {%- render 'drawer-nav', link: link -%}
                  </ul>
                </div>
              </details>
            </div>
          </li>
        {%- else -%}
          <li class="drawer__nav-item">
            <a href="{{ link.url }}" class="drawer__nav-link drawer__nav-link--top-level" {% if link.active %} aria-current="page"{% endif %}>
              {%- render 'processMenuTitle' , itemName: link.title -%}
              {%- render 'processMenuLabel' , itemName: link.title -%}
            </a>
          </li>
        {%- endif -%}
      {%- endfor -%}
      
    </ul>
    <ul class="menu-mobile-footer drawer__nav">
      {% if settings.mobile_phone != blank %}
        <li class="drawer__nav-item drawer-nav__item--secondary">
          <a href="tel:{{ settings.mobile_phone | strip }}" class="drawer__nav-link drawer__nav-link--top-level font-weight-normal pr-1 d-flex align-items-center letter-spacing-0">
            {% render 'icon-mobile-phone' %}
            <span class="pl-2">{{ settings.mobile_phone}}</span>
          </a>
        </li>
      {% endif %}
      {% if settings.mobile_email != blank %}
      <li class="drawer__nav-item drawer-nav__item--secondary">
        <a href="mailto:{{ settings.mobile_email }}" class="drawer__nav-link drawer__nav-link--top-level font-weight-normal pr-1 d-flex align-items-center letter-spacing-0">
          {% render 'icon-email' %}
          <span class="pl-2">{{ settings.mobile_email }}</span>
        </a>
      </li>
    {% endif %}
      {%- if settings.login_enable -%}
        {%- if shop.customer_accounts_optional or shop.customer_accounts_enabled -%}
          {%- if customer -%}
            <li class="drawer__nav-item drawer-nav__item--secondary">
              <a href="/account" class="drawer__nav-link drawer__nav-link--top-level font-weight-normal d-flex align-items-center">
                <span class="account-text letter-spacing-0 pl-2">{{ 'layout.customer.account' | t }}
                </span>
              </a>
            </li>
          {%- else -%}
            <li class="drawer__nav-item drawer-nav__item--secondary d-flex align-items-center d-flex align-items-center">
              <a href="/account" class="drawer__nav-link drawer__nav-link--top-level font-weight-normal pr-1 d-flex align-items-center">
                {% render 'icon-user' %}
                <span class="account-text letter-spacing-0 pl-2">{{ 'customer.login.sign_in' | t }}
                </span>
              </a> 
              <span class="drawer__nav-link--top-level small px-1">/</span> 
              <a href="/account/register" class="drawer__nav-link drawer__nav-link--top-level font-weight-normal pl-1 letter-spacing-0 d-flex align-items-center">
                {{ 'customer.register.title' | t }}
              </a>
            </li>
          {%- endif -%}
        {%- endif -%}
      {%- endif -%}
      
      <li class="drawer__nav-item drawer-nav__item--secondary py-3 pl-2 d-flex">
        {%- if settings.currency_enable -%}
          <span class="pr-4">
            {% render 'localization' id: 'HeaderCountryFormMobile' , header-left : 'header-left' %}
          </span>
        {%- endif -%}
        {%- if settings.lang_enable -%}
        {% render 'localization-language', id: 'HeaderLanguageFormMobile', header-left : 'header-left' %}
      {%- endif -%}
      </li>
    </ul>
  </div>
</div>