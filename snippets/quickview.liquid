{%- liquid
  # Quick View image ratio — its OWN setting (Theme settings > Quick View >
  # Image Ratio): 1:1 or 2:3. The whole modal adapts to this ratio.
  case settings.qv_image_ratio
    when '2x3'
      assign qv_ar = '2 / 3'
    else
      assign qv_ar = '1 / 1'
  endcase
-%}
<style>
  .qv-content{text-align:left}.rtl .qv-content{text-align:right}#qv-product-images{margin:0;opacity: 0;transition: opacity 0.1s ease-in;}#jsQuickview .option-selection{margin-bottom:16px}#jsQuickview select.option{width: calc(100% - 120px);}#jsQuickview span.option{min-width:120px;display:inline-block;text-transform:capitalize;margin-bottom:6px;}#jsQuickview .qv-product-price{display:inline-block;margin:0}#jsQuickview .qv-product-price .money{color:{{ settings.color_primary }}}#jsQuickview .qv-product-description{max-height:180px;overflow:hidden;position:relative;}#jsQuickview .qv-product-description:after{position:absolute;content:"";width:100%;left:0;bottom:0;background:#fff}.rtl #jsQuickview .qv-product-description:after{right:0;left:auto}.qv-add-to-cart .quantity{height:40px;width:100px}.qv-add-to-cart .quantity span{display:none}.qv-quantity{height:50px;width:100%;text-align:center;}
  #jsQuickview .option-selection.color .single-option-radio{
    padding-left:8px;
    padding-top:4px;
  }
  .qv-content{
    /* height now follows the image ratio (set in the Image Ratio block below);
       the content scrolls inside that height instead of a fixed 620px. */
    height: auto;
    position:relative;
  }
  .loadqvpopup .qv-content-holder{
    overflow-y:auto;
  }
  .loadqvpopup .qv-content-holder::-webkit-scrollbar-track
{
  /*-webkit-box-shadow: inset 0 0 6px rgba(0,0,0,0.3);*/
  background-color: rgba(var(--g-color-heading-rgb),0.05);
}

.loadqvpopup .qv-content-holder::-webkit-scrollbar
{
  width: 4px;
  /*background-color: #F5F5F5;*/
}

.loadqvpopup .qv-content-holder::-webkit-scrollbar-thumb
{
  background-color: rgba(var(--g-color-heading-rgb),0.18);
}
  .qv-content:after{
    position:absolute;
    content:"";
    background:linear-gradient(to bottom,rgba(255,255,255,0) 86%,rgba(255,255,255,1) 100%);
    width: 100%;
    height: 100%;
    pointer-events: none;
    bottom:0;
    left:0;
    z-index:1;
  }
  .qv-content .spr-badge-caption{
    font-size: calc(var(--g-font-size) - 2px);
    color:rgba(var(--color-body-text-rgb),0.7);
  }
  .qv-content .spr-icon{
    top:0px;
    width:auto;
  }
  .qv-content .spr-icon:before{
    font-size: 14px !important;
  }
  .qv-product-rv{
    /* no fixed reserve -> price sits right under the title when there are no
       reviews; the badge still expands naturally when reviews load. */
    min-height:0;
  }
  /* price closer to the title */
  #jsQuickview .qv-product-title{ padding-bottom: 4px !important; }
  #jsQuickview .qv-product-rv{ padding-bottom: 8px !important; }
  .qv-product-rv .spr-badge{
    display:flex;
    align-items:center;
  }
  .qv-content .spr-badge-starrating{
    margin-right: 6px;
    font-size:14px;
  }
  @media (min-width:1000px){
    #qv-product-images{min-height: 0;margin:0}
  }
  @media( max-width:999px ){
    .qv-content{
      padding: 0 !important;
    }
  }
  @media (min-width: 768px){
    .qv-content-holder{
    padding-right:2.3rem;
    }
  }

  .qv-product-title{
    font-size: calc(var(--g-h3-font-size) - 0.2rem);
  }
  .qv-product-compare-price{
    color:rgba(var(--color-body-text-rgb), 0.6);
  }
  input.qv-quantity[type=number]::-webkit-inner-spin-button,
  input.qv-quantity[type=number]::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  input.qv-quantity[type=number] {
    -moz-appearance: textfield;
    background-color: transparent;
  }
  .popup-quantity{
    border:1px solid var(--g-input-border);
    border-radius: var(--g-font-radius-btn);
  }
  .qv-minus,.qv-plus{
    flex:0 0 1.6rem;
    text-align: center;
    font-size: calc(var(--g-font-size) + 2px);
  }
  .list-product-options select{display:none;}
  .list-product-options label{cursor: pointer;margin-right: 0px;}
  .list-product-options label.active:after{
    border-color: var(--g-color-heading);
    opacity: 1;
    transform: scale(1);
    box-shadow: inset 0px 0px 0px 2px rgba(var(--g-color-heading-rgb),1) !important;
  }
  .list-product-options label.have-background{text-indent: -9999px;}
  .square-color-txt.list-product-options label.have-background{
    text-indent:inherit;
  }
  .square-color-txt label.have-background{
    background:none;
  }
  .square-color-txt label.have-background .st-color{
    width: 16px;
    height: 16px;
    background-size: cover;
    margin-right: 8px;
    border-radius: 50%;
  }
  
  .round-color.list-product-options label.have-background, .square-color.list-product-options label.have-background{
    min-width: 24px;
    height: 24px;
    border: none;
    border-radius: 50%;
    box-shadow: inset 0 0 0 1px rgba(var(--color-black), .15);
    background-size: 105% !important; 
    padding:0;
    margin: 6px 0;
  }
  
  .round-color.list-product-options label.have-background:after, .square-color.list-product-options label.have-background:after{
    border-radius: 50%;
    top: -6px;
    right: -6px;
    bottom: -6px;
    left: -6px;
    box-shadow: none;
  }
  .square-color.list-product-options label.have-background, .square-color.list-product-options label.have-background:after{
    border-radius: 0;
  }

  /*.round-color.list-product-options .color label[data-value=white], .round-color.list-product-options .color label[data-value=White]{
    border:1px solid #ddd!important;
  }*/

  /* --- native <dialog> centering/sizing for #jsQuickview ---
     Reproduces Bootstrap's .modal (flex container) + .modal-dialog-centered
     vertical centering + .modal-lg width, since the vendor Bootstrap CSS that
     used to supply this geometry no longer applies to the <dialog>.
     The global dialog.modal reset (border/padding/background/margin/::backdrop)
     is defined globally and is intentionally NOT duplicated here. */
  dialog#jsQuickview.modal{
    display:flex;
    align-items:center;
    justify-content:center;
  }
  dialog#jsQuickview.modal:not([open]){
    display:none;
  }
  dialog#jsQuickview .modal-dialog{
    width:100%;
    max-width:900px;
    margin:auto;
  }

  /* ============ Quick View "Image Ratio" layout ({{ qv_ar }}) ============
     Pure CSS scroll-snap gallery (no jQuery, no Slick, no slider library). The
     image COVERS its column (object-fit:cover) -> never any whitespace. The
     aspect-ratio is the BASELINE shape of the image area; the modal height
     follows the CONTENT so nothing has to be scrolled inside the modal: both
     columns grow to the taller of (image ratio, content) and stay equal. */
  #qv-product-images{ min-height: 0; position: relative; height: 100%; }
  #jsQuickview .left-qv{ background-color: var(--color-item-product); overflow: hidden; }

  /* horizontal scroll-snap track + slides fill the column; image covers it */
  #qv-product-images .qv-track{
    display: flex;
    width: 100%; height: 100%;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  #qv-product-images .qv-track::-webkit-scrollbar{ display: none; }
  #qv-product-images .qv-slide{ flex: 0 0 100%; height: 100%; scroll-snap-align: start; }
  #qv-product-images .qv-slide img{ display: block; width: 100%; height: 100%; object-fit: cover; background-color: var(--color-item-product); }

  /* vanilla arrows (hover-reveal) + dots */
  #qv-product-images .qv-nav{
    position: absolute; top: 50%; transform: translateY(-50%); z-index: 2;
    width: 36px; height: 36px; padding: 0; border: 0; border-radius: 50%;
    background: rgba(255,255,255,.85); color: #000; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    opacity: 0; transition: opacity .3s ease;
  }
  #qv-product-images:hover .qv-nav{ opacity: 1; }
  #qv-product-images .qv-prev{ left: 12px; }
  #qv-product-images .qv-next{ right: 12px; }
  #qv-product-images .qv-dots{ position: absolute; left: 0; right: 0; bottom: 12px; z-index: 2; display: flex; gap: 6px; justify-content: center; }
  #qv-product-images .qv-dot{ width: 7px; height: 7px; padding: 0; border: 0; border-radius: 50%; background: rgba(0,0,0,.25); cursor: pointer; transition: background .2s; }
  #qv-product-images .qv-dot.is-active{ background: rgba(0,0,0,.85); }

  /* image area = the chosen ratio as a MINIMUM; the modal grows with content. */
  @media (max-width: 991px){
    #jsQuickview .left-qv{ aspect-ratio: {{ qv_ar }}; }
  }
  @media (min-width: 992px){
    /* both columns equal height = max(image ratio, content); image covers it,
       content is fully visible -> NO internal scrolling. */
    #jsQuickview .modal-body > .row{ align-items: stretch; }
    #jsQuickview .left-qv{ aspect-ratio: {{ qv_ar }}; align-self: stretch; }
    /* override Bootstrap .align-self-center on the content column */
    #jsQuickview .right-qv{ align-self: stretch !important; }
  }

  /* no internal scroll anymore -> drop the bottom scroll-fade cue */
  #jsQuickview .qv-content:after{ display: none; }

  /* Add-to-cart row: qty (fixed) + button (fills the rest) on one flex line.
     Label stays on one line; it only wraps if the window gets too narrow (it is
     never cut off). */
  #jsQuickview .qv-add-to-cart > .d-flex{ gap: 12px; align-items: center; }
  #jsQuickview .qv-add-to-cart .quantity{ float: none; flex: 0 0 auto; }
  #jsQuickview .qv-add-button{ flex: 1 1 auto; min-width: 0; width: auto; margin: 0; float: none; white-space: normal; padding-left: 1rem; padding-right: 1rem; }

</style>
<!-- quickview.liquid -->
<dialog class="modal bd-example-modal-lg" id="jsQuickview" data-type="{{ settings.select_product_option_display }}" data-color="{{ settings.qv_variant }}">
  <div class="modal-dialog modal-dialog-centered modal-lg" role="document">
    <div class="modal-content">
      <div class="modal-header p-0">
        <button type="button" class="close" data-dismiss="modal">{%- render 'icon-close' -%}</button>
      </div>
      <div class="modal-body p-0">
        <div class="row m-0">
          <div id="loading_qv"><span class="loader-line"></span></div>
          <div class="col-lg-6 p-0 left-qv">
            <div id="qv-product-images" class="qv-product-images"></div>
          </div>
          <div class="qv-content col-lg-6 d-flex flex-column align-items-center align-self-center right-qv pr-0">
            <div class="holder h-100 pl-md-4 w-100 qv-content-holder py-md-4 ">
              <h3 class="qv-product-title pb-2 mb-0"></h3>
              {%- if settings.enable_review -%}
                <div class="qv-product-rv pb-3"> </div>
              {%- endif -%}
              <h5 class="qv-product-price font-family-2 mb-3"></h5>
              <s class="qv-product-compare-price ml-2"></s>
              {%- if settings.qv_des -%}
              <div class="qv-product-description mb-1 txt-body-70"></div>
              {%- endif -%}
              <div class="qv-add-to-cart clearfix pt-3 pb-4">
                {%- if settings.select_product_option_display == 'list' -%}
                	<div class="qv-product-options list-product-options {% if settings.type_color == 'circle' %} round-color {% elsif settings.type_color == 'square' %} square-color {% else %} square-color-txt {% endif %}"></div>
                {%- else -%}
            <div class="qv-product-options"></div>
                {%- endif -%}
                <div class="d-flex">
                  <div class="quantity popup-quantity d-flex h-100 align-items-center">
                    <span class="hide">{{ 'products.product.quantity' | t }}</span>
                    <div class="qv-minus"><a class="qv-qtity disabled-anchor d-block" href="#" data-multi="-1">-</a></div>
                    <input type="number" class="qv-quantity" value="1" min="1">
                    <div class="qv-plus"><a class="qv-qtity disabled-anchor d-block" href="#" data-multi="1">+</a></div>
                  </div>
                  <button type="submit" class="btn btn-theme gradient-theme qv-add-button">{{ 'general.quickview.addtocart' | t }}</button>
                </div>
              </div>
              {%- render 'free-shipping' -%}
              <div class="pt-4">
                {%- if settings.qv_sku -%}
                <div class=" text-uppercase qv-sku"><small class="text-body d-inline-block" style="min-width: 80px;">{{ 'general.quickview.sku' | t }}: </small><small class="qv-view-sku text-uppercase"></small></div>
                {%- endif -%}
                {%- if settings.qv_type -%}
                <div class="text-uppercase"><small class="text-body d-inline-block" style="min-width: 80px;">{{ 'general.quickview.type' | t }}: </small><small class="qv-view-type text-uppercase"></small></div>
                {%- endif -%}
                {%- if settings.qv_vendor -%}
                <div class="text-uppercase"><small class="text-body d-inline-block" style="min-width: 80px;">{{ 'general.quickview.vendor' | t }}: </small><small class="qv-view-vendor text-uppercase"></small></div>
                {%- endif -%} 
              </div>
            
              <div class="pt-4 ">
                <a class="qv-view-product small link" href="#">
                  {{ 'general.quickview.view_full' | t }}
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</dialog>
