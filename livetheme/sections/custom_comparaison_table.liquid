<style>
  {% assign tables_count = 0 %}
  {% for block in section.blocks %}
    {% if block.type == "table" %}
    {% assign tables_count = tables_count | plus : 1 %}
    {% endif %}
  {% endfor %}
 .c_{{ section.id }}{
    background:{{ section.settings.background }};
     padding-top:{{ section.settings.padding_top }}px;
    padding-bottom:{{ section.settings.padding_bottom }}px;
    {% if section.settings.h_s_color != blank %}
      {% if section.settings.h_s_color != "rgba(0,0,0,0)" %}
    --g-color-heading:{{ section.settings.h_s_color   }};
    --g-font-color-subtop:{{ section.settings.h_s_color   }};
      {% endif %}
    {% endif %}
  }
.comparaison_c_heading{
display:flex;
flex-wrap:wrap;
overflow:hidden;
padding-top:20px;
}

.c_{{ section.id }} .c_comparaison_elements{
   {% if tables_count == 3 %}
    flex:0 0 75%;
  {% else %}
 flex:0 0 66.66%;
  {% endif %}

display:flex;
}
.c_{{ section.id }} .comparaison_h{
   {% if tables_count == 3 %}
   flex:0 0 calc(100% / 3);
  {% else %}
 flex:0 0 calc(100% / 2);
  {% endif %}

  position:relative;
}
.c_{{ section.id }} .comparaison_info{
  {% if tables_count == 3 %}
    flex:0 0 25%;
  {% else %}
 flex:0 0 33.33%;
  {% endif %}
display:flex;
flex-direction:column;
justify-content:center;
}
.comparaison_h:not(.comparaison_info){
      padding: 16px 12px 8px;
}
.c_{{ section.id }} .badge_c {
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    margin-bottom: 0;
    gap: 6px;
    position: absolute;
    top: 0;
    z-index:2;
    left: 50%;
    transform: translate(-50%,-50%);
    width: max-content;
    max-width: 95%;
    overflow: hidden;
    padding:8px;
    border-radius:20px;
    font-size:{{ section.settings.badge_font_size }}px;
}
    {% if section.settings.enable_animation %}
.c_{{ section.id }}  .badge_c:after{
    background-image: linear-gradient(90deg,transparent,hsla(0,0%,100%,.3),transparent);
    content: "";
    height: 100%;
    left: -150%;
    position: absolute;
    top: 0;
    transform: skew(20deg);
    width: 150%;
    animation: leftToRightShade {{ section.settings.animation_delay }}s cubic-bezier(.01,.56,1,1) infinite forwards;
    animation-delay:{{ section.settings.animation_delay }}s;
    }

    @keyframes leftToRightShade{
        0% { left: -150%; }
        33.33% { left: 150%; }
        100% { left: 150%; }
}
{% endif %}
.media_image{
  position:relative;
  padding-top:100%;
}
.media_image.p{
  padding-top:calc(300%/4);
}
.media_image.a{
padding-top:0;
}
.media_image.l{
padding-top:calc(300%/2);
}
.media_image.cover img{
object-fit:cover;
}
.media_image.contain img{
  object-fit:contain;
}
.media_image img{
position:absolute;
top:0;
left:0;
width:100%;
height:100%;
}
.media_image.a img{
  position:relative;
} 
.c_{{ section.id }} .comparaison_elements{
    background: {{ section.settings.column_bk }};
    {% if settings.enable_radius_allimg %}
    border-radius: calc(0.2rem * {{ settings.radius_allimg_range }});
    {% endif %}
    padding: 0 0px 20px;
}
.comparaison_h p{
    margin: 24px 0 16px;
    line-height:1;
}
.centered .comparaison_h p{
text-align:center;
}
.comparaison_elements{
display:flex;
}
.c_{{ section.id }} .comparaison_item{
   {% if tables_count == 3 %}
    flex:0 0 25%;
  {% else %}
 flex:0 0 33.33%;
  {% endif %}
  padding-bottom: 20px;
  {% if settings.enable_radius_allimg %}
  border-bottom-left-radius: calc(0.2rem * {{ settings.radius_allimg_range }});
  border-bottom-right-radius: calc(0.2rem * {{ settings.radius_allimg_range }});
  {% endif %}
}
.c_{{ section.id }} .comp_heading {
    display: flex;
    align-items: center;
    padding: 24px 8px 24px 20px;
    margin: 0;
    gap: 8px;
    color:{{ section.settings.color }};
    border-bottom: 1px solid ;
    height:90px;
   
}
.comp_heading:last-child{
  border-bottom:unset;
}
.c_{{ section.id }} .comp_heading p{
  color:{{ section.settings.color }};
 line-height:1;
}
.comp_heading img{
height:32px;
width:32px;
object-fit:contain;
}
.c_{{ section.id }} .table_item{
      padding: 24px 16px;
       border-bottom: 1px solid ;
        color:{{ section.settings.color }};
        height:90px;
        display:flex;
        align-items:center;
        line-height:1;
}
.centered .table_item{
text-align:center;
justify-content:center;
}
.table_item:last-child{
  border-bottom:unset;
}

.c_{{ section.id }} .table_item svg{
  height:auto;
  width:auto;
  fill:{{ section.settings.tick_cross_color }};
}
/*.c_{{ section.id }} .table_item svg path{
  stroke:{{ section.settings.color }}!important;
}*/
.c_{{ section.id }} .highlited{
{%  if section.settings.highlights_bk != blank %}
background:{{ section.settings.highlights_bk }};
{%  else %}
background:{{ settings.branding_color }};
{% endif %}
}
.c_{{ section.id }}  .check_color{
  color:{{ section.settings.check_color }};
}
.c_{{ section.id }} .cross_color{
color:{{ section.settings.cross_color }};
}
.comparaison_h.highlited{
border:1px solid black;
border-bottom:unset;
{% if settings.enable_radius_allimg %}
border-top-left-radius:calc(0.2rem * {{ settings.radius_allimg_range }});
border-top-right-radius: calc(0.2rem * {{ settings.radius_allimg_range }});
{% endif %}
}
.comparaison_item.highlited{
  border:1px solid black;
  border-top:unset;
}
.c_{{ section.id }} .comparaison_item.highlited .table_item {
  color:{{ section.settings.highlights_color }};
}
/*.c_{{ section.id }} .comparaison_item.highlited .table_item  svg path{
  stroke:{{ section.settings.highlights_color }}!important;
}*/
.c_{{ section.id }} .comparaison_h p{
  font-size:{{ section.settings.table_h_font_size }}px
}
.c_{{ section.id }} .comparaison_item  .table_item,
.c_{{ section.id }} .comp_heading p{
  font-size:{{ section.settings.table_c_font_size }}px
}
    @media (max-width:768px){
      .c_{{ section.id }}{
         padding-top:{{ section.settings.mobile_padding_top }}px;
          padding-bottom:{{ section.settings.mobile_padding_bottom }}px;
      }   

     .c_{{ section.id }} .badge_c {
      font-size:{{ section.settings.mobile_badge_font_size }}px
     }
     .c_{{ section.id }}  .c_comparaison_elements{
        margin-left:calc(100% / 3);
        flex:0 0 100%;
      }
     .c_{{ section.id }}   .comparaison_h {
          flex: 0 0 calc(100% / 3);
          width:calc(100%/3);
          word-break: break-word;
        overflow-wrap: break-word;
      }
         .c_{{ section.id }}    .comparaison_info{
          flex: 0 0 100%;
          text-align: center;
          position: sticky;
        left: 0;
      }
     .c_{{ section.id }}  .comparaison_item {
           flex: 0 0 calc(100% / 3);
           width:calc(100% / 3);
        }
        .c_{{ section.id }}  .comparaison_item *{
          word-break: break-word;
          overflow-wrap: break-word;
        }
       /* .comparaison_elements{
          border-top-right-radius:unset;
          border-radius:unset;
        }*/
        .comparaison_c_heading{
          scrollbar-width:none;
        }
        .comparaison_c_heading.three,
        .comparaison_elements.three{
          overflow:auto; 
        }
        .c_{{ section.id }} .comparaison_h p{
          font-size:{{ section.settings.table_h_font_size_mobile }}px
        }
        .c_{{ section.id }} .comparaison_item  .table_item,
        .c_{{ section.id }} .comp_heading p{
