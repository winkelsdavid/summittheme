</style>
<div class="comparaison_table c_{{ section.id }}" data-aos="{{ section.settings.animation }}">
  <div class="{{ section.settings.setwidth }} {% if section.settings.center_content %} centered {% endif %}">
  <div class="comparaison_c_heading {% if tables_count == 3 %} three {% endif %}">
    <div class="comparaison_info comparaison_h">
      {% if section.settings.subtitle != blank %}
      <div class="subtop text-top mb-2 aos-init aos-animate"  data-aos="{{ section.settings.animation }}" data-aos-duration="200">{{ section.settings.subtitle }}</div>
      {% endif %}
      {% if section.settings.title != blank %}
      <h3 class="h3 mb-5 aos-init aos-animate" data-aos="{{ section.settings.animation }}" data-aos-duration="500">
        <span>{{ section.settings.title }}</span>
      </h3>
    {% endif %}
    </div>
<div class="c_comparaison_elements {% if tables_count == 3 %} three {% endif %}">
    {% assign highlists_position = 1 %}
    {% if section.settings.h_position == "s" %}
        {% assign highlists_position = 2 %}
    {% elsif section.settings.h_position == "t" %}
        {% assign highlists_position = 3 %}
    {% endif %}
    {% assign loop_i = 0 %}
    {% for block in section.blocks %}
        {% if block.type == "table" %}
          {% assign loop_i = loop_i | plus : 1 %}
            <div class="comparaison_h {% if section.settings.highlights %}{% if loop_i == highlists_position %} highlited {% endif %}{% endif %}">
              {% if block.settings.image != blank %}
                <div class="table_media">
                  {% if loop_i == highlists_position %}
                  {% if section.settings.badge_text != blank %}
                    <div class="badge_c" style="background:{{ section.settings.badge_background }};color:{{ section.settings.badge_color }};border-radius:{{ section.settings.badge_round }}px;">
                      {% if section.settings.icon_style == "star" %}
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="17" viewBox="0 0 18 17" fill="none">
                          <path d="M9 0L11.0206 6.21885H17.5595L12.2694 10.0623L14.2901 16.2812L9 12.4377L3.70993 16.2812L5.73056 10.0623L0.440492 6.21885H6.97937L9 0Z" fill="var(--badge-icon-text-color)"></path>
                        </svg>
                      {% elsif section.settings.icon_style == "heart" %}
                          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="16" viewBox="0 0 18 16" fill="none">
                            <circle cx="13.1999" cy="4.8" r="4.8" fill="var(--badge-icon-text-color)"></circle>
                            <circle cx="4.8" cy="4.8" r="4.8" fill="var(--badge-icon-text-color)"></circle>
                            <path d="M0.632812 7.2002H17.3578C17.3578 7.2002 17.0529 7.94131 16.8 8.4002C14.7994 12.0309 9 15.6002 9 15.6002C9 15.6002 3.20061 12.0309 1.2 8.4002C0.947142 7.94131 0.632812 7.2002 0.632812 7.2002Z" fill="var(--badge-icon-text-color)"></path>
                          </svg>
                      {% endif %}
                        <span>{{ section.settings.badge_text }}</span>
                    </div>
                  {% endif %}
                {% endif %}
                  <div class="media_image {{ section.settings.image_ratio }} {{ section.settings.image-fit }}">
                    <img src="{{ block.settings.image | img_url:"1000X" }}" loading="lazy">
                  </div>
                </div>
              {% endif %}
              {% if block.settings.heading != blank %}
                  <p>{{ block.settings.heading }}</p>
              {% endif %}
            </div>
        {% endif %}
  {% endfor %}
</div>
  </div>
  <div class="comparaison_elements {% if tables_count == 3 %} three {% endif %}">
    <div class="comparaison_item comparaison_titles">
      {% for block in section.blocks %}
        {% if block.type == "heading" %}
          {% for ii in (1..10) %}
            {% assign heading = "heading_" | append: forloop.index %}
            {% assign icon = "icon_" | append: forloop.index %}
            {% if block.settings[heading] != blank %}
                <div class="comp_heading">
                  {% if block.settings[icon] != blank %}
                    <img src='{{ block.settings[icon] | img_url:"100x" }}' loading="lazy" height="32" width="32">
                  {% endif %}
                  <p>{{ block.settings[heading] }}</p>
                </div>
            {% endif %}
          {% endfor %}
        {% endif %}
      {% endfor %}
    </div>
    {% assign loop_i = 0 %}
    {% for block in section.blocks %}
      {% if block.type == "table" %}
        {% assign loop_i = loop_i | plus : 1 %}
          <div class="comparaison_item {% if section.settings.highlights %}{% if loop_i == highlists_position %} highlited {% endif %}{% endif %}">
              {% for ii in (1..10) %}
                {% assign value = "value_" | append: forloop.index %}
                {% assign icon = "icon_" | append: forloop.index %}
              {% if block.settings[icon] != "none" %}
                  <div class="table_item">
                    {% if block.settings[icon] == "tick" %}
                      <svg xmlns="http://www.w3.org/2000/svg" class="check_color" xmlns:xlink="http://www.w3.org/1999/xlink" version="1.1"  height="32" width="32" id="Layer_1" x="0px" y="0px" viewBox="0 0 100 100" style="enable-background:new 0 0 100 100" xml:space="preserve"><path class="st0" d="M50,2.5C23.7700195,2.5,2.5,23.7700195,2.5,50S23.7700195,97.5,50,97.5c26.2300415,0,47.5-21.2700195,47.5-47.5  S76.2300415,2.5,50,2.5z M79.1600342,36.4699707L44.8200073,70.8099976C43.7399902,71.8900146,42.2800293,72.5,40.75,72.5  c-1.5199585,0-2.9899902-0.6099854-4.0599976-1.6900024L20.8400269,54.9699707  c-1.1199951-1.1199951-1.1199951-2.9399414,0-4.0599976l4.0700073-4.0699463c1.1199951-1.1200562,2.9400024-1.1200562,4.0599976,0  L40.75,58.6199951l30.2800293-30.2799683c1.1199951-1.1200562,2.9400024-1.1200562,4.0599976,0l4.0700073,4.0699463  C80.2800293,33.5300293,80.2800293,35.3499756,79.1600342,36.4699707z"/></svg>
                    {% elsif block.settings[icon] == "cross" %}
                     <svg xmlns="http://www.w3.org/2000/svg" class="cross_color" xmlns:xlink="http://www.w3.org/1999/xlink" version="1.1" height="32" width="32" id="Layer_1" x="0px" y="0px" viewBox="0 0 100 100" style="" xml:space="preserve"><path class="st0" d="M83.5875626,16.4124355c-18.5473938-18.5473976-48.6277008-18.5474396-67.1751404,0  c-18.5473976,18.5473957-18.5473976,48.6277466,0,67.1751404s48.6277466,18.5474014,67.1751404,0  C102.1350021,65.0401382,102.134964,34.9598312,83.5875626,16.4124355z M64.0219345,71.0930176L49.9999924,57.0710754  L35.978096,71.0929718c-1.9586983,1.9587021-5.1194458,1.951622-7.0710678,0s-1.9587002-5.1123657,0-7.0710678  l14.0218964-14.0218964L28.9069843,35.9780693c-1.9586563-1.9586563-1.951622-5.1194477,0-7.0710678  s5.1124134-1.9586563,7.0710697,0l14.0219383,14.0219383l14.0219421-14.0219383c1.9586945-1.9587002,5.1194458-1.951622,7.0710678,0  s1.9586945,5.1123657,0,7.0710678L57.0710602,50.0000076l14.0219421,14.0219421c1.9586563,1.9586563,1.951622,5.1194458,0,7.0710678  S65.9805908,73.0516739,64.0219345,71.0930176z"/></svg>
                    {% endif %}
                  </div>
                {% else %}
                  {% if block.settings[value] != blank  %}
                  <div class="table_item">
                     {{ block.settings[value] }}
                  </div>
                {% endif %}
                {% endif %}
              {% endfor %}
          </div>
      {% endif %}
    {% endfor %}
     </div>
  </div>
</div>
<script>
 function initializeScrollSync() {
  const heading = document.querySelector('.comparaison_c_heading');
  const elements = document.querySelector('.comparaison_elements');

  if (heading && elements) {
    function syncScroll(source, target) {
      source.addEventListener('scroll', () => {
        target.scrollLeft = source.scrollLeft;
      });
    }

    // Remove previous listeners if needed (optional)
    heading.replaceWith(heading.cloneNode(true));
    elements.replaceWith(elements.cloneNode(true));

    // Re-select after cloning
    const newHeading = document.querySelector('.comparaison_c_heading');
    const newElements = document.querySelector('.comparaison_elements');

    syncScroll(newHeading, newElements);
    syncScroll(newElements, newHeading);
  }
}
document.addEventListener('shopify:section:load', initializeScrollSync);
document.addEventListener('DOMContentLoaded', initializeScrollSync);

</script>

