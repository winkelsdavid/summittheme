<style>
  .c-{{ section.id }}{
  padding-top:{{  section.settings.mobile_padding_top }}px;
  padding-bottom:{{  section.settings.mobile_padding_bottom }}px;
  background:{{ section.settings.background }};
  }
   .image-tabs-c{
      gap: 3rem;
      display:grid;
  }
  .image-tabs-images{
  height:500px;
  overflow:hidden;
  position:relative;
  border-radius:calc(0.2rem * {{ settings.radius_allimg_range }});
  }
  .c-{{ section.id }} .image-tabs-images{
  height:{{ section.settings.image_height_mobile }}px;
  }
  .image-tabs-image{
  height:100%;
  width:100%;
  overflow:hidden;
  position:absolute;
  top:0;
  left:0;
  transition-property: opacity, transform;
  transition-timing-function: cubic-bezier(.4, 0, .2, 1);
  transition-duration: .5s;
  opacity:0;
  transform:scale(1.1);
  }
  .image-tabs-image.active{
    opacity:1;
    transform:scale(1);
  }
  .image-tabs-image img{
  width:100%;
  height:100%;
  object-fit:cover;
  }
  .image-tabs-text{
    padding:42px 0;
    transition-property: all;
    transition-timing-function: cubic-bezier(.4,0,.2,1);
    transition-duration: .5s;
    border-bottom:1px solid #4040401a;
    cursor:pointer;
  }
   .image-tabs-text .icon_and_title{
  display:flex;
  gap:8px;
  align-items:center;
  }
  .image-tabs-text .icon_and_title img{
  width:var(--width-mobile);
  }
  .image-tabs-text h3{
    transition-property: color,background-color,border-color,text-decoration-color,fill,stroke;
    transition-timing-function: cubic-bezier(.4,0,.2,1);
    transition-duration: .5s;
    --g-color-heading:#40404073;
  }
  .c-{{ section.id }} .image-tabs-text h3{
   {% if section.settings.heading_color != blank and section.settings.heading_color != "rgba(0,0,0,0)" %}
    --g-color-heading:{{ section.settings.heading_color }};
    {%  endif %}
  }
   .image-tabs-text p{
    margin:0;
        transition-property: max-height,opacity,margin;
    transition-timing-function: cubic-bezier(.4,0,.2,1);
    transition-duration: .5s;
    max-height:0px;
    opacity:0;
    color:#40404073;
  }
  .c-{{ section.id }} .image-tabs-text p{
    font-size:var(--text_size_mobile);
    {% if section.settings.text_color != blank and section.settings.text_color != "rgba(0,0,0,0)" %}
    color:{{ section.settings.text_color }};
    {%  endif %}
  }
  .image-tabs-text.active p{
    max-height:10rem;
    opacity:1;
  }
  @media (min-width:768px){
   .c-{{ section.id }}{
  padding-top:{{  section.settings.padding_top }}px;
  padding-bottom:{{  section.settings.padding_bottom }}px;
  }
  .image-tabs-text-container{
        display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .image-tabs-c{
      grid-template-columns: repeat(2,minmax(0,1fr));
      gap: 6rem;
  }
 
  .c-{{ section.id }} .image-tabs-images{
  height:{{ section.settings.image_height }}px;
  }
    .c-{{ section.id }} .image-tabs-text p{
    font-size:var(--text_size);
  }
  .image-tabs-text .icon_and_title img{
  width:var(--width);
  }
  }
    @media (max-width:768px){
    .image-tabs-images{
      grid-area:1;
      }
      .image-tabs-c{
      gap:1rem;
      }
      .image-tabs-text {
        padding: 24px 0;
      }
    }

</style>
<div class="c-{{ section.id }}" data-aos="{{ section.settings.animation }}">
  <div class="{{ section.settings.setwidth }}">
      <div class="image-tabs-c {{ section.settings.layout }}">
        {% capture images %}
        <div class="image-tabs-images">
        {% for block in section.blocks %}
            <div class="image-tabs-image {% if forloop.first %} active{%  endif %}" data-open="{{  forloop.index }}">
              {% if block.settings.image != blank %}
                <img src="{{  block.settings.image | img_url:"1000x" }}" loading="lazy" alt="{{  block.settings.title }} image">
              {%  else %}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%  endif %}
            </div>
        {%  endfor %}
        </div>
      {% endcapture %}
      {% if section.settings.layout == "left" %}
          {{ images }}
      {% endif %}
        <div class="image-tabs-text-container">
        {% for block in section.blocks %}
          <div class="image-tabs-text {% if forloop.first %} active{%  endif %}" data-open="{{  forloop.index }}">
            <div class="icon_and_title">
              {% if block.settings.icon != blank %}
                <img src="{{ block.settings.icon | img_url:"100x" }}" alt="{{ block.settings.title }}" loading="lazy" style="--width:{{ block.settings.icons_width }}px;--width-mobile:{{ block.settings.icons_width_mobile }}px">
              {% endif %}
              <h3 class="{{ section.settings.heading_size }}">{{  block.settings.title }}</h3>
            </div>
              <p style="--text_size:{{ section.settings.text_size }}px;--text_size_mobile:{{ section.settings.text_size_mobile }}px">{{  block.settings.content }}</p>
          </div>
        {%  endfor %}
        </div>
        {% if section.settings.layout == "right" %}
          {{ images }}
      {% endif %}
      </div>
  </div>
</div>
<script>
 function initImageTabs() {
  const textBlocks = document.querySelectorAll('.image-tabs-text-container .image-tabs-text');
  const imageBlocks = document.querySelectorAll('.image-tabs-image');

  // Guard clause: stop if elements aren't found
  if (!textBlocks.length) return;

  function switchTabs(textBlock) {
    const targetIndex = textBlock.getAttribute('data-open');

    textBlocks.forEach(t => t.classList.remove('active'));
    imageBlocks.forEach(img => img.classList.remove('active'));

    textBlock.classList.add('active');

    const matchingImage = document.querySelector(`.image-tabs-image[data-open="${targetIndex}"]`);
    if (matchingImage) {
      matchingImage.classList.add('active');
    }
  }

  textBlocks.forEach(textBlock => {
    // Note: Re-binding listeners is safe here because the 
    // Customizer replaces the DOM elements entirely
    textBlock.addEventListener('mouseenter', () => switchTabs(textBlock));
    textBlock.addEventListener('click', () => switchTabs(textBlock));
  });
}

// 1. Initial Load
document.addEventListener("DOMContentLoaded", initImageTabs);

// 2. Shopify Customizer Load
// This fires every time a section is refreshed or changed in the editor
document.addEventListener('shopify:section:load', (event) => {
  initImageTabs();
});
</script>
