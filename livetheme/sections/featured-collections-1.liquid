<!-- featured-collections-1.liquid -->
<style>
  
  .customstyle{{ section.id }} .collection-card__image{
    border-radius:{{ section.settings.radius }}%;
    isolation: isolate;
  }
  @media(min-width:750px){
    .customstyle{{ section.id }}{
      --g-hgutter:{{ section.settings.space }}px;
    }
  }
      .customstyle{{ section.id }}{
    padding-top:{{ section.settings.padding_top }}px;
    padding-bottom:{{ section.settings.padding_bottom }}px;
  }
  @media (max-width:768px){
     .customstyle{{ section.id }}{
    padding-top:{{ section.settings.mobile_padding_top }}px;
    padding-bottom:{{ section.settings.mobile_padding_bottom }}px;
  }
  }
</style>
<div class="customstyle{{ section.id }}"  data-aos="{{ section.settings.animation }}" >
{%- render 'style-section' -%}
  <div class="{{ section.settings.setwidth }}">
    <div class="section-block">
      {%- render 'section-heading' -%}
      <div class="collectionlist-wrapper">
        <div class="collectionlist-slider row" id="collection-list-{{ section.id }}"
            data-rows="{{ section.settings.rows }}"
            data-slidesToShow="{{ section.blocks.size }}"
            data-slidestoscroll="{{ section.blocks.size }}"
            data-arrows="{{ section.settings.arrows }}"
            data-dots="{{ section.settings.dots }}" 
            data-draggable="{{ section.settings.draggable }}" 
            data-infinite="{{ section.settings.infinite }}" 
            data-section-id="{{ section.id }}" 
            data-slidestoshow-mobile="2"
            {% if section.settings.enable_carousel %}
            data-section-type="slickCarousels"
            {% endif %}
          >
          {%- for block in section.blocks -%}
          <div class="col collectionlist-item carousel__slide-wrapper--{{ block.id }}" {{ block.shopify_attributes }} >
            {%- assign featured_collection = collections[block.settings.collection] -%}
            {%- assign featured_image = block.settings.image -%}
            {%- render 'collection-grid-item' , featured_image: featured_image, featured_collection: featured_collection, column: 'none', size_image: section.settings.size_image, headinglist: section.settings.size_text -%}
          </div>
          {%- endfor -%}
        </div>
      </div>
      {%- if section.blocks.size == 0 -%}
      {%- render 'no-blocks' -%}
      {%- endif -%}
    </div>
  </div>
</div>


