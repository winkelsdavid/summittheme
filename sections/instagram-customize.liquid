<!-- instagram-customize.liquid -->
{%-  liquid 
  assign enable_carousel = section.settings.enable_carousel
  case section.settings.image_size
  when 'square'
    assign himg = '100%'
    when 'portrait'
      assign himg = '150%'
    when 'wide'
      assign himg = '56%'
    when 'landscape'
      assign himg = '75%'
  else
    assign himg = '100%'
  endcase
  # Carousel scrolls through ALL blocks; only the grid is capped to "Show".
  assign loop_limit = section.settings.show
  if enable_carousel
    assign loop_limit = section.blocks.size
  endif
  # Native scroll-snap: visible items per view (Column), responsive down to 2 on mobile.
  assign per_lg = section.settings.column | at_least: 1
  assign per_sm = 2 | at_most: per_lg
  assign per_md = per_lg | minus: 1 | at_least: per_sm
-%}
<style>
  .instagramoff-grid{
    display: grid;
    grid-template-columns: repeat({{ section.settings.column }},1fr);
    gap:{{ section.settings.gutter_padding | append: 'px' }};
    margin:0 !important;
  }
  .instagramoff-grid .col{
    padding:0 !important;
  }
  @media(max-width:749px){
    .instagramoff-grid{
      grid-template-columns: repeat(2,1fr);
    }
  }
   .customstyle{{ section.id }}{
    padding-top:{{ section.settings.padding_top }}px;
    padding-bottom:{{ section.settings.padding_bottom }}px;
  }
  @media (max-width:749px){
     .customstyle{{ section.id }}{
    padding-top:{{ section.settings.mobile_padding_top }}px;
    padding-bottom:{{ section.settings.mobile_padding_bottom }}px;
  }
  }
  /* Empty image/video blocks: give the placeholder the same aspect box (Image
     Ratio) so it shows instead of collapsing to 0 height. */
  .customstyle{{ section.id }} .instagramoff-placeholder{
    position: relative;
    padding-top: var(--h-image-insta);
  }
  /* B1-Fallback-Medien: die Ratio-Box haengt sonst am <a> der Instanz-Pfade
     (.instagramoff-item a) und JEDES img/video im Item ist global absolut -
     ohne eigene Box kollabiert der Depot-Fallback auf 0 Hoehe (#79-Nachtrag). */
  .customstyle{{ section.id }} .instagramoff-b1box{
    position: relative;
    display: block;
    overflow: hidden;
    padding-top: var(--h-image-insta);
  }
  .customstyle{{ section.id }} .instagramoff-placeholder .placeholder-svg{
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }
  /* --- Native scroll-snap slider (Swiper-frei, wie Blog Posts) --- */
  .instascroll-wrap-{{ section.id }}{ position: relative; }
  .instascroll-{{ section.id }}{
    display: flex; gap: {{ section.settings.gutter_padding }}px;
    overflow-x: auto; overflow-y: hidden;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; -ms-overflow-style: none;
    margin: 0; --per: {{ per_sm }};
  }
  .instascroll-{{ section.id }}::-webkit-scrollbar{ display: none; }
  .instascroll-{{ section.id }}, .instascroll-{{ section.id }} a{ cursor: grab; }
  .instascroll-{{ section.id }}.is-grabbing, .instascroll-{{ section.id }}.is-grabbing *{ cursor: grabbing !important; }
  .instascroll-{{ section.id }}.is-grabbing{ scroll-snap-type: none; }
  @media (min-width: 768px){ .instascroll-{{ section.id }}{ --per: {{ per_md }}; } }
  @media (min-width: 1200px){ .instascroll-{{ section.id }}{ --per: {{ per_lg }}; } }
  .instascroll-{{ section.id }} > .instascroll-slide{
    flex: 0 0 calc((100% - (var(--per) - 1) * {{ section.settings.gutter_padding }}px) / var(--per));
    max-width: calc((100% - (var(--per) - 1) * {{ section.settings.gutter_padding }}px) / var(--per));
    scroll-snap-align: start; min-width: 0;
  }
  .instascroll-wrap-{{ section.id }} .instascroll-arrow{
    position: absolute; top: 50%; transform: translateY(-50%);
    width: 44px; height: 44px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    background: #fff; color: var(--g-color-carousel); border: 0; cursor: pointer;
    box-shadow: 0 2px 6px #36363626; z-index: 6;
    transition: all 0.3s ease;
  }
  .instascroll-prev-{{ section.id }}{ left: -10px; }
  .instascroll-next-{{ section.id }}{ right: -10px; }
  .instascroll-wrap-{{ section.id }} .instascroll-arrow:after{
    font-family: swiper-icons; font-size: 16px; line-height: 1;
    letter-spacing: 0; text-transform: none; font-variant: initial; display: inline-block;
  }
  .instascroll-prev-{{ section.id }}:after{ content: 'prev'; }
  .instascroll-next-{{ section.id }}:after{ content: 'next'; }
  .instascroll-prev-{{ section.id }}:hover:after{ animation: 0.4s ease-in-out reverse forwards animateIcon; }
  .instascroll-next-{{ section.id }}:hover:after{ animation: 0.4s ease-in-out forwards animateIcon; }
  .instascroll-dots-{{ section.id }}{ display: flex; justify-content: center; gap: 8px; margin-top: 24px; }
  .instascroll-dots-{{ section.id }} button{ width: 8px; height: 8px; padding: 0; border: 0; border-radius: 50%; background: currentColor; opacity: .25; cursor: pointer; }
  .instascroll-dots-{{ section.id }} button.is-active{ opacity: 1; }
</style>
{%- render 'style-section' -%}
<div class="customstyle{{ section.id }}" data-aos="{{ section.settings.animation }}" style="--h-image-insta:{{ himg }};">
  <div class="{{ section.settings.section_width }}">
  <div class="section-block">
    {%- render 'section-heading' -%}
    <div class="instagramoff-wrapper dots-negative instascroll-wrap-{{ section.id }}">
      <div class="instagramoff-slider mb-0 {% if enable_carousel %}instascroll-{{ section.id }}{% else %}instagramoff-grid {% if section.settings.padding == false %}row mx-0{% else %}row{% endif %}{% endif %}" id="instascroll-{{ section.id }}" data-section-id="{{ section.id }}">

        {%- for block in section.blocks limit: loop_limit -%}
          {% case block.type %}
            {% when 'image' %}
            {%- assign b1_pos = b1_pos | plus: 1 -%}
            <div class="{% if enable_carousel %}instascroll-slide{% else %}{% if section.settings.padding == false %}col px-0{% else %}col{% endif %}{% endif %} carousel__slide-wrapper--{{ block.id }}" {{ block.shopify_attributes }}>
              <div class="position-relative hv-image-brightness instagramoff-item"  data-aos="{{ section.settings.animation }}"  data-aos-delay="{{ forloop.index | times: 100 }}" >
                {%- if block.settings.image != blank -%}
                <a {% if block.settings.image_link != blank %}href="{{ block.settings.image_link }}"{% endif %} title="{{ block.settings.image.alt | escape }}" class="image-content__image-wrapper">
                  {%- assign widths = '165, 360, 535, 750, 1070, 1500' -%}
                  {%- capture sizes -%}
                  (min-width: {{ settings.container }}px) {{ settings.container | minus: 100 | divided_by: 2 }}px,(min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)
                  {%- endcapture -%}
                  {{
                    block.settings.image
                    | image_url: width: 600
                    | image_tag: sizes: sizes, widths: widths, fetchpriority: 'auto', class: "image-content__image lazyload scale-in"
                    }}
                </a>
                {%- else -%}
                {%- capture b1_fb -%}{% render 'brand-image', handle: 'instagram-customize--image', position: b1_pos, width: 600, class: 'image-content__image scale-in lazyloaded' %}{%- endcapture -%}
                {%- if b1_fb != blank -%}<div class="instagramoff-b1box">{{ b1_fb }}</div>{%- else -%}<div class="instagramoff-placeholder">{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</div>{%- endif -%}
                {%- endif -%}
              </div>
            </div>
           {% when 'video' %}
           {%- assign b1_pos_v = b1_pos_v | plus: 1 -%}
           <div class="{% if enable_carousel %}instascroll-slide{% else %}{% if section.settings.padding == false %}col px-0{% else %}col{% endif %}{% endif %} carousel__slide-wrapper--{{ block.id }}" {{ block.shopify_attributes }}>
            <div class="position-relative hv-image-brightness instagramoff-item instagramoff-itemvideo"  data-aos="{{ section.settings.animation }}"  data-aos-delay="{{ forloop.index | times: 100 }}" >
              {%- if block.settings.video != blank -%}
                 <a {% if block.settings.image_link != blank %}href="{{ block.settings.image_link }}"{% endif %} class="d-block">
                {%- if block.settings.image_poster != blank -%}
                <video loop muted playsinline {% if block.settings.enable_play_video %}autoplay{% else %}preload="none"{% endif %} disablepictureinpicture controlslist="nodownload noplaybackrate" poster="{{ block.settings.image_poster | image_url: width: 1920 }}">
                  {%- for source in block.settings.video.sources -%}{%- if source.format == 'mp4' -%}<source src="{{ source.url }}" type="video/mp4">{%- endif -%}{%- endfor -%}
                </video>
                {%- else -%}
                {{   block.settings.video | video_tag: autoplay: block.settings.enable_play_video , loop: true, muted: true, controls: false, playsinline: true }}
                {%- endif -%}
                </a>
              {%- elsif block.settings.video_url != blank -%}
              <a {% if block.settings.image_link != blank %}href="{{ block.settings.image_link }}"{% endif %} class="d-block">
                <video id="video-insta-{{ block.id }}"  loop="" muted="" playsinline="" {% if block.settings.enable_play_video %} autoplay {% else %} preload="none" {% endif %} disablepictureinpicture controlslist="nodownload noplaybackrate"
                {% if block.settings.image_poster != blank %} poster="{{ block.settings.image_poster | image_url: width: 1920 }}" {% endif %}>
                  <source src="{{ block.settings.video_url }}" type="video/mp4">
              </video>
              </a>
              {%- else -%}
              {%- comment -%} Welle-4-Kontrakt: Legacy-Handle des video-Blocks traegt
                  video_1..N (erstes Media-Setting = Video); Poster liegen unter
                  --image_poster. Kette: Video -> Poster-Bild -> Placeholder. {%- endcomment -%}
              {%- capture b1_vid -%}{% render 'brand-video', handle: 'instagram-customize--video', position: b1_pos_v, autoplay: true, loop: true, muted: true, controls: false, class: 'image-content__image scale-in lazyloaded' %}{%- endcapture -%}
              {%- if b1_vid != blank -%}
              <div class="instagramoff-b1box">{{ b1_vid }}</div>
              {%- else -%}
              {%- capture b1_fb -%}{% render 'brand-image', handle: 'instagram-customize--video--image_poster', position: b1_pos_v, width: 600, class: 'image-content__image scale-in lazyloaded' %}{%- endcapture -%}
              {%- if b1_fb != blank -%}<div class="instagramoff-b1box">{{ b1_fb }}</div>{%- else -%}<div class="instagramoff-placeholder">{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</div>{%- endif -%}
              {%- endif -%}
              {%- endif -%}
            </div>
          </div>
              
          {% endcase %}
        
        {%- endfor -%}
      </div>
      {%- if enable_carousel and section.settings.arrows -%}
        <button type="button" class="instascroll-arrow instascroll-prev-{{ section.id }}" aria-label="Previous"></button>
        <button type="button" class="instascroll-arrow instascroll-next-{{ section.id }}" aria-label="Next"></button>
      {%- endif -%}
      {%- if enable_carousel and section.settings.dots -%}
        <div class="instascroll-dots-{{ section.id }}"></div>
      {%- endif -%}
    </div>
    {%- if section.blocks.size == 0 -%}
    {%- render 'no-blocks' -%}
    {%- endif -%}
  </div>
</div>
</div>

<script>
(function(){
  var sc = document.getElementById('instascroll-{{ section.id }}');
  if(!sc || sc.dataset.snapInit) return;
  sc.dataset.snapInit = '1';
  var wrap = sc.closest('.instascroll-wrap-{{ section.id }}') || sc.parentNode;
  var infinite = {{ section.settings.infinite | default: true }};
  var real = [].slice.call(sc.querySelectorAll('.instascroll-slide'));
  var n = real.length;
  var all = real;

  function gap(){ return parseFloat(getComputedStyle(sc).columnGap) || 0; }
  function step(){ var s = sc.querySelector('.instascroll-slide'); return s ? s.getBoundingClientRect().width + gap() : sc.clientWidth; }
  function jump(x){ var b = sc.style.scrollBehavior; sc.style.scrollBehavior = 'auto'; sc.scrollLeft = x; sc.style.scrollBehavior = b; }

  /* Infinite: clone all slides before & after. When the user lands in a clone
     region (after the scroll settles), silently jump scrollLeft by one block
     width -> seamless wrap. Native scroll-snap, no Swiper, no 0px-collapse. */
  if(infinite && n > 1){
    var before = document.createDocumentFragment(), after = document.createDocumentFragment();
    real.forEach(function(sl){
      var a = sl.cloneNode(true); a.classList.add('is-clone'); a.setAttribute('aria-hidden','true'); after.appendChild(a);
      var b = sl.cloneNode(true); b.classList.add('is-clone'); b.setAttribute('aria-hidden','true'); before.appendChild(b);
    });
    sc.appendChild(after);
    sc.insertBefore(before, sc.firstChild);
    all = [].slice.call(sc.querySelectorAll('.instascroll-slide'));
    var anchor = function(){ jump(all[n].offsetLeft - sc.offsetLeft); };
    requestAnimationFrame(anchor);
    var t, busy = false;
    sc.addEventListener('scroll', function(){
      clearTimeout(t);
      t = setTimeout(function(){
        if(busy) return; busy = true;
        var rs = all[n].offsetLeft - sc.offsetLeft;
        var period = all[2*n].offsetLeft - all[n].offsetLeft;
        var x = sc.scrollLeft;
        if(x < rs - 1) jump(x + period);
        else if(x >= rs + period - 1) jump(x - period);
        busy = false;
      }, 90);
    });
    window.addEventListener('resize', function(){ clearTimeout(t); t = setTimeout(anchor, 150); });
  }

  /* Desktop mouse drag-to-scroll ("swipe" mit der Maus, wie Swipers grabCursor).
     Touch scrollt ohnehin nativ. Klick wird nach echtem Drag unterdrueckt, damit
     Links beim Ziehen nicht navigieren. */
  var dDown=false, dMoved=false, dX=0, dL=0;
  sc.addEventListener('pointerdown', function(e){
    if(e.pointerType !== 'mouse') return;
    dDown=true; dMoved=false; dX=e.clientX; dL=sc.scrollLeft;
    sc.classList.add('is-grabbing');
    try{ sc.setPointerCapture(e.pointerId); }catch(_){}
  });
  sc.addEventListener('pointermove', function(e){
    if(!dDown) return;
    var dx = e.clientX - dX;
    if(Math.abs(dx) > 4) dMoved=true;
    sc.scrollLeft = dL - dx;
  });
  function endDrag(){ if(!dDown) return; dDown=false; sc.classList.remove('is-grabbing'); }
  sc.addEventListener('pointerup', endDrag);
  sc.addEventListener('pointercancel', endDrag);
  sc.addEventListener('click', function(e){ if(dMoved){ e.preventDefault(); e.stopPropagation(); dMoved=false; } }, true);

  var prev = wrap.querySelector('.instascroll-prev-{{ section.id }}');
  var next = wrap.querySelector('.instascroll-next-{{ section.id }}');
  if(prev){ prev.addEventListener('click', function(){ sc.scrollBy({ left: -step(), behavior: 'smooth' }); }); }
  if(next){ next.addEventListener('click', function(){ sc.scrollBy({ left: step(), behavior: 'smooth' }); }); }

  var dotsWrap = wrap.querySelector('.instascroll-dots-{{ section.id }}');
  if(dotsWrap){
    dotsWrap.innerHTML = '';
    real.forEach(function(sl, i){
      var b = document.createElement('button');
      b.type = 'button'; b.setAttribute('aria-label', 'Slide ' + (i + 1));
      b.addEventListener('click', function(){ sc.scrollTo({ left: sl.offsetLeft - sc.offsetLeft, behavior: 'smooth' }); });
      dotsWrap.appendChild(b);
    });
    var dots = [].slice.call(dotsWrap.querySelectorAll('button'));
    var sync = function(){
      var x = sc.scrollLeft, best = 0, bd = Infinity;
      all.forEach(function(sl, i){ var d = Math.abs((sl.offsetLeft - sc.offsetLeft) - x); if(d < bd){ bd = d; best = i; } });
      var ri = best % n;
      dots.forEach(function(d, i){ d.classList.toggle('is-active', i === ri); });
    };
    sc.addEventListener('scroll', function(){ requestAnimationFrame(sync); });
    sync();
  }
})();
</script>
