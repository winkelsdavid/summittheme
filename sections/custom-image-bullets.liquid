{% comment %} image_with_bullets section {% endcomment %}

<style>
.c-{{ section.id }}{
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  background:{{  section.settings.background }};
}
@media screen and (max-width: 991px) {
  .c-{{ section.id }}{
      padding-top: {{ section.settings.mobile_padding_top }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
  }
}
  .iwb-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .iwb-content-side {
    display: flex;
    flex-direction: column;
  }

 .c-{{ section.id }}  .iwb-heading {
    margin: 0 0 12px;
    {% if section.settings.heading_color != blank and section.settings.heading_color != "rgba(0,0,0,0)" %}
    --g-color-heading: {{ section.settings.heading_color }};
    {% endif %}
    line-height: 1.2;
  }

  .iwb-description {
    margin: 0 0 32px;
    font-size: 16px;
    line-height: 1.5;
     {% if section.settings.text_color != blank and section.settings.text_color != "rgba(0,0,0,0)" %}
    color: {{ section.settings.text_color }};
    {% endif %}
  }

  .iwb-bullets-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

 .c-{{ section.id }}  .iwb-bullet-item {
    display: flex;
    gap: 12px;
    padding: 16px;
    background: {{ section.settings.card_bg_color }};
    {% if settings.enable_radius_allimg %}border-radius:calc(0.2rem * {{ settings.radius_allimg_range }}) !important;{% endif %}
    border: 1px solid {{ section.settings.card_border_color }};
    align-items: flex-start;
  }

  .iwb-bullet-icon {
    flex-shrink: 0;
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .iwb-bullet-icon svg {
    width: 30px;
    height: 30px;
        fill: none;
    stroke-width: 4px;
  }

  .iwb-bullet-text {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .c-{{ section.id }} .iwb-bullet-item{
    {% if  section.settings.box_align == "right" %}
        flex-direction:row-reverse;
    {% endif %}
    }
   .c-{{ section.id }} .iwb-bullet-text{
    text-align:{{ section.settings.box_align }};
    }
    
  .c-{{ section.id }} .iwb-bullet-title {
    margin: 0;
    font-size: 20px;
    line-height: 1.3;
     {% if section.settings.heading_color != blank and section.settings.heading_color != "rgba(0,0,0,0)" %}
    --g-color-heading: {{ section.settings.heading_color }};
    {% endif %}
  }

  .c-{{ section.id }} .iwb-bullet-body {
    margin: 0;
    font-size: 15px;
    line-height: 1.5;
    {% if section.settings.text_color != blank and section.settings.text_color != "rgba(0,0,0,0)" %}
    color: {{ section.settings.text_color }};
    {% endif %}
    
  }

  .iwb-image-side {
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    {% if settings.enable_radius_allimg %}border-radius: calc(0.2rem * {{ settings.radius_allimg_range }}) !important;{% endif %}
  }
  .iwb-parallax-img{
  height:100%;
  }
  .iwb-image-side img,
  .iwb-image-side svg {
    max-width: 100%;
    height:100%;
    display: block;
    object-fit: cover;
   /* max-height: 740px;*/
    will-change: transform;
    transform-origin: 50% 50%;
  }

  {% if section.settings.image_layout == 'image_left' %}
   .c-{{ section.id }} .iwb-grid {
      direction: rtl;
    }
   .c-{{ section.id }} .iwb-grid > * {
      direction: ltr;
    }
  {% endif %}

  @media screen and (max-width: 767px) {
    .iwb-grid {
      grid-template-columns: 1fr;
      gap: 24px;
      direction: ltr;
    }

    {% if section.settings.image_layout == 'image_right' %}
      .iwb-image-side { order: -1; }
    {% endif %}


    .iwb-bullet-title {
      font-size: 17px;
    }

    .iwb-bullet-body{
      font-size: 14px;
    }

    .iwb-bullet-icon,
    .iwb-bullet-icon svg {
      width: 24px;
      height: 24px;
    }

    .iwb-bullets-list {
      gap: 12px;
    }
  }

  /* Hover-Animationen entfernt (Kundenwunsch 2026-07) — hover_style bleibt
     nur als Legacy-Setting im Schema (Nitro-Mappability). */
</style>

<section class="iwb-section c-{{ section.id }}" id="iwb-{{ section.id }}" data-aos="{{ section.settings.animation }}">
  <div class="{{ section.settings.section_width }}">
    <div class="iwb-grid">

      <!-- Content Side -->
      <div class="iwb-content-side">
        {% if section.settings.heading != blank %}
          <h3 class="iwb-heading">{{ section.settings.heading }}</h3>
        {% endif %}

        {% if section.settings.description != blank %}
          <p class="iwb-description">{{ section.settings.description }}</p>
        {% endif %}

        {% if section.blocks.size > 0 %}
          <div class="iwb-bullets-list">
            {% for block in section.blocks %}
              <div class="iwb-bullet-item" {{ block.shopify_attributes }}>

                <div class="iwb-bullet-icon" style="--icon-color:{{ block.settings.icon_color }};">
                    {% render 'list-svg',block:block, icon: block.settings.icon %}
                </div>

                <div class="iwb-bullet-text">
                  {% if block.settings.title != blank %}
                    <h6 class="iwb-bullet-title">{{ block.settings.title }}</h6>
                  {% endif %}
                  {% if block.settings.body != blank %}
                    <p class="iwb-bullet-body">{{ block.settings.body }}</p>
                  {% endif %}
                </div>

              </div>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <!-- Image Side -->
      <div class="iwb-image-side">
        {% if section.settings.image != blank %}
        <div class="iwb-parallax-img">
          {{
            section.settings.image
            | image_url: width: 800
            | image_tag:
              loading: 'lazy',
              alt: section.settings.image.alt | default: section.settings.heading
          }}
          </div>
        {% else %}
           {%- capture b1_fb -%}{% render 'brand-image', handle: 'custom-image-bullets', slot: 1, width: 800 %}{%- endcapture -%}
           {%- if b1_fb != blank -%}<div class="iwb-parallax-img">{{ b1_fb }}</div>{%- else -%}{{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg iwb-parallax-img' }}{%- endif -%}
        {% endif %}
      </div>

    </div>
  </div>
</section>

