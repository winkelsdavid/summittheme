{% comment %} image_with_bullets section {% endcomment %}

<style>
.c-{{ section.id }}{
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  background:{{  section.settings.background }};
}
@media screen and (max-width: 991px) {
  .c-{{ section.id }}{
      padding-top: {{ section.settings.mobile_padding_top }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
  }
}
  .iwb-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .iwb-content-side {
    display: flex;
    flex-direction: column;
  }

 .c-{{ section.id }}  .iwb-heading {
    margin: 0 0 12px;
    {% if section.settings.heading_color != blank and section.settings.heading_color != "rgba(0,0,0,0)" %}
    --g-color-heading: {{ section.settings.heading_color }};
    {% endif %}
    line-height: 1.2;
  }

  .iwb-description {
    margin: 0 0 32px;
    font-size: 16px;
    line-height: 1.5;
     {% if section.settings.text_color != blank and section.settings.text_color != "rgba(0,0,0,0)" %}
    color: {{ section.settings.text_color }};
    {% endif %}
  }

  .iwb-bullets-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

 .c-{{ section.id }}  .iwb-bullet-item {
    display: flex;
    gap: 12px;
    padding: 16px;
    background: {{ section.settings.card_bg_color }};
    border-radius:calc(0.2rem * {{ settings.radius_allimg_range }}) !important;
    border: 1px solid {{ section.settings.card_border_color }};
    align-items: flex-start;
  }

  .iwb-bullet-icon {
    flex-shrink: 0;
    width: 30px;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .iwb-bullet-icon svg {
    width: 30px;
    height: 30px;
        fill: none;
    stroke-width: 4px;
  }

  .iwb-bullet-text {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .c-{{ section.id }} .iwb-bullet-item{
    {% if  section.settings.box_align == "right" %}
        flex-direction:row-reverse;
    {% endif %}
    }
   .c-{{ section.id }} .iwb-bullet-text{
    text-align:{{ section.settings.box_align }};
    }
    
  .c-{{ section.id }} .iwb-bullet-title {
    margin: 0;
    font-size: 20px;
    line-height: 1.3;
     {% if section.settings.heading_color != blank and section.settings.heading_color != "rgba(0,0,0,0)" %}
    --g-color-heading: {{ section.settings.heading_color }};
    {% endif %}
  }

  .c-{{ section.id }} .iwb-bullet-body {
    margin: 0;
    font-size: 15px;
    line-height: 1.5;
    {% if section.settings.text_color != blank and section.settings.text_color != "rgba(0,0,0,0)" %}
    color: {{ section.settings.text_color }};
    {% endif %}
    
  }

  .iwb-image-side {
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    border-radius: calc(0.2rem * {{ settings.radius_allimg_range }}) !important;
  }
  .iwb-parallax-img{
  height:100%;
  }
  .iwb-image-side img,
  .iwb-image-side svg {
    max-width: 100%;
    height:100%;
    display: block;
    object-fit: cover;
   /* max-height: 740px;*/
    will-change: transform;
    transform-origin: 50% 50%;
  }

  {% if section.settings.image_layout == 'image_left' %}
   .c-{{ section.id }} .iwb-grid {
      direction: rtl;
    }
   .c-{{ section.id }} .iwb-grid > * {
      direction: ltr;
    }
  {% endif %}

  @media screen and (max-width: 767px) {
    .iwb-grid {
      grid-template-columns: 1fr;
      gap: 24px;
      direction: ltr;
    }

    {% if section.settings.image_layout == 'image_right' %}
      .iwb-image-side { order: -1; }
    {% endif %}


    .iwb-bullet-title {
      font-size: 17px;
    }

    .iwb-bullet-body{
      font-size: 14px;
    }

    .iwb-bullet-icon,
    .iwb-bullet-icon svg {
      width: 24px;
      height: 24px;
    }

    .iwb-bullets-list {
      gap: 12px;
    }
  }

  /* === Content-matched hover animations (Hydrate. Plump. Glow.) === */
  .c-{{ section.id }} .iwb-bullet-item{
    transition: transform .35s, box-shadow .35s;
    will-change: transform;
  }
  @media (hover: hover){
    .c-{{ section.id }} .iwb-bullet-item--plump:hover{ animation: orellaPlump .5s cubic-bezier(0.34,1.56,0.64,1) forwards; }
    .c-{{ section.id }} .iwb-bullet-item--jelly:hover{ animation: orellaJelly .65s ease-in-out; }
    .c-{{ section.id }} .iwb-bullet-item--shine:hover{ animation: orellaShine .9s ease forwards; filter: brightness(1.03); }
    .c-{{ section.id }} .iwb-bullet-item--guard:hover{ animation: orellaGuard .7s ease-out forwards; }
  }
  @keyframes orellaPlump{
    0%{ transform: scale(1); }
    45%{ transform: scale(1.05); }
    70%{ transform: scale(1.015); }
    100%{ transform: scale(1.035); box-shadow: 0 10px 28px rgba(32,14,16,0.13); }
  }
  @keyframes orellaJelly{
    0%{ transform: scale(1,1); }
    25%{ transform: scale(1.04,0.94); }
    50%{ transform: scale(0.96,1.05); }
    70%{ transform: scale(1.02,0.98); }
    100%{ transform: scale(1,1); }
  }
  @keyframes orellaShine{
    from{ background-image: linear-gradient(110deg, rgba(255,255,255,0) 35%, #ffd9e2 50%, rgba(255,255,255,0) 65%); background-size:250% 100%; background-repeat:no-repeat; background-position:130% 0; box-shadow:0 3px 14px rgba(32,14,16,0.07); }
    to{ background-image: linear-gradient(110deg, rgba(255,255,255,0) 35%, #ffd9e2 50%, rgba(255,255,255,0) 65%); background-size:250% 100%; background-repeat:no-repeat; background-position:-30% 0; box-shadow:0 6px 26px rgba(254,137,154,0.45); }
  }
  @keyframes orellaGuard{
    0%{ box-shadow: 0 3px 14px rgba(32,14,16,0.07), 0 0 0 0 #fe899a, 0 0 0 0 rgba(254,137,154,0.5); }
    100%{ box-shadow: 0 3px 14px rgba(32,14,16,0.07), 0 0 0 2px #fe899a, 0 0 0 16px rgba(254,137,154,0); }
  }
  @media (prefers-reduced-motion: reduce){
    .c-{{ section.id }} .iwb-bullet-item--plump:hover,
    .c-{{ section.id }} .iwb-bullet-item--jelly:hover,
    .c-{{ section.id }} .iwb-bullet-item--shine:hover,
    .c-{{ section.id }} .iwb-bullet-item--guard:hover{
      animation: none; filter: none;
      box-shadow: 0 6px 18px rgba(32,14,16,0.10);
    }
  }
</style>

<section class="iwb-section c-{{ section.id }}" id="iwb-{{ section.id }}" data-aos="{{ section.settings.animation }}">
  <div class="{{ section.settings.section_width }}">
    <div class="iwb-grid">

      <!-- Content Side -->
      <div class="iwb-content-side">
        {% if section.settings.heading != blank %}
          <h3 class="iwb-heading">{{ section.settings.heading }}</h3>
        {% endif %}

        {% if section.settings.description != blank %}
          <p class="iwb-description">{{ section.settings.description }}</p>
        {% endif %}

        {% if section.blocks.size > 0 %}
          <div class="iwb-bullets-list">
            {% for block in section.blocks %}
              {%- liquid
                assign hs = block.settings.hover_style
                if hs == blank or hs == 'auto'
                  case forloop.index
                    when 1
                      assign hs = 'plump'
                    when 2
                      assign hs = 'jelly'
                    when 3
                      assign hs = 'shine'
                    when 4
                      assign hs = 'guard'
                    else
                      assign hs = 'plump'
                  endcase
                endif
              -%}<div class="iwb-bullet-item iwb-bullet-item--{{ hs }}" {{ block.shopify_attributes }}>

                <div class="iwb-bullet-icon" style="--icon-color:{{ block.settings.icon_color }};">
                    {% render 'list-svg',block:block, icon: block.settings.icon %}
                </div>

                <div class="iwb-bullet-text">
                  {% if block.settings.title != blank %}
                    <h6 class="iwb-bullet-title">{{ block.settings.title }}</h6>
                  {% endif %}
                  {% if block.settings.body != blank %}
                    <p class="iwb-bullet-body">{{ block.settings.body }}</p>
                  {% endif %}
                </div>

              </div>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <!-- Image Side -->
      <div class="iwb-image-side">
        {% if section.settings.image != blank %}
        <div class="iwb-parallax-img">
          {{
            section.settings.image
            | image_url: width: 800
            | image_tag:
              loading: 'lazy',
              alt: section.settings.image.alt | default: section.settings.heading
          }}
          </div>
        {% else %}
           {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg iwb-parallax-img' }}
        {% endif %}
      </div>

    </div>
  </div>
</section>

