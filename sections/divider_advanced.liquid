<!-- wave-section.liquid -->
<style>
    .customstyle{{ section.id }}{
      --g-wave-flip:{%- if section.settings.flip_pos == 'down' -%}rotate(180deg){%- else -%}rotate(0deg){%- endif -%};
      {% if section.settings.bg_wave != blank and section.settings.bg_wave != "rgba(0,0,0,0)" %}
      --g-wave-bg: {{ section.settings.bg_wave }};
      {% else %}
      --g-wave-bg: {{ settings.color_body_bg }};
      {% endif %}
    }
   .customstyle{{ section.id }}{
    padding-top:{{ section.settings.padding_top }}px;
    padding-bottom:{{ section.settings.padding_bottom }}px;
    overflow:hidden;
  }
  @media (max-width:768px){
     .customstyle{{ section.id }}{
    padding-top:{{ section.settings.mobile_padding_top }}px;
    padding-bottom:{{ section.settings.mobile_padding_bottom }}px;
  }
  }
    .customstyle{{ section.id }} .border-custom{
        border-top-width: {{ section.settings.wborder }} !important;
        border-color: {{ section.settings.bgborder }} !important;
    }
    {%- if section.settings.flip_pos == 'down' -%}
      .customstyle{{ section.id }} .wave-svg{
      margin-bottom:-2px;
      }
    {% endif %}
    .wave-svg{
      transform:var(--g-wave-flip);
    }
    .wave-svg svg{
      width: 100%;
      height:auto;
      
    }
    .wave-svg svg > g,.wave-svg svg, .wave-svg svg .elementor-shape-fill{
      fill:var(--g-wave-bg);
      max-height:90px;
    }
    {% if section.settings.animated %}
      {%- assign speed_multiplier = 51 | minus : section.settings.animation_speed -%}
    .customstyle{{ section.id }} .wave-svg svg{
        transform: scaleX(4);
        transform-origin: 100% 0;
        animation: {{ speed_multiplier }}s infinite alternate shape-anim linear;
        z-index: 3;
        pointer-events: none;
    }
    {% endif %}
    @keyframes shape-anim{
        100% {
        transform: scaleX(4) translateX(calc(100% - (100% / 4)));
        }
    }
</style>
<div class="customstyle{{ section.id }}" data-aos="{{ section.settings.animation }}">
    {%- render 'style-section' -%}
    <div class="{{ section.settings.setwidth }}">
      <div class="d-flex flex-column wave-svg">
        {%- case section.settings.wave_style -%}
          {%- when 'style1' -%}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 35.28 2.17" preserveAspectRatio="none"><path d="M0 .5c3.07.55 9.27-.42 16.14 0 6.88.4 13.75.57 19.14-.11V0H0z" fill="%23000000"></path><path d="M0 1c3.17.8 7.29-.38 10.04-.55 2.75-.17 9.25 1.47 12.67 1.3 3.43-.17 4.65-.84 7.05-.87 2.4-.02 5.52.88 5.52.88V0H0z" opacity=".5" fill="%23000000"></path><path d="M0 1.85c2.56-.83 7.68-.3 11.79-.42 4.1-.12 6.86-.61 9.58-.28 2.73.33 5.61 1.17 8.61 1 3-.19 4.73-.82 5.3-.84V.1H0z" opacity=".5" fill="%23000000"></path></svg>
          {%- when 'style2' -%}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 35.28 2.17" preserveAspectRatio="none"><path d="M0 .5c3.07.55 9.27-.42 16.14 0 6.88.4 13.75.57 19.14-.11V0H0z" fill="%23000000"></path></svg>
          {%- when 'style3' -%}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 35.28 2.17" preserveAspectRatio="none"><path d="M0 1c3.17.8 7.29-.38 10.04-.55 2.75-.17 9.25 1.47 12.67 1.3 3.43-.17 4.65-.84 7.05-.87 2.4-.02 5.52.88 5.52.88V0H0z" fill="%23000000"></path></svg>
            {%- when 'style4' -%}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0.1 35.28 2.17" preserveAspectRatio="none"><path d="M0 1.85c2.56-.83 7.68-.3 11.79-.42 4.1-.12 6.86-.61 9.58-.28 2.73.33 5.61 1.17 8.61 1 3-.19 4.73-.82 5.3-.84V.1H0z" fill="%23000000"></path></svg>
           {%- when 'style5' -%}
             <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 8 1" preserveAspectRatio="none"><path d="M0 0l10 0l-10 1" fill="%23000000"></path></svg>
            {%- when 'style6' -%}
             <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 381 77.25" preserveAspectRatio="none"><g fill="%23000000"><path d="M381 8.47L0 42.33V0h381z"></path><path d="M381 33.87L0 59.27V0h381z" opacity=".33"></path><path d="M381 59.27L0 77.25V0h381z" opacity=".33"></path></g></svg>
            {%- when 'style7' -%}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 381 59.27" preserveAspectRatio="none"><g fill="%23000000"><path d="M381 8.47L0 42.33V0h381z"></path><path d="M381 33.87L0 59.27V0h381z" opacity=".66"></path></g></svg>
            {%- when 'style8' -%}
