<!-- count-down.liquid -->
{%- style -%}
    .customstyle{{ section.id }}{
      background:{%- if section.settings.gradient_bg != blank -%} {{ section.settings.gradient_bg }} !important {%- else -%} {{ section.settings.background }} {%- endif -%};
        color:{{ section.settings.color }};
        --cd-overlay-rgb:{{ section.settings.overlay.red }},{{ section.settings.overlay.green }}, {{ section.settings.overlay.blue }};
        --cd-color:{{ section.settings.color.red }},{{ section.settings.color.green }},{{ section.settings.color.blue }};
        --color-body-text:{{ section.settings.color }};
        --g-color-heading: {{ section.settings.color }};
    }
    /* .cd-section{
        overflow:hidden;
    } */
    .customstyle{{ section.id }}{
    padding-top:{{ section.settings.padding_top }}px;
    padding-bottom:{{ section.settings.padding_bottom }}px;
  }
  @media (max-width:768px){
     .customstyle{{ section.id }}{
    padding-top:{{ section.settings.mobile_padding_top }}px;
    padding-bottom:{{ section.settings.mobile_padding_bottom }}px;
  }
  }
    .cd-bg{
        position:absolute;
        top:0;
        left:0;
        width:100%;
        height:100%;
        background-size:cover;
        background-position: center;
        {% if section.settings.e_blur %}
        filter:blur(4px);
        transform: scale(1.1);
        {% endif %}
    }
    .cd-bg:before{
        content:"";
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 2;
        background-color:rgba(var(--cd-overlay-rgb),{{ section.settings.opacity }});
    }
    .content-countdown{
      position:relative;
      z-index:3;
    }
    .countdown-item ul li:not(:last-child){
        border-right:1px solid  rgba(var(--cd-color),0.2);
    }
    .countdown-item ul li {
        padding:0 16px;
        line-height:1;
        text-align:center;
    }
    .countdown-item ul li .countdown-time{
        font-size:var(--g-h3-font-size);
        margin-bottom:0.3rem;
        min-width:64px;
        text-align:center;
        display: block;
    }
    .countdown-item ul li .countdown-time b{
        font-weight:500;
    }
    .countdown-item ul li .countdown-text{
        font-size: .75rem;
        letter-spacing: 1.7px;
        text-transform:uppercase;
        display:block;
    }
    @media (max-width:749px){
      .countdown-item ul li .countdown-time{
        font-size:calc(var(--g-h3-font-size) - 4px);
        min-width:max-content;
      }
      .countdown-item ul li .countdown-text{
        letter-spacing: 1.2px;
      }
    }
    
{%- endstyle -%}
{%- liquid
  assign bg_full = section.settings.bg_full
-%}
{%- render 'style-section' -%}
{%- if bg_full -%}
  <div style="background-color: {{ section.settings.background_section }};" data-aos="{{ section.settings.animation }} " class=" cd-section position-relative customstyle{{ section.id }}">
    {% if section.settings.image_bg != blank %}
      {% assign bg_image = section.settings.image_bg %}
        <section class="cd-bg lazyload"
            data-bgset="{% render 'bgset', image: bg_image %}"
            data-sizes="auto"
            data-parent-fit="cover" 
            loading="lazy"></section>
    {% endif %}
{%- endif -%}

<div class="{{ section.settings.section_width }}">
    <div class="{% if section.settings.enable_padding %} px-lg-5 px-2 {% endif %} {% unless bg_full %}  customstyle{{ section.id }} {% endunless %}   cd-section position-relative" data-aos="{{ section.settings.animation }}" >
      {% unless bg_full %}  
      {% if section.settings.image_bg != blank %}
          {% assign bg_image = section.settings.image_bg %}
            <section class="cd-bg lazyload"
                data-bgset="{% render 'bgset', image: bg_image %}"
                data-sizes="auto"
                data-parent-fit="cover" 
                loading="lazy"></section>
        {% endif %}
      {% endunless %}  
            <div class="row align-items-center content-countdown">
                <div class="col-lg-5 col-12">
                    {%- if  section.settings.title != blank -%}
                        <h3 class="text-lg-left text-center {{ section.settings.size_text }}">{{ section.settings.title }}</h3>
                    {%- endif -%}
                    {%- if  section.settings.description != blank -%}
                        <div class="text-lg-left text-center">{{ section.settings.description }}</div>
                    {%- endif -%}
                </div>
                <div class="col-lg-7 col-12 d-flex align-items-center {% if section.settings.e_button %} justify-content-between {% else %} justify-content-center {% endif %} mt-lg-0 mt-4 flex-lg-row flex-column">
                  {% comment %}
                  <countdown-timer class="countdown-timer countdown-item" data-time="{{ section.settings.data_countdown }}"></countdown-timer>
                  {% endcomment %}
                  <div class="countdown_announcement">
                    {% if section.settings.data_countdown != blank %}
                      <div
                        class="kik_hero_timer_an {{ section.id }}"
                        data-time="{{ section.settings.data_countdown }}"
                        data-enable-set-to="{{ section.settings.enable_set_to }}"
                        data-set-hours="{{ section.settings.set_to | default: '24' }}"
                      >
                        <div id="hero_countdown" class="countdown-item">
                          <ul class=list--inline>
                            <li><span class="hero_days countdown-time"></span><span class="countdown-text">{{ 'general.months.days' | t }}</span></li>
                            <li><span class="hero_hours countdown-time"></span><span class="countdown-text">{{ 'general.months.hours' | t }}</span></li>
                            <li><span class="hero_minutes countdown-time"></span><span class="countdown-text">{{ 'general.months.minutes' | t }}</span></li>
                            <li><span class="hero_seconds countdown-time"></span><span class="countdown-text">{{ 'general.months.seconds' | t }}</span></li>
                          </ul>
                        </div>
                      </div>
                    {% endif %}
                  </div>
                    {%- if section.settings.e_button -%}
                        <div>
                            <a href="{{ section.settings.link_button }}" class="btn {{ section.settings.style_btn }} mt-4 mt-lg-0">{{ section.settings.txt_button }}</a>
                        </div>
                    {%- endif -%} 
                    
                </div>
            </div>
    </div>
</div>
{%- if bg_full -%}
  </div>
{%- endif -%}
{% if section.settings.data_countdown != blank %}
<script>
  // 1. Core initialization function
  function kik_hero_init_timer() {
    const ms_sec = 1000,
          ms_min = ms_sec * 60,
          ms_hr  = ms_min * 60,
          ms_day = ms_hr * 24;

    const timerWrapper = document.querySelector(".kik_hero_timer_an.{{ section.id }}");

    if (!timerWrapper) return;

    const isEnabledSetTo = timerWrapper.getAttribute("data-enable-set-to") === "true";
    const hoursToSet     = parseInt(timerWrapper.getAttribute("data-set-hours")) || 24;
    // Shared store-wide key derived from the hours value: every "Set to Nh" timer
    // (count-down + announcement-bar) shares ONE start timestamp -> they stay in sync.
    const HERO_STORAGE_KEY = "kik_sales_timer_start_" + hoursToSet + "h";

    let targetTimestamp;

    if (isEnabledSetTo) {
      const localStartTime = localStorage.getItem(HERO_STORAGE_KEY);
      let startTime;
      if (localStartTime) {
        startTime = parseInt(localStartTime);
      } else {
        startTime = new Date().getTime();
        localStorage.setItem(HERO_STORAGE_KEY, startTime);
      }
      targetTimestamp = startTime + (hoursToSet * ms_hr);
    } else {
      const rawDate   = timerWrapper.getAttribute("data-time");
      targetTimestamp = new Date(rawDate).getTime();
    }

    // Clear any existing interval running for this specific section identifier
    if (window.kik_hero_interval_{{ section.id | replace: '-', '_' }}) {
      clearInterval(window.kik_hero_interval_{{ section.id | replace: '-', '_' }});
    }

    function heroUpdateDisplay() {
      const currentTime = new Date().getTime();
      let gap = targetTimestamp - currentTime;

      if (gap < 0) {
        {% if section.settings.action_timer == "resets_itself" %}
          const newNow = new Date().getTime();
          localStorage.setItem(HERO_STORAGE_KEY, newNow);
          targetTimestamp = newNow + (hoursToSet * ms_hr);
          gap = targetTimestamp - newNow;
        {% else %}
          const hero_text_countdown = document.querySelector("#hero_text_countdown");
          timerWrapper.style.display = "none";
          if (hero_text_countdown) {
            hero_text_countdown.style.display = "none";
          }
          clearInterval(window.kik_hero_interval_{{ section.id | replace: '-', '_' }});
          return;
        {% endif %}
      }

      const d = Math.floor(gap / ms_day);
      const h = Math.floor((gap % ms_day) / ms_hr);
      const m = Math.floor((gap % ms_hr)  / ms_min);
      const s = Math.floor((gap % ms_min) / ms_sec);

      timerWrapper.querySelectorAll(".hero_days").forEach(el    => el.innerText = d);
      timerWrapper.querySelectorAll(".hero_hours").forEach(el   => el.innerText = h);
      timerWrapper.querySelectorAll(".hero_minutes").forEach(el => el.innerText = m);
      timerWrapper.querySelectorAll(".hero_seconds").forEach(el => el.innerText = s);
    }

    window.kik_hero_interval_{{ section.id | replace: '-', '_' }} = setInterval(heroUpdateDisplay, 1000);
    heroUpdateDisplay();
  }

  // 2. Run immediately on normal storefront page load
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", kik_hero_init_timer);
  } else {
    kik_hero_init_timer();
  }

  // 3. Listen for Shopify Design/Theme Editor lifecycle events globally
  document.addEventListener("shopify:section:load", function (event) {
    // Only re-init if the loaded section matches this snippet instance
    if (event.detail.sectionId === "{{ section.id }}") {
      kik_hero_init_timer();
    }
  });
</script>
{% endif %}
