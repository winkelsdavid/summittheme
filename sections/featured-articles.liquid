<!-- featured-articles.liquid -->
{%- liquid

  assign image_size = section.settings.image_size
  assign enable_btn_blog = section.settings.enable_btn_blog
  assign enable_btn_line = section.settings.enable_btn_line
  assign enable_date = section.settings.enable_date
  assign enable_tag = section.settings.enable_tag
  assign enable_comment = section.settings.enable_comment
  assign enable_short = section.settings.enable_short
  assign text_color = section.settings.title_color
  assign style_btn = section.settings.style_btn
  assign blog_gap = section.settings.gutter_padding | default: 30
  assign per_lg = section.settings.show | plus: 0 | at_least: 1
  assign per_md = per_lg | minus: 1 | at_least: 1
  
-%}
<style>
  .customstyle{{ section.id }}{
    {% if text_color != 'transparent' and text_color != 'rgba(0,0,0,0)' %}
      --g-font-color-subtop: {{ text_color }};
      --g-color-heading :  {{ text_color }};
      --color-body-text : {{ text_color }};
      --color-body-text-rgb: {{ text_color.red }}, {{ text_color.green }},  {{ text_color.blue }} ;
      --g-color-heading-rgb: {{ text_color.red }}, {{ text_color.green }},  {{ text_color.blue }} ;
    {% endif %}
  }
    .customstyle{{ section.id }}{
    padding-top:{{ section.settings.padding_top }}px;
    padding-bottom:{{ section.settings.padding_bottom }}px;
  }
  @media (max-width:768px){
     .customstyle{{ section.id }}{
    padding-top:{{ section.settings.mobile_padding_top }}px;
    padding-bottom:{{ section.settings.mobile_padding_bottom }}px;
  }
  }
  .blog-section{{ section.id }}{
    position: relative;
    z-index: {{ section.settings.zindex }};
  }
  .article__photo-wrapper.portrait{
    padding-top: 120% !important;
    overflow: hidden;
  }
  .article__photo-wrapper.square{
    padding-top: 100% !important;
    overflow: hidden;
  }
  .article__photo-wrapper.landscape{
    padding-top: 75% !important;
    overflow: hidden;
  }
  .article__photo-wrapper.wide{
    padding-top: 56% !important;
    overflow: hidden;
  }
  .article__photo-wrapper.portrait img,.article__photo-wrapper.square img, .article__photo-wrapper.landscape img,.article__photo-wrapper.wide img{
    height: 100%;
    object-fit: cover;
  }
  .bloglist-wrapper .blog__item{
    margin-bottom: 0 !important;
    padding-bottom: 0px !important;
  }
  @media(max-width:749px){
    .blog__item--3 .article__photo-wrapper{
      padding-top: 100% !important;
    }
  }
  /* --- Native scroll-snap Slider (Swiper-frei, P6) --- */
  .blogscroll-wrap-{{ section.id }}{ position: relative; }
  .blogscroll-{{ section.id }}{
    display: flex; gap: {{ blog_gap }}px;
    overflow-x: auto; overflow-y: hidden;
    scroll-snap-type: x mandatory; scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; -ms-overflow-style: none;
    --per: 1;
  }
  .blogscroll-{{ section.id }}::-webkit-scrollbar{ display: none; }
  @media (min-width: 768px){ .blogscroll-{{ section.id }}{ --per: {{ per_md }}; } }
  @media (min-width: 1200px){ .blogscroll-{{ section.id }}{ --per: {{ per_lg }}; } }
  .blogscroll-{{ section.id }} > .blogscroll-slide{
    flex: 0 0 calc((100% - (var(--per) - 1) * {{ blog_gap }}px) / var(--per));
    max-width: calc((100% - (var(--per) - 1) * {{ blog_gap }}px) / var(--per));
    scroll-snap-align: start; min-width: 0;
  }
  /* Buttons buendig (#67): Der Flex-Container macht die Slides gleich hoch,
     aber die innere Block-Kette wuchs nicht mit - Kette auf 100% strecken,
     Content als Spalte, Button per margin-top:auto ans Karten-Ende.
     align-self statt align-items, damit Titel/Text volle Breite behalten. */
  .blogscroll-{{ section.id }} > .blogscroll-slide > div{ height: 100%; }
  .blogscroll-{{ section.id }} .blog__item{ height: 100%; display: flex; flex-direction: column; }
  .blogscroll-{{ section.id }} .blog__content{ flex: 1 1 auto; display: flex; flex-direction: column; }
  .blogscroll-{{ section.id }} .blog__content .btn{ margin-top: auto; align-self: flex-start; }
  .blogscroll-wrap-{{ section.id }} .blogscroll-arrow{
    position: absolute; top: 28%; transform: translateY(-50%);
    width: 44px; height: 44px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    background: #fff; color: var(--g-color-carousel); border: 0; cursor: pointer;
    box-shadow: 0 2px 6px #36363626; z-index: 6;
    transition: all 0.3s ease;
  }
  .blogscroll-prev-{{ section.id }}{ left: -10px; }
  .blogscroll-next-{{ section.id }}{ right: -10px; }
  /* Exact same icon as the standard arrows: the swiper-icons font glyph via
     :after (content 'prev'/'next') — same size/colour — plus the same
     animateIcon hover (prev reversed), identical to .swiper-button-prev/next. */
  .blogscroll-wrap-{{ section.id }} .blogscroll-arrow:after{
    font-family: swiper-icons; font-size: 16px; line-height: 1;
    letter-spacing: 0; text-transform: none; font-variant: initial;
    display: inline-block;
  }
  .blogscroll-prev-{{ section.id }}:after{ content: 'prev'; }
  .blogscroll-next-{{ section.id }}:after{ content: 'next'; }
  .blogscroll-prev-{{ section.id }}:hover:after{ animation: 0.4s ease-in-out reverse forwards animateIcon; }
  .blogscroll-next-{{ section.id }}:hover:after{ animation: 0.4s ease-in-out forwards animateIcon; }
  .blogscroll-dots-{{ section.id }}{ display: flex; justify-content: center; gap: 8px; margin-top: 24px; }
  .blogscroll-dots-{{ section.id }} button{ width: 8px; height: 8px; padding: 0; border: 0; border-radius: 50%; background: currentColor; opacity: .25; cursor: pointer; }
  .blogscroll-dots-{{ section.id }} button.is-active{ opacity: 1; }
</style>

<div class="customstyle{{ section.id }} blog-section{{section.id}}" data-aos="{{ section.settings.animation }}">
  {%- render 'style-section' -%}
<div class="{{ section.settings.section_width }}">
  <div class="section-block">
    {%- render 'section-heading' -%}
    <div class="bloglist-wrapper dots-negative blogscroll-wrap-{{ section.id }}">
      <div class="bloglist-slider blogscroll-{{ section.id }}" id="Bloglist-{{ section.id }}" data-section-id="{{ section.id }}">
        {%- assign blog = blogs[section.settings.blog] -%}
        {%- assign limit = section.settings.limit -%}
        {%- if blog != blank -%}
          {%- for article in blog.articles limit: limit -%}
            <div class="bloglist-item blogscroll-slide"><div>
              {%- liquid
                case section.settings.item_style
                when 'blog-1'
                  render 'blog-grid-1', article: article, image_size: image_size, enable_btn_blog: enable_btn_blog, enable_btn_line: enable_btn_line, enable_date: enable_date, enable_tag: enable_tag, enable_comment: enable_comment, enable_short: enable_short, style_btn: style_btn, text_color: text_color
                when 'blog-3'
                  render 'blog-grid-3', article: article, image_size: image_size, enable_btn_blog: enable_btn_blog, enable_btn_line: enable_btn_line, enable_date: enable_date, enable_tag: enable_tag, enable_comment: enable_comment, enable_short: enable_short
                when 'blog-6'
                  render 'blog-grid-6', article: article, image_size: image_size, enable_btn_blog: enable_btn_blog, enable_btn_line: enable_btn_line, enable_date: enable_date, enable_tag: enable_tag, enable_comment: enable_comment, enable_short: enable_short, style_btn: style_btn
                when 'blog-7'
                  render 'blog-grid-7', article: article, image_size: image_size, enable_btn_blog: enable_btn_blog, enable_btn_line: enable_btn_line, enable_date: enable_date, enable_tag: enable_tag, enable_comment: enable_comment, enable_short: enable_short, style_btn: style_btn
                else
                  render 'blog-grid-blank'
                endcase
              -%}
            </div></div>
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..limit) -%}
            <div class="bloglist-item blogscroll-slide"><div>{%- render 'blog-grid-blank' -%}</div></div>
          {%- endfor -%}
        {%- endif -%}
      </div>
      {%- if section.settings.arrows -%}
        <button type="button" class="blogscroll-arrow blogscroll-prev-{{ section.id }}" aria-label="Previous"></button>
        <button type="button" class="blogscroll-arrow blogscroll-next-{{ section.id }}" aria-label="Next"></button>
      {%- endif -%}
      {%- if section.settings.dots -%}
        <div class="blogscroll-dots-{{ section.id }}"></div>
      {%- endif -%}
    </div>
  </div>
</div>
</div>

<script>
(function(){
  var sc = document.getElementById('Bloglist-{{ section.id }}');
  if(!sc || sc.dataset.snapInit) return;
  sc.dataset.snapInit = '1';
  var wrap = sc.closest('.blogscroll-wrap-{{ section.id }}') || sc.parentNode;
  function step(){ var s = sc.querySelector('.blogscroll-slide'); var g = parseFloat(getComputedStyle(sc).columnGap) || 0; return s ? s.getBoundingClientRect().width + g : sc.clientWidth; }
  var prev = wrap.querySelector('.blogscroll-prev-{{ section.id }}');
  var next = wrap.querySelector('.blogscroll-next-{{ section.id }}');
  if(prev){ prev.addEventListener('click', function(){ sc.scrollBy({ left: -step(), behavior: 'smooth' }); }); }
  if(next){ next.addEventListener('click', function(){ sc.scrollBy({ left: step(), behavior: 'smooth' }); }); }
  var dotsWrap = wrap.querySelector('.blogscroll-dots-{{ section.id }}');
  if(dotsWrap){
    dotsWrap.innerHTML = '';
    var slides = [].slice.call(sc.querySelectorAll('.blogscroll-slide'));
    slides.forEach(function(sl, i){
      var b = document.createElement('button');
      b.type = 'button'; b.setAttribute('aria-label', 'Slide ' + (i + 1));
      b.addEventListener('click', function(){ sc.scrollTo({ left: sl.offsetLeft - sc.offsetLeft, behavior: 'smooth' }); });
      dotsWrap.appendChild(b);
    });
    var dots = [].slice.call(dotsWrap.querySelectorAll('button'));
    var sync = function(){
      var x = sc.scrollLeft, best = 0, bd = Infinity;
      slides.forEach(function(sl, i){ var d = Math.abs((sl.offsetLeft - sc.offsetLeft) - x); if(d < bd){ bd = d; best = i; } });
      dots.forEach(function(d, i){ d.classList.toggle('is-active', i === best); });
    };
    sc.addEventListener('scroll', function(){ requestAnimationFrame(sync); });
    sync();
  }
})();
</script>
