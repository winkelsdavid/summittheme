                          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#000000" viewBox="0 0 256 256">
                            <path d="M181.66,133.66l-80,80a8,8,0,0,1-11.32-11.32L164.69,128,90.34,53.66a8,8,0,0,1,11.32-11.32l80,80A8,8,0,0,1,181.66,133.66Z"></path>
                          </svg>
                      </div>
                      <div class="swiper-button-prev_r swiper-button-prev-{{ section.id }}">
                          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="#000000" viewBox="0 0 256 256">
                            <path d="M165.66,202.34a8,8,0,0,1-11.32,11.32l-80-80a8,8,0,0,1,0-11.32l80-80a8,8,0,0,1,11.32,11.32L91.31,128Z"></path>
                          </svg>
                        </div>
                        {% endcomment %}
                      {% if section.settings.automatic_sliding %}
                      <div class="opac_item left_opac"></div>
                      <div class="opac_item right_opac"></div>
                      {% endif %}
                    </div>

      </div>
    </div>
  </div>
    {%- if section.blocks.size == 0 -%}
      {%- render 'no-blocks' -%}
    {%- endif -%}
  </div>
</div>
</div>
<script>
document.addEventListener('DOMContentLoaded', () => {
  initCustomVideoSlider_2('{{ section.id }}');
});

document.addEventListener('shopify:section:load', (event) => {
  const sectionId = event.detail.sectionId;
  initCustomVideoSlider_2(sectionId);
});

function initCustomVideoSlider_2(sectionId) {
  const container_2 = document.querySelector(`.custom_video_items-${sectionId}`);
  if (!container_2) return;

  let globalMuted_2 = true;

  // Read autoplay setting from data attribute
  const autoplayEnabled_2 = container_2.dataset.autoslide === 'true';
{%- assign speed_multiplier = 51 | minus : section.settings.speed -%}
const swiper_2 = new Swiper(`.custom_video_items-${sectionId}`, {
  slidesPerView: 2.8,
  spaceBetween: 12,
   centeredSlides: true,
   freeMode: autoplayEnabled_2 ? true : false, // Enables continuous scroll
  loop: true,
  speed: autoplayEnabled_2 ? {{  speed_multiplier | times : 1000 }} : 300, // Controls how fast it scrolls
  autoplay: autoplayEnabled_2 ? {
     delay: 1,
    disableOnInteraction: false,
      pauseOnMouseEnter: true
  } : false,
  allowTouchMove: !autoplayEnabled_2,
  simulateTouch: !autoplayEnabled_2,  
  breakpoints: {
    999: { slidesPerView: 2.5 },
    600: { slidesPerView: 2.5 }
  },
  on: {
    slideChange: function () {
      handleSlideChange_2(this);
    }
  }
});


  // Nach Swiper-Init erneut abfragen: loop:true erzeugt Duplikat-Slides,
  // deren Videos sonst nie gesteuert wuerden.
  container_2.querySelectorAll('video').forEach(v => (v.muted = globalMuted_2));
  handleSlideChange_2(swiper_2);

  // Delegation statt Index-Zuordnung (funktioniert auch in Duplikat-Slides).
  container_2.addEventListener('click', (e) => {
    const btn = e.target.closest('.shoppable-video_control-button');
    if (btn) {
      const slide = btn.closest('.swiper-slide');
      const vid = slide && slide.querySelector('video');
      if (vid) {
        if (vid.paused) {
          const p = vid.play();
          if (p && p.catch) p.catch(() => {});
          btn.classList.add('playing');
        } else {
          vid.pause();
          btn.classList.remove('playing');
        }
      }
      return;
    }
    const mbtn = e.target.closest('.video__sound-toggle');
    if (mbtn) {
      globalMuted_2 = !globalMuted_2;
      container_2.querySelectorAll('video').forEach(v => (v.muted = globalMuted_2));
      container_2
        .querySelectorAll('.video__sound-toggle')
        .forEach(b => b.classList.toggle('unmuted', !globalMuted_2));
    }
  });
}


function handleSlideChange_2(swiper) {
  // Swiper 6: swiper.slides ist eine Dom7-Collection (kein Array.indexOf) und
  // loop dupliziert Slides — daher ueber swiper-slide-active steuern statt Index.
  swiper.el.querySelectorAll('.swiper-slide').forEach((slide) => {
    const vid = slide.querySelector('video');
    if (!vid) return;
    const btn = slide.querySelector('.shoppable-video_control-button');
    if (slide.classList.contains('swiper-slide-active') || slide.classList.contains('swiper-slide-duplicate-active')) {
      const p = vid.play();
      if (p && p.catch) p.catch(() => {});
      if (btn) btn.classList.add('playing');
    } else {
      vid.pause();
      if (btn) btn.classList.remove('playing');
    }
  });
}


</script>
