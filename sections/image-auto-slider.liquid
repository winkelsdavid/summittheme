<!-- image-content.liquid -->
<style>

 /* .customstyle{{ section.id }}::before{
    position: absolute;
    top:0;
    content: "";
    {%- if section.settings.bg_pos == 'left' -%}
      left:0;
    {%- else -%}
      right:0;
    {%- endif -%}
    width:33%;
    height: {{ section.settings.rangebg }}%;
    background-color: {{ section.settings.bgbefore }};
  }*/
      .customstyle{{ section.id }}{
    padding-top:{{ section.settings.padding_top }}px;
    padding-bottom:{{ section.settings.padding_bottom }}px;
  }
  .customstyle{{ section.id }} .wt-video__movie{
    height:100%;
  }
  /*.custom_shoppable_video video,
  .custom_shoppable_video img,
.custom_shoppable_video .svg_video svg{
    width: 100%;
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    transition: height .3s ease-out;
}*/
 .customstyle{{ section.id }}  .swiper-wrapper {
    transition-timing-function: linear;
}
.opac_item{
    position:absolute;
    top:0;
    height:100%;
    width:20%;
    z-index: 2;
  }
  .customstyle{{ section.id }} .opac_item.left_opac{
    left:0;
        background: linear-gradient(90deg, {{ section.settings.opacity_color }}, transparent);
  }
  .customstyle{{ section.id }} .opac_item.right_opac{
    right:0;
        background: linear-gradient(270deg, {{ section.settings.opacity_color }}, transparent);
    
  }
  .wt-video__movie{
  height:100%;
  {% if settings.enable_radius_allimg %}border-radius:calc(0.2rem * {{ settings.radius_allimg_range }});{% endif %}
  overflow:hidden;
  }
  .wt-video__movie svg{
    aspect-ratio: 3/4;
  }
  /* Media fills its (Swiper-equalised) slide box without distortion -> fixes the
     squish, and gives the placeholder svg a definite size so it shows. No forced
     container aspect-ratio, so slide height/shape stays exactly as before.
     Direct-child (>) keeps the inline video control-icon svgs untouched. */
  .customstyle{{ section.id }} .wt-video__movie > img,
  .customstyle{{ section.id }} .wt-video__movie > video,
  .customstyle{{ section.id }} .wt-video__movie > svg{
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
  }
  /* The global .placeholder-svg colour is dark + semi-transparent, so on this
     section's (often dark) background the empty-slide placeholder was invisible.
     Force a visible light-grey example box, like the placeholders elsewhere. */
  .customstyle{{ section.id }} .wt-video__movie .placeholder-svg {
    background: #e8e8e8;
    fill: #c0c0c0;
  }
  .kik_video_item,
  .c_video_content,
  .video_item_image_text,
  .c_video_item_c,
  .c_video_item_c img{
  height:100%;
  }
  @media(max-width:749px){
     .customstyle{{ section.id }}{
    padding-top:{{ section.settings.mobile_padding_top }}px;
    padding-bottom:{{ section.settings.mobile_padding_bottom }}px;
  }
    .customstyle{{ section.id }}::before{
      {%- if section.settings.bg_pos == 'left' -%}
        left:0;
        top:0;
        right:0;
        width:100%;
        bottom:auto;
      {%- else -%}
        right:0;
        left:0;
        top:auto;
        bottom:0;
        width:100%;
      {%- endif -%}
    }
    .c_row.top{
      flex-direction:column-reverse;
      margin:0;
    }
     .c_row.top .flex__item{
      flex:unset;
      width:100%!important;
    }
  }
</style>
<div class="customstyle{{ section.id }} position-relative" >
  {%- render 'style-section' -%}
  <style>
    .customstyle{{ section.id }}{
      background:{{ section.settings.background_section }}
    }
  </style>
    
  <div class="{{ section.settings.section_width }}">
  <div class="section-block">
    <div class="row {% unless section.settings.enable_padding %}no-gutters {% endunless %}">
      {%- liquid
        case section.blocks.size 
        when 1 
          assign flex_size = '' 
        when 2 
          assign flex_size = 'col-md-6' 
        when 3 
          assign flex_size = 'col-md-4' 
        else 
          assign flex_size = 'col-md-6' 
      endcase 
      -%}
      <div class="c_row row flex__item flex {% if section.settings.align_center %}flex--center-vertical{% endif %} {{ section.settings.mobile_pos }}" {{ block.shopify_attributes }}>
      {%- for block in section.blocks -%}
        
          {%- case block.type -%}
            {%- when 'text_block' -%}
              {%- assign text_color = block.settings.title_color -%}
              <div class="mb-lg-0  flex__item flex flex--center-vertical col-md-6">
              <div class="img_text_block flex  w-100 flex--center-vertical p-3 pb-5 p-lg-5 " style="background-color:{{ block.settings.bgtext }} ;" data-aos="{{ section.settings.animation }}"  data-aos-delay="{{ forloop.index | times: 100 }}" {{ block.shopify_attributes }}>
                <div class="flex__item image-content__text text-{{ block.settings.align }}"  {% if text_color != 'rgba(0,0,0,0)' %}
                  style="--g-font-color-subtop: {{ text_color }};--g-color-heading :  {{ text_color }};--color-body-text : {{ text_color }};--color-body-text-rgb: {{ text_color.red }}, {{ text_color.green }},  {{ text_color.blue }} ;"
                {% endif %} >
                <div class="row justify-content-{{- block.settings.block_align -}}">
                  {%- liquid
                    case block.settings.width 
                    when '50%' 
                      assign block_width = 'col-lg-6 col-12' 
                    when '58%' 
                      assign block_width = 'col-lg-7 col-12 ' 
                    when '66%' 
                      assign block_width = 'col-lg-8 col-12 ' 
                    when '75%' 
                      assign block_width = 'col-lg-9 col-12 ' 
                    when '100%' 
                      assign block_width = 'col-12' 
                  endcase 
                  -%}
                  <div class="{{ block_width }}">
                  {% if block.settings.replace_reviews %}
                      {%  render 'rating-custom', section: block , align : block.settings.align %}
                  {% else %}
                    {%- if block.settings.subtitle != blank -%}
                      <div class="subtop mb-3">{{ block.settings.subtitle }}</div>
                    {%- endif -%}
                  {% endif %}
                    {%- if block.settings.title != blank -%}
                    <h3 class="mb-3 {{ block.settings.size_text }} ">{{ block.settings.title }}</h3>
                    {%- endif -%}
                    {%- if block.settings.content -%}
                      <div class="rte-setting">{{ block.settings.content }}</div>
                    {%- endif -%}
                    {%- comment -%} answer_content (Richtext-Duplikat mit Default-Text) wird
                        nicht mehr gerendert — nur die HTML-Description (content) zaehlt.
                        Schema-ID bleibt wegen Nitro-Mappability erhalten. {%- endcomment -%}
                    {%- if block.settings.button != blank -%}
                      <div class="mt-4">
                        <a href="{{ block.settings.link }}" class="btn {{ block.settings.style_btn }} ">
                          {{ block.settings.button }}
                        </a>
                      </div>
                      {%- endif -%}
                    </div>
                  </div>
                </div>
              </div>
              </div>
          {%- endcase -%}
      {%- endfor -%}
      <div class="mb-lg-0  flex__item flex flex--center-vertical col-md-6">
