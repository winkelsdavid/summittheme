<script>
function initReviewSlider(sectionId, autoplayEnabled, autoplaySpeed) {
  const sliderSelector = `.custom_slider_items-${sectionId}`;
  const nextBtn = `.swiper-button-next-${sectionId}`;
  const prevBtn = `.swiper-button-prev-${sectionId}`;
  const container = document.querySelector(sliderSelector);
  if (!container) return;

  // Destroy existing Swiper instance if needed
  if (container.swiper) {
    container.swiper.destroy(true, true);
  }

  const config = {
    slidesPerView: "auto",
    spaceBetween: 0,
    loop: true,
    centeredSlides: true,
    navigation: {
      nextEl: nextBtn,
      prevEl: prevBtn
    }
  };

  if (autoplayEnabled) {
    config.autoplay = {
      delay: autoplaySpeed * 1000,
      disableOnInteraction: false
    };
  }

  new Swiper(sliderSelector, config);
}

// Initial load
document.addEventListener('DOMContentLoaded', () => {
  initReviewSlider('{{ section.id }}', {{ section.settings.autoplay | json }}, {{ section.settings.speed }});
});

// Re-init on section load in Customizer
document.addEventListener('shopify:section:load', (event) => {
  const section = event.target.querySelector('[data-section-id]');
  if (!section) return;

  const sectionId = section.dataset.sectionId;
  const autoplayEnabled = section.dataset.autoplay === "true";
  const autoplaySpeed = parseInt(section.dataset.autoplaySpeed || "3");

  initReviewSlider(sectionId, autoplayEnabled, autoplaySpeed);
});

// Optional: Re-init on resize (if layout depends on viewport)
window.addEventListener('resize', () => {
  initReviewSlider('{{ section.id }}', {{ section.settings.autoplay | json }}, {{ section.settings.speed }});
});
</script>

