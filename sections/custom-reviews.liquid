<style>
  .custom_reviews_slider-{{ section.id }}{
    background:{{ section.settings.background }};
     padding-top:{{ section.settings.padding_top }}px;
    padding-bottom:{{ section.settings.padding_bottom }}px;
    {% if section.settings.h_s_color != blank %}
      {% if section.settings.h_s_color != "rgba(0,0,0,0)" %}
    --g-color-heading:{{ section.settings.h_s_color   }};
    --g-font-color-subtop:{{ section.settings.h_s_color   }};
      {% endif %}
    {% endif %}
  }

  .c_testimonial-header-review {
    display: flex;
    align-items: center;
    gap: 10px;
    
}
  .justify-left{
    justify-content:flex-start;
  }
  .justify-center{
    justify-content:center;
  }
    .justify-right{
    justify-content:flex-end;
  }
 .c_testimonial-header-review span{
   font-size:14px;
 } 
  .c_testimonial-header-review svg{
    width:auto;
  }
  .custom_slider_items {
    width: 100%;
    height: unset;
    padding-block: 20px;
    overflow: hidden;
    background-color: unset;
}
  .custom_slider_items .swiper-wrapper {
    align-items: center;
    flex-direction: row;
}
  .custom_review {
    padding: 30px;
    {% if settings.enable_radius_allimg %}
    border-radius: calc(0.2rem * {{ settings.radius_allimg_range }});
    {% endif %}
    max-width: 400px;
    display: flex !important;
    flex-direction: column;
    gap: 10px;
    box-shadow: rgba(0, 0, 0, 0.05) 0px 0px 0px 1px;
    align-items: flex-start;
    justify-content: center;
    background: var(--g-chrome-bg, #ffffff);
}
  .c_testimonial-reviewbox-verified-text {
    display: flex;
    align-items: center;
    gap: 5px;
}
  .c_testimonial-reviewbox-verified-text svg {
    width: 20px;
    height: 20px;
    fill: var(--badge-color, var(--g-chrome-text, #9e9e9e));
}
  .c_testimonial-reviewbox-verified-text span {
    font-size: 16px;
}
  .c_testimonial-reviewbox-footer {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
}
  .c_testimonial-reviewbox-user-info {
    display: flex;
    align-items: center;
    gap: 10px;
}
  .c_testimonial-reviewbox-user-info img {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    object-fit: cover;
}
  .c_testimonial-reviewbox-user-info-text {
    display: flex;
    flex-direction: column;
}
  .c_testimonial-reviewbox-rating {
    display: flex;
}
  .c_testimonial-reviewbox-rating svg{
    fill:{{ section.settings.color }};
  }
  {%- if section.settings.color_gradient != blank -%}
  .c_testimonial-reviewbox-footer .c_testimonial-reviewbox-rating svg{
    fill: transparent;
    background: {{ section.settings.color_gradient }};
    -webkit-mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 256 256'><path d='M234.29,114.85l-45,38.83L203,211.75a16.4,16.4,0,0,1-24.5,17.82L128,198.49,77.47,229.57A16.4,16.4,0,0,1,53,211.75l13.76-58.07-45-38.83A16.46,16.46,0,0,1,31.08,86l59-4.76,22.76-55.08a16.36,16.36,0,0,1,30.27,0l22.75,55.08,59,4.76a16.46,16.46,0,0,1,9.37,28.86Z'/></svg>") center / contain no-repeat;
    mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 256 256'><path d='M234.29,114.85l-45,38.83L203,211.75a16.4,16.4,0,0,1-24.5,17.82L128,198.49,77.47,229.57A16.4,16.4,0,0,1,53,211.75l13.76-58.07-45-38.83A16.46,16.46,0,0,1,31.08,86l59-4.76,22.76-55.08a16.36,16.36,0,0,1,30.27,0l22.75,55.08,59,4.76a16.46,16.46,0,0,1,9.37,28.86Z'/></svg>") center / contain no-repeat;
  }
  {%- endif -%}
  .custom_slider_items .swiper-slide {
    opacity: .7;
    scale: .9;
    transition: opacity 0.3s ease-in-out, scale 0.5s ease-in-out !important;
}
  .custom_slider_items .swiper-slide-active {
    opacity: 1;
    scale: 1;
    transition: opacity 0.3s ease-in-out, scale 0.5s ease-in-out !important;
}
  .custom_slider_items .swiper-button-next_r, .custom_slider_items .swiper-button-prev_r {
    position: absolute;
    top: var(--swiper-navigation-top-offset,50%);
    width: 50px;
    height: 50px;
    margin-top: -20px;
    z-index: 10;
    cursor: pointer;
    display: flex;
    box-shadow: rgba(0, 0, 0, 0.1) 0px 10px 50px;
    align-items: center;
    justify-content: center;
    background-color: white;
    border-radius: 50%;
    border: 1px solid #21212117;
}
   .custom_slider_items .swiper-button-prev_r {
    left: 10px;
    right: auto;
}
  .custom_slider_items .swiper-button-next_r {
    right: 10px;
    left: auto;
}
  .custom_slider_items .swiper-button-next_r svg,
  .custom_slider_items .swiper-button-prev_r svg {
    fill: var(--g-chrome-text, #000000);
}
  .reviews_link_label{
    display:flex;
    justify-content:center;
    margin-top:24px;
  }
  .reviews_link_label .btn{
    width:fit-content;
  }
  @media (max-width:768px){
      .custom_reviews_slider-{{ section.id }}{
         padding-top:{{ section.settings.mobile_padding_top }}px;
          padding-bottom:{{ section.settings.mobile_padding_bottom }}px;
      }

    .custom_review {
    max-width: 300px;
}
    
  }
