                <script>
                  document.querySelectorAll('.video_item').forEach((container) => {
                    const video = container.querySelector('video');
                    const playButton = container.querySelector('.play-button');

                    if (video && playButton) {
                      // Click video to toggle play/pause
                      video.addEventListener('click', () => {
                        toggleVideoPlayback(video, playButton);
                      });

                      // Click play button to toggle play/pause
                      playButton.addEventListener('click', () => {
                        toggleVideoPlayback(video, playButton);
                      });

                      // Hide button when video plays
                      video.addEventListener('play', () => {
                        pauseAllOtherVideos(video);
                        playButton.classList.add('paused');
                      });

                      // Show button when video pauses
                      video.addEventListener('pause', () => {
                        playButton.classList.remove('paused');
                      });

                      // Show button when video ends
                      video.addEventListener('ended', () => {
                        playButton.style.display = 'block';
                      });
                    }
                  });

                  // Function to pause all videos except the current one
                  function pauseAllOtherVideos(currentVideo) {
                    document.querySelectorAll('.video_item video').forEach((v) => {
                      if (v !== currentVideo && !v.paused) {
                        v.pause();
                      }
                    });
                  }

                  // Function to toggle video playback
                  function toggleVideoPlayback(video, playButton) {
                    if (video.paused) {
                      video.play();
                      playButton.classList.add('paused');
                    } else {
                      video.pause();
                    }
                  }
                </script>

