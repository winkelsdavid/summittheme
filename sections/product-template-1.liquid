<div
  class="{{ section.settings.section_width }} js-recently-view"
  itemscope
  itemtype="http://schema.org/Product"
  id="ProductSection-{{ section.id }}"
  data-id="{{ section.settings.media_style }}"
  data-section-id="{{ section.id }}"
  data-section-type="product"
  data-enable-history-state="true"
  data-ajax="true"
  data-stock="{{ section.settings.stock_enable }}"
  data-handle="{{ product.handle }}"
  data-autoplay="{{ section.settings.e_autoplay }}"
  data-videoloop="{{ section.settings.e_loop }}"
>
  {%- liquid
    assign current_variant = product.selected_or_first_available_variant
    assign left_size = 'col-md-6 col-12'
    assign right_size = 'col-md-6 col-12'
    case section.settings.media_size
      when 'small'
        assign left_size = 'col-md-5 col-12'
        assign right_size = 'col-md-7 col-12'
      when 'normal'
        assign left_size = 'col-md-6 col-12'
        assign right_size = 'col-md-6 col-12'
      when 'large'
        assign left_size = 'col-md-7 col-12'
        assign right_size = 'col-md-5 col-12'
      when 'largest'
        assign left_size = 'col-md-8 col-12'
        assign right_size = 'col-md-4 col-12'
    endcase
    assign featured_img = current_variant.featured_image | default: product.featured_image

    assign media_style = section.settings.media_style
  -%}
  {%- if media_style == 'media-collage-1' or media_style == 'media-collage-2' -%}
    {% style %}
      /* Collage: Unterkanten beider Spalten enden immer buendig auf der Row-Unterkante.
         Rechts laenger -> Bildzeilen strecken sich mit (cover-Crop);
         links laenger -> letzter Info-Block (z.B. Banner) wird unten angepinnt. */
      @media (min-width: 768px) {
        #ProductSection-{{ section.id }} .photos-thumb-collage-1,
        #ProductSection-{{ section.id }} .photos-thumb-collage-2,
        #ProductSection-{{ section.id }} .photos-thumb-collage-1 .photos__item--main,
        #ProductSection-{{ section.id }} .photos-thumb-collage-2 .photos__item--main {
          height: 100%;
        }
        #ProductSection-{{ section.id }} .my-gallery {
          height: 100%;
          align-content: stretch;
          /* Zeilenabstand via gap statt margin: kein Nachlauf-Margin unter der letzten Reihe */
          row-gap: var(--g-gutter);
        }
        #ProductSection-{{ section.id }} .my-gallery .product-single__photo {
          margin: 0;
        }
        #ProductSection-{{ section.id }} .my-gallery .product__photo-wrapper {
          height: 100%;
        }
        #ProductSection-{{ section.id }} .my-gallery .product__photo-wrapper img {
          height: 100%;
          object-fit: cover;
        }
        #ProductSection-{{ section.id }} .product-single__info-wrapper {
          height: 100%;
          display: flex;
          flex-direction: column;
        }
        #ProductSection-{{ section.id }} .product-single__meta {
          display: flex;
          flex-direction: column;
          flex: 1 1 auto;
        }
        #ProductSection-{{ section.id }} .product-single__meta > :last-child {
          margin-top: auto;
          margin-bottom: 0;
        }
      }
    {% endstyle %}
  {%- endif -%}
  <meta itemprop="name" content="{{ product.title }}">
  <meta itemprop="url" content="{{ shop.url }}{{ product.url }}">
  <meta itemprop="image" content="{{ product.featured_image.src | image_url: width: 600, height: 600 }}">
  <meta itemprop="brand" content="{{ product.vendor }}">

  <div class="row product-single c_{{ section.settings.image_size }}">
    <div
      class="
        {{ left_size }}
          {% unless media_style == 'media-list' or media_style == 'media-grid' or media_style == 'media-collage-1' or media_style == 'media-collage-2' %}
          photos-sticky
        {% endunless %}
      "
    >
      {% render 'product-media',
        product: product,
        featured_image: featured_img,
        image_size: section.settings.image_size,
        loop: section.settings.enable_video_looping,
        media_style: section.settings.media_style
      %}
    </div>
    <div
      class="
        {{ right_size }} order-1
        {% if  media_style == 'media-list' or media_style == 'media-grid' or media_style == 'media-collage-1' or media_style == 'media-collage-2' %}
        photos-sticky
        {% endif %}
      "
      itemprop="offers"
      itemscope
      itemtype="http://schema.org/Offer"
    >
      <div class="product-single__info-wrapper">
        <meta itemprop="priceCurrency" content="{{ shop.currency }}">
        <link
          itemprop="availability"
          href="http://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}"
        >
        <div class="product-single__meta small--text-center">
          {%- comment -%} METAFIELD_CONTRACT.md: summit.*-Metafields gewinnen, wenn gesetzt;
              leere Arrays zaehlen als nicht gesetzt (Normalisierung auf nil). {%- endcomment -%}
          {%- liquid
            assign smf_usps = product.metafields.summit.usps.value
            unless smf_usps and smf_usps[0]
              assign smf_usps = nil
            endunless
            assign smf_faq = product.metafields.summit.faq.value
            unless smf_faq and smf_faq[0]
              assign smf_faq = nil
            endunless
            assign smf_reviews = product.metafields.summit.reviews.value
            unless smf_reviews and smf_reviews[0]
              assign smf_reviews = nil
            endunless
            assign smf_rimgs = product.metafields.summit.review_images.value
            unless smf_rimgs and smf_rimgs[0]
              assign smf_rimgs = nil
            endunless
            assign smf_banner = product.metafields.summit.banner.value
          -%}
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when '@app' -%}
                {% render block %}
              {%- when 'text' -%}
                <p
                  class="product-block product__text{% if block.settings.text_style == 'uppercase' %} text-uppercase {% elsif block.settings.text_style == 'subtitle' %} subtop{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  {{- block.settings.text -}}
                </p>
              {%- when 'title' -%}
                <style>
                  .product-single__title,
                  .product-single__title *{
                    font-size:{{ block.settings.font_size }}px;
                    line-height: var(--g-h3-font-lineheight);
                    }
                    @media (max-width:768px){
                      .product-single__title,
                      .product-single__title *{
                       font-size:{{ block.settings.font_size_mobile }}px;
                      }
                    }
                </style>
                <div class="product-block product-title" {{ block.shopify_attributes }}>
                  {%- if block.settings.e_label -%}
                    {% render 'product-label', showlabel: false %}
                  {%- endif -%}
                  <h1 itemprop="name" class="product-single__title">
                    {% comment -%} METAFIELD_CONTRACT.md Abschn. 2: Titel immer nativ
                        product.title; use_custom_title/custom_title entfallen (Settings
                        bleiben im Schema als tote Felder — Mappability). {%- endcomment -%}
                    {% if block.settings.use_custom_title %}
                      {{ product.title }}
                    {% else %}
                      {{ product.title }}
                    {% endif %}
                  </h1>
                </div>
              {% when 'reviews_start' %}
                <style>
                  .truspilot_icon{
                    width:72px;
                  }
                  .amazon_icon{
                  width:72px;
                  }
                  .ebay_icon{
                  width:52px;
                  }
                  .etsy_icon{
                  width:42px;
                  }
                  .google_icon{
                  width:62px;
                  }
                </style>
                <div
                  class="rating-custom product-block"
                  style="--font_size:{{ block.settings.font_size }}px;--radius:{{ block.settings.radius }}px;--border-color:{{ block.settings.border_color }};--stars-color:{{ block.settings.stars_color }};--background:{% if block.settings.background != blank %}{{ block.settings.background }}{% else %}{{ settings.branding_color }}{% endif %};"
                  {{ block.shopify_attributes }}
                >
                  <div class="trustpilot-block-rating-text">
                    {% comment %}
                    {% assign sanitized_text = block.settings.text | strip_html | downcase | replace: 'out of', '/' %}
                    {% assign pre_slash = sanitized_text | split: '/' | first | strip %}
                    {% assign rating_string = pre_slash | split: ' ' | last | strip %}
                    {% assign rating = rating_string | replace: ',', '.' | plus: 0.0 %}
                    {% if rating == 0 %}{% assign rating = rating_string | plus: 0.0 %}{% endif %}
                     {% endcomment %}
                    {% assign rating = block.settings.stars_rating %}
                    {% assign fill_percentage_3 = rating | divided_by: 5.0 | times: 100 %}
                    <svg
                      class="trustpilot-star-five"
                      style="--height:{{ block.settings.stars_height }}px"
                      height="15"
                      width="80"
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 512 96"
                    >
                        <defs>
                          <linearGradient id="grad-1-{{ ii }}-{{ section.id }}">
                            <stop offset="{{ fill_percentage_3 }}%" stop-color="{{ block.settings.stars_color }}" />
                            <stop offset="{{ fill_percentage_3 }}%" stop-color="transparent" />
                          </linearGradient>
                           <linearGradient id="grad-stars-{{ ii }}-{{ section.id }}">
                                  <stop offset="{{ fill_percentage_3 | plus : 3 }}%" stop-color="#fff" />
                                  <stop offset="{{ fill_percentage_3 | plus : 3 }}%" stop-color="transparent" />
                                </linearGradient>
                        </defs>
                      <g fill="none"><g fill="url(#grad-1-{{ ii }}-{{ section.id }})"><path d="M0 0h96v96H0zM104 0h96v96h-96zM208 0h96v96h-96zM312 0h96v96h-96zM416 0h96v96h-96z"></path></g><path d="M48 64.7L62.6 61l6.1 18.8zm33.6-24.3H55.9L48 16.2l-7.9 24.2H14.4l20.8 15-7.9 24.2 20.8-15 12.8-9.2zM152 64.7l14.6-3.7 6.1 18.8zm33.6-24.3h-25.7L152 16.2l-7.9 24.2h-25.7l20.8 15-7.9 24.2 20.8-15 12.8-9.2zM256 64.7l14.6-3.7 6.1 18.8zm33.6-24.3h-25.7L256 16.2l-7.9 24.2h-25.7l20.8 15-7.9 24.2 20.8-15 12.8-9.2zM360 64.7l14.6-3.7 6.1 18.8zm33.6-24.3h-25.7L360 16.2l-7.9 24.2h-25.7l20.8 15-7.9 24.2 20.8-15 12.8-9.2zM464 64.7l14.6-3.7 6.1 18.8zm33.6-24.3h-25.7L464 16.2l-7.9 24.2h-25.7l20.8 15-7.9 24.2 20.8-15 12.8-9.2z" fill="url(#grad-stars-{{ ii }}-{{ section.id }})"></path></g>
                    </svg>
                    <span class="rating-excellent" style="--color:{{ block.settings.text_color }}">{% if block.settings.text != blank %}{{ block.settings.text }}{% else %}{{ 'products.product.reviews_start_text_html' | t }}{% endif %}</span>
                    {% if block.settings.show_truspilot  %}
                    
