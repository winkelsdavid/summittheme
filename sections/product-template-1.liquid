                 function updateDeliveryDate() {
                      const deliveryElement = document.getElementById('delivery-date');
                      if (!deliveryElement) return;

                      const daysToAdd = parseInt(deliveryElement.dataset.days, 10);
                      const deliveryDate = new Date();
                      deliveryDate.setDate(deliveryDate.getDate() + daysToAdd);

                      // Shop-Locale statt Monats-Tabelle: lokalisiert Monatsname UND
                      // Format/Reihenfolge (de: "8. Juli", en: "July 8").
                      deliveryElement.innerText = deliveryDate.toLocaleDateString(
                        '{{ request.locale.iso_code }}',
                        { month: 'long', day: 'numeric' }
                      );
                    }

                    // Run on initial load
                    document.addEventListener('DOMContentLoaded', updateDeliveryDate);

                    // Re-run when Shopify customizer updates sections
                    if (window.Shopify && Shopify.designMode) {
                      document.addEventListener('shopify:section:load', updateDeliveryDate);
                      document.addEventListener('shopify:section:select', updateDeliveryDate);
                    }

