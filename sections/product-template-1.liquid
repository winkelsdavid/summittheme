                      class="product-single__price"
                      itemprop="price"
                      content="{{ current_variant.price | divided_by: 100.00 }}"
                    >
                      {{ current_variant.price | money }}
                    </span>
                  </li>

                  <li
                    {% if product.compare_at_price_max > product.price %}
                    {% else %}
                      style="display:none"
                    {% endif %}
                  >
                    <span class="visually-hidden">{{ 'products.product.regular_price' | t }}</span>
                    <s id="ComparePrice-{{ section.id }}" class="product-single__price product-single__price--compare">
                      {% if product.compare_at_price_max > product.price %}
                        {{ current_variant.compare_at_price | money }}
                      {% else %}
                        {{ current_variant.price | money }}
                      {% endif %}
                    </s>
                  </li>
                  {%- if settings.sale_label_enable -%}
                    <li style="padding-right:5px;">
                      {% capture txtupper %}{% if settings.txtuppercase %}text-uppercase {% endif %}{% endcapture %}
                      <div
                        class="d-inline-block hide product-tag product-tag-sale product-tag--absolute {{ txtupper }} {{ settings.tagsale }}"
