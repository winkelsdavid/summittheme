                                assign isColor = true
                              elsif kw1 != blank and optionName_dc contains kw1
                                assign isColor = true
                              elsif kw2 != blank and optionName_dc contains kw2
                                assign isColor = true
                              endif
                            -%}
                          {%- endif -%}
                          <div class="selector-wrapper js product-form__item {% if isColor %} {% if siblings_collection != blank and enable_sibling %} d-none {% endif %} {% endif %}  ">
