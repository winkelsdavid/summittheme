  // Initial load
  document.addEventListener('DOMContentLoaded', attachBundleScript);

  // Re-attach after Shopify section updates
  document.addEventListener('shopify:section:load', attachBundleScript);

  function initBundlePriceUpdater() {
    const checkboxes = document.querySelectorAll(".bundle_products input[type='checkbox']");
    let priceDisplay = document.querySelector('.custom_price');
    let compareDisplay = document.querySelector('.compare_price');

    const productPriceEl = document.querySelector('.product-single__meta-price .product-single__price');
    const comparePriceEl = document.querySelector('.product-single__meta-price .product-single__price--compare');
    const saleBadgeEl = document.querySelector('.product-tag-sale-number');

     

    if ( !productPriceEl || !saleBadgeEl || checkboxes.length === 0){
        console.warn("Stopping: One or more required elements are missing.");
        return; 
    }

     

    if(!priceDisplay){
      priceDisplay = productPriceEl;
    }
    if(!compareDisplay){
      compareDisplay = comparePriceEl;
    }
    
    console.log({
        checkboxesFound: checkboxes.length,
        productPriceEl: productPriceEl,
        saleBadgeEl: saleBadgeEl
    });

    

    const basePriceText = priceDisplay.textContent.trim();
    const currencySymbol = basePriceText.match(/[^\d,.\s]+/g)?.[0] || '';
    const basePrice = parseFloat(basePriceText.replace(/[^\d,]/g, '').replace(',', '.'));

    console.log({
         basePrice
    });

    const baseCompareText = compareDisplay.textContent.trim();
    const baseComparePrice = baseCompareText
      ? parseFloat(baseCompareText.replace(/[^\d,]/g, '').replace(',', '.'))
      : basePrice;

    function parsePrice(text) {
      return parseFloat(text.replace(/[^\d,]/g, '').replace(',', '.'));
    }

function formatPrice(value) {
    // 1. Convert to a number just in case it's a string
    let numericValue = parseFloat(value);

    // 2. DO NOT divide by 100 if your console.log shows 93 for £93
    // Just ensure it has two decimal places and the comma swap
    return currencySymbol + numericValue.toFixed(2).replace('.', ',');
}

    function updateTotal() {
      let totalPrice = basePrice;
      let totalCompare = baseComparePrice;
      

      checkboxes.forEach((checkbox) => {
        if (checkbox.checked) {
          const label = checkbox.closest('label');
          const salePriceEl = label.querySelector('.price__sale');
          const regularPriceEl = label.querySelector('.price__regular');

          if (salePriceEl && regularPriceEl) {
            totalPrice += parsePrice(regularPriceEl.textContent);
            totalCompare += parsePrice(salePriceEl.textContent);
          } else if (regularPriceEl) {
            const regular = parsePrice(regularPriceEl.textContent);
            totalPrice += regular;
            totalCompare += regular;
          }
          console.log(totalPrice,totalCompare)
        }
      });

      priceDisplay.textContent = formatPrice(totalPrice);
      compareDisplay.textContent = '(' + formatPrice(totalCompare) + ')';
      if (comparePriceEl) {
        comparePriceEl.textContent = '(' + formatPrice(totalCompare) + ')';
      }

      if (totalPrice === totalCompare) {
        compareDisplay.style.display = 'none';
        if (comparePriceEl?.closest('li')) {
          comparePriceEl.closest('li').style.display = 'none';
        }
      } else {
        compareDisplay.style.display = 'inline-block';
        if (comparePriceEl?.closest('li')) {
          comparePriceEl.closest('li').style.display = 'inline-block';
        }
      }

      productPriceEl.textContent = formatPrice(totalPrice);
      productPriceEl.setAttribute('content', totalPrice.toFixed(2));

      const discount = totalCompare > totalPrice ? Math.round(((totalCompare - totalPrice) / totalCompare) * 100) : 0;

      saleBadgeEl.textContent = discount + '%';
    }

    checkboxes.forEach((checkbox) => {
      checkbox.addEventListener('change', updateTotal);
    });

    updateTotal();
  }

  document.addEventListener('DOMContentLoaded', initBundlePriceUpdater);
  document.addEventListener('shopify:section:load', initBundlePriceUpdater);
</script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    const select = document.querySelector('.product-form__variants.no-js');
    const quantityWrapper = document.querySelector('.product-form__item--quantity');

    function getMaxCount() {
      const selectedOption = select.options[select.selectedIndex];
      return parseInt(selectedOption.getAttribute('data-count'), 10) || 1;
    }

    function enforceQuantityLimit(input) {
      const max = getMaxCount();
      let current = parseInt(input.value, 10) || 1;
      console.log(max);
      if (current > max) {
        input.value = max;

        // Show growl only when quantity exceeds max
        const growl = document.querySelector('.c_growl_default');
        if (growl && growl.classList.contains('hide')) {
          growl.classList.remove('hide');
          setTimeout(() => {
            growl.classList.add('hide');
          }, 2000);
        }
      }

      if (current < 1) input.value = 1;
    }

    function attachInputListener() {
      const quantityInput = document.getElementById('Quantity');
      if (quantityInput && !quantityInput.dataset.listenerAttached) {
        quantityInput.addEventListener('input', () => {
          console.log('Input event triggered');
          enforceQuantityLimit(quantityInput);
        });
        quantityInput.dataset.listenerAttached = 'true';
        console.log('Listener attached to Quantity');
      }
    }

    function updateQuantityFromSelect() {
      const quantityInput = document.getElementById('Quantity');
      const max = getMaxCount();
      if (quantityInput) {
        let current = parseInt(quantityInput.value, 10) || 1;
        quantityInput.value = Math.min(current, max);
      }
      if (quantityWrapper) {
        quantityWrapper.setAttribute('data-count', max);
        document.querySelector('.c_badge_icon span').innerHTML = max;
      }
    }

    // Watch for changes to the quantity wrapper
    const observer = new MutationObserver(() => {
      attachInputListener();
      updateQuantityFromSelect();
    });

    observer.observe(quantityWrapper, {
      childList: true,
      subtree: true,
    });

    // Also watch for select changes
    const selectObserver = new MutationObserver(() => {
      updateQuantityFromSelect();
    });

    selectObserver.observe(select, {
      attributes: true,
      childList: true,
      subtree: true,
    });

    let lastQuantity = null;
    let growlShown = false;

    setInterval(() => {
      const quantityInput = document.getElementById('Quantity');
      if (!quantityInput) return;

      const current = parseInt(quantityInput.value, 10) || 1;
      const max = getMaxCount();

      // Only act if quantity changed
      if (current !== lastQuantity) {
        lastQuantity = current;

        if (current > max) {
          quantityInput.value = max;

          if (!growlShown) {
            const growl = document.querySelector('.c_growl_default');
            if (growl) {
              growl.classList.remove('hide');
              growlShown = true;
              setTimeout(() => {
                growl.classList.add('hide');
                growlShown = false;
              }, 1000);
            }
          }
        }
      }
    }, 100);

    // Fallback polling
    setInterval(() => {
      attachInputListener();
      updateQuantityFromSelect();
    }, 500);
  });

  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.growl-close').forEach(function (closeBtn) {
      closeBtn.addEventListener('click', function () {
        const growlBox = this.closest('.growl');
        if (growlBox) {
          growlBox.classList.add('hide');
        }
      });
    });
  });
</script>

