                  {% if cd_date != blank or cd_set %}
                    <script>
                      document.addEventListener("DOMContentLoaded", function () {
                        initCountdown();

                        document.addEventListener("shopify:section:load", function () {
                          initCountdown();
                        });

                        function initCountdown() {
                          const ms_sec = 1000,
                                ms_min = ms_sec * 60,
                                ms_hr  = ms_min * 60,
                                ms_day = ms_hr * 24;

                          const timerElement = document.querySelector(".kik_banner_timer.{{ block.id }}");
                          if (!timerElement) return;

                          const isEnabledSetTo = timerElement.getAttribute("data-enable-set-to") === "true";
                          const hoursToSet     = parseInt(timerElement.getAttribute("data-set-hours")) || 24;
                          // Shared key when following the global Sale Countdown -> stays in sync with the
                          // top bar & Count Down section. Custom mode keeps its own ("countdown_start_time").
                          const STORAGE_KEY    = timerElement.getAttribute("data-storage-key") || "countdown_start_time";

                          let countDown_1;
                          if (isEnabledSetTo) {
                            const storedTime = localStorage.getItem(STORAGE_KEY);
                            let startTime;
                            if (storedTime) {
                              startTime = parseInt(storedTime);
                            } else {
                              startTime = new Date().getTime();
                              localStorage.setItem(STORAGE_KEY, startTime);
                            }
                            countDown_1 = startTime + (hoursToSet * ms_hr);
                          } else {
                            const rawDate = timerElement.getAttribute("data-time") || "2025-12-31T00:00:00Z";
                            countDown_1 = new Date(rawDate).getTime();
                          }

                          if (window.countdownInterval_{{ block.id | replace: '-', '_' }}) {
                            clearInterval(window.countdownInterval_{{ block.id | replace: '-', '_' }});
                          }

                          function updateCountdown() {
                            const now_1 = new Date().getTime();
                            let distance_1 = countDown_1 - now_1;

                            if (distance_1 < 1) {
                              {% if cd_action == "resets_itself" %}
                                const nowReset = new Date().getTime();
                                localStorage.setItem(STORAGE_KEY, nowReset);
                                countDown_1 = nowReset + (hoursToSet * ms_hr);
                                distance_1 = countDown_1 - nowReset;
                              {% else %}
                                timerElement.style.display = "none";
                                document.querySelector(".c_promo_code")?.classList.add("hide");
                                clearInterval(window.countdownInterval_{{ block.id | replace: '-', '_' }});
                                return;
                              {% endif %}
                            } else {
                              document.querySelector(".c_promo_code")?.classList.remove("hide");
                            }

                            timerElement.querySelectorAll(".days").forEach(item => {
                              item.innerText = Math.floor(distance_1 / ms_day);
                            });
                            timerElement.querySelectorAll(".hours").forEach(item => {
                              item.innerText = Math.floor((distance_1 % ms_day) / ms_hr);
                            });
                            timerElement.querySelectorAll(".minutes").forEach(item => {
                              item.innerText = Math.floor((distance_1 % ms_hr) / ms_min);
                            });
                            timerElement.querySelectorAll(".seconds").forEach(item => {
                              item.innerText = Math.floor((distance_1 % ms_min) / ms_sec);
                            });
                          }

                          window.countdownInterval_{{ block.id | replace: '-', '_' }} = setInterval(updateCountdown, 1000);
                          updateCountdown();
                        }
                      });
