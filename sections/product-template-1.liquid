<script>
  try {
    const items = JSON.parse(localStorage.getItem('recentlyviewed') || '[]');
    if (!items.includes({{ product.id }})) {
      items.unshift({{ product.id }});
    }
    localStorage.setItem('recentlyviewed', JSON.stringify(items.slice(0, 20)));
  } catch (e) {
    // have error
  }
</script>
{% assign item_index = 0 %}
