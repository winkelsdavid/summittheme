<script>
  function bundle_open() {
    const tabToggle = document.querySelector('.tabcustom');
    const bundleSection = document.querySelector('.bundle_products');
    tabToggle.classList.toggle('collapsed');
    bundleSection.classList.toggle('collapse');
  }
  function initCustomPriceUpdater() {
    const colorRadios = document.querySelectorAll('.single-option-radio input[type="radio"]');
    const customPriceElements = document.querySelector('.product_custom_prices .custom_price');
    const customComparePriceElements = document.querySelector('.product_custom_prices .compare_price');

    if (!customPriceElements || !colorRadios.length) return;

    function updateCustomPrices() {
      const currentPrice = document
        .querySelector('.product-single__price-container .product-single__price')
        ?.textContent.trim();
      customPriceElements.textContent = currentPrice || '';

      const comparePriceEl = document.querySelector(
        '.product-single__price-container .product-single__price.product-single__price--compare'
      );
      if (comparePriceEl) {
        const comparePrice = comparePriceEl.textContent.trim();
        customComparePriceElements.textContent = `(${comparePrice})`;
      } else {
        customComparePriceElements.textContent = '';
      }
    }

    colorRadios.forEach((radio) => {
      radio.addEventListener('change', function () {
        if (this.checked) {
          setTimeout(updateCustomPrices, 50);
        }
      });
    });

  //  updateCustomPrices();
  }

  document.addEventListener('DOMContentLoaded', initCustomPriceUpdater);
  document.addEventListener('shopify:section:load', initCustomPriceUpdater);

function attachBundleScript() {
  const form = document.querySelector('.product-form');
  if (!form) return;

  const submitButton = form.querySelector('.product-form__cart-submit');
  if (!submitButton) return;

  submitButton.addEventListener('click', function (e) {
    const mainProductId = form.querySelector("select[name='id']").value;
    const quantity = form.querySelector("input[name='quantity']").value;
    const bundleContainer = document.querySelector('.bundle_products');
    const bundleCheckboxes = bundleContainer
      ? bundleContainer.querySelectorAll("input[type='checkbox']:checked")
      : [];

    const enableDirectCheckout = submitButton.classList.contains('enable_direct_checkout');
      if (bundleCheckboxes.length === 0 && enableDirectCheckout == false) {
      return;
    }
    e.preventDefault(); // Always intercept

    const items = [{ id: mainProductId, quantity: parseInt(quantity) }];

    bundleCheckboxes.forEach((checkbox) => {
      items.push({ id: checkbox.value, quantity: 1 });
    });

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items }),
    })
