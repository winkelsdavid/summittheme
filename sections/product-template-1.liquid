                    Preis-ul, aber INNERHALB des Price-Box-Wrappers: eigene Zeile, die
                    Badges bleiben nowrap nebeneinander (Desktop/Tablet/Mobile). {%- endcomment -%}
                {%- if block.settings.show_tax_disclaimer -%}
                  <div class="product-single__tax-disclaimer tax-disclaimer-{{ section.id }}">{{ 'products.product.tax_disclaimer' | t }}</div>
                {%- endif -%}
                </div>
              {%- when 'salepoint' -%}
