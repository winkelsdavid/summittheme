<script>
document.addEventListener("DOMContentLoaded", function() {
    
    const initReviewsMarquee = () => {
        const scrollContainers = document.querySelectorAll('.reviews_marquee_item');
        
        scrollContainers.forEach((col, index) => {
            // Check if this specific container has already been processed
            if (col.dataset.marqueeInitialized === 'true') return;

            // 1. Duplicate the inner HTML for the infinite loop
            col.innerHTML = col.innerHTML + col.innerHTML;

            // 2. Apply animation classes based on index
            const items = col.querySelectorAll(".reviews_marquee_c");
            
            items.forEach((item) => {
                if (index % 2 === 0) {
                    item.classList.add('animate-down');
                } else {
                    item.classList.add('animate-up');
                }
            });

            // Mark as initialized so we don't double-up on the next editor refresh
            col.dataset.marqueeInitialized = 'true';
        });
    };

    // Run on initial page load
    initReviewsMarquee();

    // Run when Shopify Customizer updates a section
    document.addEventListener('shopify:section:load', initReviewsMarquee);
    document.addEventListener('shopify:section:select', initReviewsMarquee);
});
</script>
