                <div class="reviews_info_h_t">
                    {% if section.settings.title != blank %}
                        <h2 {% if section.settings.title_color != "rgba(0,0,0,0)" and section.settings.title_color != blank %}style="--g-color-heading:{{ section.settings.title_color }}"{% else %}style="--g-color-heading:{{ settings.color_body_headings }}"{% endif %}>{{  section.settings.title }}</h2>
                    {% endif %}
                    {% if section.settings.content != blank %}
                        <div class="rte" {% if section.settings.content_color != "rgba(0,0,0,0)" %}style="--color:{{ section.settings.content_color }}"{% endif %}>{{ section.settings.content }}</div>
                    {% endif %}
