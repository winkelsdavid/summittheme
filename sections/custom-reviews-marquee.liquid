<style>
.c-{{ section.id }}{
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  background:{{  section.settings.background }};
}
@media screen and (max-width: 991px) {
  .c-{{ section.id }}{
      padding-top: {{ section.settings.mobile_padding_top }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
  }
}
.custom_reviews_marquee{
    display: flex;
    grid-column-gap: 80px;
    grid-row-gap: 80px;
    place-items: center start;
    overflow: hidden;
}
.c-{{ section.id }} .custom_reviews_marquee{ 
    height:{{  section.settings.section_height_desktop }}px;
    position:relative;
}
.reviews_count {
    grid-column-gap: 10px;
    grid-row-gap: 10px;
    justify-content: flex-start;
    align-items: center;
    display: flex;
    flex-wrap: wrap;
}
.reviews_marquee_item {
display:flex;
flex-direction:column;
gap:20px;
height:100%;
position:relative;
width:100%;
}
.reviews_count img:first-child{
width:107px;
border-radius:0!important;
}
.reviews_count p{
margin:0
}
.reviews_count img:last-child{
width:72px;
border-radius:0!important;
}
.review_marquee_info .h2 {
    margin-top: 15px;
    margin-bottom: 16px;
}
.review_marquee_info .rte{
margin:0;
}
.review_marquee_info .rte *{
color:var(--color);
}
.reviews_marquee_review {
    grid-column-gap: 20px;
    grid-row-gap: 20px;
    grid-template-rows: auto;
    grid-template-columns: 1fr 1fr;
    grid-auto-columns: 1fr;
    justify-content: center;
    align-items: center;
  /*  display: grid;*/
    display: flex;
    height: 100%;
}
@media (min-width:768px){
/*.reviews_marquee_review {
  flex:0 0 65%;
}*/
.review_marquee_info{
min-width:340px;
}
}
.reviews_marquee_c {
    grid-column-gap: 20px;
    grid-row-gap: 20px;
    flex-flow: column;
    display: flex;
}
.review_marquee_item {
    background-color: #fff;
    border-radius: 0;
    padding: 15px 30px;
    border-radius: 10px;
    border: 1px solid #ffffff;
    box-shadow: rgb(0 0 0 / 6%) 0px 2px 25px 0px;
}
.c-{{ section.id }} .review_marquee_item {
    background: {{  section.settings.quote_box_color }};
}
.badges_verified {
    width: 20px;
    border-radius:0!important;
}
.review_marquee_item h3 {
    margin: 0;
    font-size: 25px;
}
.review_marquee_item .date {
    grid-column-gap: 15px;
    grid-row-gap: 15px;
    justify-content: flex-start;
    align-items: center;
    margin-bottom: 20px;
    display: flex;
}
.review_marquee_item .date img{
width:107px;
border-radius:0!important;
}
.review_marquee_item .rte{
margin:7px 0;
}
.review_marquee_item .rte *{
  color:var(--color);
}
.review_marquee_item .name{
margin:0!important;
font-weight:700;
}
{%  if section.settings.enable_overlay_edges %}
.c-{{ section.id }} .opacity_item_reviews{
    position: absolute;
    height: 50px;
    width: 100%;
    z-index: 2;
    left:0;
}
{%  else %}
.c-{{ section.id }} .opacity_item_reviews{
   display:none!important;
}
{% endif %}
{% if  section.settings.overlay_color != blank and section.settings.overlay_color != "rgba(0,0,0,0)"%}
  {%  assign overlay_color = section.settings.overlay_color %}
{% else %}
 {%  assign overlay_color = settings.color_body_bg %}
{% endif %}
.c-{{ section.id }} .opacity_item_reviews.opacity_top{
    top: -1px;
    background: linear-gradient(180deg, {{ overlay_color }}, transparent);
}
.c-{{ section.id }} .opacity_item_reviews.opacity_bottom{
    bottom: -1px;
    background: linear-gradient(0deg, {{ overlay_color }}, transparent);
}
{% if section.settings.animated %}
  {%- assign speed_multiplier = 51 | minus : section.settings.animation_speed -%}
.c-{{ section.id }} .animate-down {
    animation: marquee-down {{  speed_multiplier }}s linear infinite;
}
.c-{{ section.id }}  .animate-up {
    animation: marquee-up {{  speed_multiplier }}s linear infinite;
}
{% endif %}
@keyframes marquee-down {
    0% { transform: translateY(-50%); }
    100% { transform: translateY(0%); }
}

@keyframes marquee-up {
    0% { transform: translateY(0%); }
    100% { transform: translateY(-50%); }
}
@keyframes marquee-left {
    0% { transform: translateX(-67%); }
    100% { transform: translateX(0%); }
}

@keyframes marquee-right {
    0% { transform: translateX(0%); }
    100% { transform: translateX(-67%); }
}
.c-{{ section.id }} .reviews_count > svg:first-child{
width:88px;
}
.trustpilot_container{
display:flex;
}
.c-{{ section.id }} .trustpilot_container svg:last-child{
height:18px;
}
.c-{{ section.id }} .trustpilot_container .truspilot_icon{
transform: translateY(-2px);
}
.truspilot_icon{
  width:72px; 
}
.amazon_icon{
width:72px;
}
.ebay_icon{
width:52px;
}
.etsy_icon{
width:42px;
}
.google_icon{
width:62px;
}
.verified_flex{
display:flex;
gap:8px;
align-items:center;
}
.opacity_bottom.mobile_only{
display:none;
}
@media (max-width:999px){
  .c-{{ section.id }} .custom_reviews_marquee{ 
    height:auto;
}
.c-{{ section.id }} .container{
padding:0;
}
.review_marquee_info{
padding:0px 20px;
}
.custom_reviews_marquee {
    flex-wrap:wrap;
    grid-row-gap: 40px;
}
.opacity_bottom.mobile_only{
display:block;
bottom:-1px;
}
.reviews_marquee_review {
    overflow: hidden;
}
{% if section.settings.animated %}
  {%- assign speed_multiplier = 51 | minus : section.settings.animation_speed_mobile -%}
.c-{{ section.id }} .animate-down {
    animation: marquee-down {{  speed_multiplier }}s linear infinite;
}
.c-{{ section.id }}  .animate-up {
    animation: marquee-up {{  speed_multiplier }}s linear infinite;
}
{% endif %}
}
@media (max-width:549px){
.reviews_marquee_review {
    display: flex;
    flex-wrap:wrap;
}
.reviews_marquee_item{
  flex-direction:row;
}
.reviews_marquee_c {
    flex-flow: row;
}
.review_marquee_item{
flex:0 0 320px;
}
.reviews_marquee_item .reviews_marquee_c:nth-child(5){
display:none;
}
.c-{{ section.id }} .opacity_item_reviews{
    height: 100%;
    width: 50px;
    left: -1px;
    top:0;
}
.c-{{ section.id }} .opacity_item_reviews.opacity_top{
    top: 0px;
    background: linear-gradient(90deg, {{ overlay_color }}, transparent);
}
.c-{{ section.id }} .opacity_item_reviews.opacity_bottom{
    bottom: 0px;
    right:0;
    left:unset;
    background: linear-gradient(-90deg, {{ overlay_color }}, transparent);
}
{% if section.settings.animated %}
{%- assign speed_multiplier = 51 | minus : section.settings.animation_speed_mobile -%}
.c-{{ section.id }} .animate-down {
    animation: marquee-left {{  speed_multiplier }}s linear infinite;
}
.c-{{ section.id }}  .animate-up {
    animation: marquee-right {{  speed_multiplier }}s linear infinite;
}
{% endif %}
}
}
</style>
