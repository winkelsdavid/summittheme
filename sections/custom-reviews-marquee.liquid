            </div>
            <div class="reviews_marquee_review">
                <div class="reviews_marquee_item reviews_marquee_left">
                  <div class="opacity_item_reviews opacity_top"></div>
                    <div class="reviews_marquee_c">
                        {% for block in section.blocks %}
                            {% if block.type == "review_left" %}
                                <div class="review_marquee_item">
                                    {% if section.settings.show_quotes %}
                                    <svg xmlns="http://www.w3.org/2000/svg" id="Laag_1" version="1.1" viewBox="0 0 24 24">
                                      <path d="M9,3C4.1,3,0,7.1,0,12v9h9v-9H3c0-3.3,2.7-6,6-6v-3ZM20.4,3c-4.9,0-9,4.1-9,9v9h9v-9h-6c0-3.3,2.7-6,6-6v-3Z"/>
                                    </svg>
                                    {% endif %}
                                   {% if block.settings.title != blank %}
                                        <h5 {% if section.settings.quote_title_color != "rgba(0,0,0,0)" %}style="--g-color-heading:{{ section.settings.quote_title_color }}"{% else %}style="--g-color-heading:{{ settings.color_body_headings }}"{% endif %}>{{  block.settings.title }}</h5>
                                    {% endif %}
                                    {% if block.settings.date != blank %}
                                        <div class="date" {% if section.settings.quote_date_color != "rgba(0,0,0,0)" %} style="color:{{ section.settings.quote_date_color }}"{% endif %}>
                                            <span>{{  block.settings.date }}</span>
                                        </div>
                                    {% endif %}
                                    {% if block.settings.content != blank %}
                                        <div class="rte" {% if section.settings.quote_content_color != "rgba(0,0,0,0)" %} style="--color:{{ section.settings.quote_content_color }}"{% endif %}>
                                            {{ block.settings.content }}
                                        </div>
                                    {% endif %}
                                    <div class="verified_flex">
                                      {% if block.settings.name != blank %}
                                          <p class="name mb-2" {% if section.settings.quote_name_color != "rgba(0,0,0,0)" %}style="color:{{ section.settings.quote_name_color }}"{% endif %}>{{  block.settings.name }}</p>
                                      {% endif %}
                                     {% if block.settings.add_verified %}
