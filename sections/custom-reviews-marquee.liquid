                      </svg>
                    {% endif %}
                    {% if section.settings.reviews_count_caption != blank %}
                        <p {% if section.settings.reviews_cout_color != "rgba(0,0,0,0)" %}style="color:{{ section.settings.reviews_cout_color }}"{% endif %}>{{ section.settings.reviews_count_caption }}</p>
