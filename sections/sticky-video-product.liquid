{%- comment -%}
  Sticky Video Product Widget
  - Shows a small sticky video (bottom-left, desktop only)
  - Fades in after a configurable delay
  - Links to a chosen product
  - Includes a close (X) button
{%- endcomment -%}

{%- liquid
  assign sticky_video = section.settings.video
  assign sticky_product = section.settings.product
  assign delay_seconds = section.settings.delay | default: 5
  assign show_widget = true
  if section.settings.only_homepage and request.page_type != 'index'
    assign show_widget = false
  endif
-%}

{%- if sticky_video != blank and show_widget -%}
  <div
    class="sticky-video-widget"
    id="StickyVideo-{{ section.id }}"
    data-delay="{{ delay_seconds }}"
    style="--sticky-video-aspect-ratio: 15/23;"
  >
    <button
      type="button"
      class="sticky-video-widget__close"
      aria-label="Close"
      id="StickyVideoClose-{{ section.id }}"
    >
      &times;
    </button>
    {% if section.settings.action == "atc" %}
        <span  class="js-grid-cart" 
            data-id="{{ sticky_product.selected_or_first_available_variant.id }}">
        {% elsif section.settings.action == "gtp" %}
          <span data-tooltip="true" data-placement="left" class="js-btn-quickview" title="" data-toggle="modal" data-target="#jsQuickview" data-handle="{{ sticky_product.handle }}" data-pavailable="true" data-original-title="Quickshop">
        {% else %}
        <a href="{{ sticky_product.url }}">  
        {% endif %}
      <div class="sticky-video-widget__media">
        {{
          sticky_video
          | video_tag:
            autoplay: true,
            loop: true,
            muted: true,
            controls: false,
            class: 'sticky-video-widget__video'
        }}
      </div>
      {% if section.settings.action == "atc" or section.settings.action == "gtp" %}
      </span>
    {% else %}
      </a>
    {%  endif %}
  </div>

  <style>
    .sticky-video-widget {
      position: fixed;
      bottom: 90px;
      right:30px;
      width: {{  section.settings.video_width }}px;
      z-index: 99;
      background: #ffffff;
      {% if settings.enable_radius_allimg %}border-radius: calc(0.2rem * {{ settings.radius_allimg_range }});{% endif %}
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
      overflow: hidden;
      opacity: 0;
      transform: translateY(12px);
      transition: opacity 0.6s ease, transform 0.6s ease;
      pointer-events: none;
    }
    body:has(.wsp-whatsapp) .sticky-video-widget {
      bottom:160px;
    }
    /* Desktop only */
    @media screen and (max-width: 749px) {
      .sticky-video-widget {
        display: none;
      }
    }

    .sticky-video-widget.is-visible {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }

    .sticky-video-widget.is-hidden {
      opacity: 0;
      transform: translateY(12px);
      pointer-events: none;
    }

    .sticky-video-widget__link {
      display: block;
      color: inherit;
      text-decoration: none;
    }

    .sticky-video-widget__media {
      position: relative;
      width: 100%;
      height: 0;
      padding-bottom: calc(100% / (0 + var(--sticky-video-aspect-ratio, 16 / 9)));
      background: #000;
    }

    .sticky-video-widget__video {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .sticky-video-widget__label {
      position: absolute;
      left: 8px;
      bottom: 8px;
      margin: 0;
      max-width: calc(100% - 40px);
      font-size: 11px;
      line-height: 1.3;
      color: #ffffff;
      text-shadow: 0 1px 3px rgba(0, 0, 0, 0.6);
      z-index: 2;
    }

    .sticky-video-widget__close {
      position: absolute;
      top: 6px;
      right: 6px;
      width: 22px;
      height: 22px;
      border: none;
      border-radius: 50%;
      background: rgba(0, 0, 0, 0.55);
      color: #ffffff;
      font-size: 16px;
      line-height: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      z-index: 3;
      padding: 0;
    }

    .sticky-video-widget__close:hover {
      background: rgba(0, 0, 0, 0.8);
    }

    .sticky-video-widget__product {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 8px;
      background: #ffffff;
    }

    .sticky-video-widget__product-image {
      width: 36px;
      height: 36px;
      object-fit: cover;
      border-radius: 6px;
      flex-shrink: 0;
    }

    .sticky-video-widget__product-info {
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .sticky-video-widget__product-title {
      font-size: 12px;
      font-weight: 600;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .sticky-video-widget__product-price {
      font-size: 12px;
      color: #555;
    }
  </style>

  <script>
    (function () {
      var root = document.getElementById('StickyVideo-{{ section.id }}');
      if (!root) return;

      var closeBtn = document.getElementById('StickyVideoClose-{{ section.id }}');
      var storageKey = 'sticky-video-dismissed-{{ section.id }}';
      var delay = parseFloat(root.getAttribute('data-delay')) || 0;

      // Don't show again this session if previously closed
      if (sessionStorage.getItem(storageKey) === 'true') {
      //  return;
      }

      // Only run on desktop widths
      function isDesktop() {
        return window.matchMedia('(min-width: 750px)').matches;
      }

      if (isDesktop()) {
        setTimeout(function () {
          if (isDesktop()) {
            root.classList.add('is-visible');
          }
        }, delay * 1000);
      }

      if (closeBtn) {
        closeBtn.addEventListener('click', function (e) {
          e.preventDefault();
          e.stopPropagation();
          root.classList.remove('is-visible');
          root.classList.add('is-hidden');
          sessionStorage.setItem(storageKey, 'true');
        });
      }
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Sticky Video Product",
  "settings": [
    {
      "type": "checkbox",
      "id": "only_homepage",
      "label": "Only Show On Homepage"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video"
    },
     {
      "type": "range",
      "id": "video_width",
      "label": "Video Width",
      "min": 80,
      "max": 180,
      "step": 1,
      "default": 150
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "range",
      "id": "delay",
      "label": "Delay Before Showing (Seconds)",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "s",
      "default": 5
    },
    {
      "type": "select",
      "id": "action",
      "label": "Action On Click",
      "default":"atc",
      "options": [
        {
        "label": "Add To Cart",
        "value":"atc"
        },
         {
        "label": "Quick Buy",
        "value":"gtp"
        },
        {
        "label": "Go To Product",
        "value":"qb"
        }
      ]
    }
  ]
}
{% endschema %}
