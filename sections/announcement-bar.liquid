{%- if section.settings.enable -%}
{%-liquid
    assign text_topbar = section.settings.text_topbar
    assign enable_login_topbar = section.settings.enable_login_topbar
    assign enable_money_topbar = section.settings.enable_money_topbar
    assign enable_language_topbar = section.settings.enable_language_topbar
    assign enable_social_topbar = section.settings.enable_social_topbar
    assign buttonall_topbar = section.settings.buttonall_topbar
    assign buttonall_link_topbar = section.settings.buttonall_link_topbar
    assign enable_name = section.settings.enable_name
    assign enable_image = section.settings.enable_image
    assign gradient_bg = section.settings.gradient_bg
    assign background = section.settings.background
    assign text_color = section.settings.text_color
    assign font_size_topbar = section.settings.font_size_topbar

    assign enable_countdown = section.settings.enable_countdown
    assign text_countdown = section.settings.text_countdown

    assign topbar_phone = section.settings.topbar_phone
    assign topbar_email = section.settings.topbar_email
    assign topbar_store = section.settings.topbar_store
    assign topbar_store_link = section.settings.topbar_store_link
    assign topbar_appointment = section.settings.topbar_appointment
    assign topbar_page_appointment = section.settings.topbar_page_appointment
    assign enable_block_link = section.settings.enable_block_link

-%}
<style>
    .announcement-bar{
    padding: 0.6rem 0;
    background:{% if gradient_bg == blank and background == 'rgba(0,0,0,0)' %}{{  settings.branding_color }} {% else %}{%- if gradient_bg != blank -%} {{ gradient_bg }} {%- else -%} {{ background }} {%- endif -%}{% endif %};
    }
    #announcement-topbar{
        {% if text_color != 'transparent' and text_color != 'rgba(0,0,0,0)' %}
        --color-body-text : {{ text_color }};
        --color-body-text-rgb: {{ text_color.red }}, {{ text_color.green }},  {{ text_color.blue }} ;
      {% endif %}
      --g-font-size : {{ font_size_topbar }}px;
      color:var(--color-body-text);
      font-size:var(--g-font-size);
    }
    #announcement-topbar .list-inline-item:not(:last-child){
        margin-right: 1.5rem;
    }
    #announcement-topbar .social-icons li a{
        color:var(--color-body-text);
    }
    #announcement-topbar .site-header__link{
        color:var(--color-body-text);
    }
    #announcement-topbar #HeaderCountryForm .localization-form__select,  
    #announcement-topbar #HeaderLanguageForm .localization-form__select{
        color:var(--color-body-text);
        font-size: var(--g-font-size);
        font-weight: var(--g-font-weight-body);
        text-transform:inherit;
        letter-spacing:0;
    }
    #announcement-topbar .col-right .topbar-block{
        padding-right: 2.5rem;
    }
    #announcement-topbar .col-right .topbar-block:last-child{
        padding-right: 0rem;
    }
    #announcement-topbar .disclosure__list-wrapper{
        z-index: 9999;
        --color-body-text-rgb: {{ settings.color_body_text.red }}, {{ settings.color_body_text.green }}, {{ settings.color_body_text.blue }};
    }
    #announcement-topbar .link {
    color: rgba(var(--color-body-text-rgb),1);
    text-decoration-color: rgba(var(--color-body-text-rgb),1);
    }
    .announcement-bar .countdown-timer{
    line-height:1;
  }
  .announcement-bar .countdown-timer ul{
    display:flex;
    column-gap:16px;
  }
  .announcement-bar .countdown-timer li{
    text-align:center;
    position:relative;
    padding:0;
  }
  .announcement-bar .countdown-timer li:not(:last-child):before{
  content:":";
  position:absolute;
  top:0;
  right:-8px;
  }
    .announcement-bar .countdown-timer .countdown-time{
      display:block;
      text-align:center;
      font-weight:500;
      font-size: var(--g-font-size);
      min-width: fit-content;
    }
    .announcement-bar .countdown-text{
    font-size: 65% !important;
    text-transform: none !important;
    letter-spacing: 0 !important;
    }
    .promo_announcement{
    display:flex;
    }
    .promo_announcement .kik_banner_timer_an{
    display:flex;
    }
    .promo_announcement  #countdown{
    width:fit-content;
    display:flex;
    }
    .promo_announcement  #countdown ul{
    display: flex;
    align-items: flex-start;
    padding: 0;
    gap: 8px;
    margin: 0;
    margin-top: px;
    }
    .promo_announcement  #countdown ul li{
    display: flex;
    flex-direction:column;
    align-items: center;
    justify-content:center;
    line-height: 1;
    color:{{ block.settings.color }};
    flex-wrap:wrap;
    }
    .promo_announcement #countdown ul li span:first-child{
    font-size:13px;
    }
     .promo_announcement #countdown ul li span:last-child{
    font-size:8px;
    margin-top: 2px;
    }
</style>


<announcement-bar >
  <div class="announcement-bar" data-aos="{{ section.settings.animation }}">
    <div class="{{ section.settings.section_width }}">
        <div id="announcement-topbar">
            <div class="row align-items-center">
                
                <div class="col-4 d-none d-lg-flex gap-4">
                  {%- if enable_social_topbar -%}
                    <div class="topbar-block">
                    {%- render 'block-social' -%}
                    </div>
                  {%- endif -%}
                  {%- if enable_block_link -%}
                    {% if topbar_phone != blank %}
                      <div class="d-flex">
                        <a href="tel:{{ topbar_phone | strip }}"class="d-inline-flex align-items-center">
                          {% render 'icon-mobile-phone' %}
                          <span class="pl-2">{{ topbar_phone }}</span>
                        </a>
                      </div>
                    {% endif %}
                    {% if topbar_email != blank %}
                      <div class="d-flex">
                        <a href="mailto:{{ topbar_email }}"  class="d-inline-flex align-items-center">
                          {% render 'icon-email' %}
                          <span class="pl-2">{{ topbar_email }}</span>
                        </a>
                      </div>
                    {% endif %}
                    {% if topbar_store != blank %}
                      <div class="d-flex">
                        <a href="{{ topbar_store_link | default:"/pages/store" }}" class="d-inline-flex align-items-center">
                          {% render 'icon-location' %}
                          <span class="pl-2">{{ topbar_store }}</span>
                        </a>
                      </div>
                    {% endif %}
                    {% if topbar_appointment != blank %}
                      <div class="d-flex">
                        <a href="{{ topbar_page_appointment | default:"/pages/appointment" }}" class="d-inline-flex align-items-center">
                          {% render 'icon-calendar' %}
                          <span class="pl-2">{{ topbar_appointment }}</span>
                        </a>
                      </div>
                    {% endif %}
                  {%- endif -%}
                  
                  
                </div>
                
                {%- if text_topbar != blank -%}
                <div class="col-lg-4 col-left col-12">
                <div class="text-center w-100 d-flex gap-2 justify-content-center text-body">
                    {{ text_topbar }}
                    {%- if buttonall_topbar != blank -%}
                    <a href="{{ buttonall_link_topbar }}" class="link">
                    {{ buttonall_topbar }}
                    </a>
                {%- endif -%}
                </div>
                </div>
                {%- endif -%}
                <div class="col-4 col-right text-right d-none d-lg-flex justify-content-end">
                  {%- if enable_countdown -%}
                  <div class="topbar-block d-flex">
                  {% if text_countdown != blank %}
                      <span class="mr-3" id="text_countdown"> {{ text_countdown }}</span>
                    {% endif %}
                    {%  comment %}
                    <countdown-timer class="countdown-timer countdown-item" data-time="{{ section.settings.data_countdown }}"></countdown-timer> 
                    {% endcomment %}
                    <div class="promo_announcement">
                        {% if section.settings.data_countdown != blank %}
                          <div
                            class="kik_banner_timer_an {{ section.id }}"
                            data-time="{{ section.settings.data_countdown }}"
                            data-enable-set-to="{{ section.settings.enable_set_to }}"
                            data-set-hours="{{ section.settings.set_to | default: '24' }}"
                          >
                            <div id="countdown">
                              <ul>
                                <li><span class="days"></span><span>{{ 'general.months.days' | t }}</span></li>
                                <li class="timer-dot">:</li>
                                <li><span class="hours"></span><span>{{ 'general.months.hours' | t }}</span></li>
                                <li class="timer-dot">:</li>
                                <li><span class="minutes"></span><span>{{ 'general.months.minutes' | t }}</span></li>
                                <li class="timer-dot">:</li>
                                <li><span class="seconds"></span><span>{{ 'general.months.seconds' | t }}</span></li>
                              </ul>
                            </div>
                          </div>
                        {% endif %}
                      </div>
                  </div>
                {%- endif -%}
                {%- if enable_money_topbar and localization.available_countries.size > 1 -%}
                    <div class="d-none d-sm-flex topbar-block text-left align-items-center">
                    {% render 'localization', id: 'HeaderCountryForm', margin: 'topbar' , enable_image: enable_image, enable_name : enable_name %}
                    </div>
                {%- endif -%}
                {%- if enable_language_topbar and localization.available_languages.size > 1 -%}
                    <div class="d-none d-sm-flex topbar-block text-left align-items-center">
                    {% render 'localization-language', id: 'HeaderLanguageForm', margin: 'topbar' , enable_name: enable_name %}
                </div>
                {%- endif -%}
                
                </div>
            </div>
        </div>
    </div>
  </div>
</announcement-bar>
{% if section.settings.data_countdown != blank %}
<script>
  document.addEventListener("DOMContentLoaded", function () {
    kik_lp_init_timer();

    document.addEventListener("shopify:section:load", function () {
      kik_lp_init_timer();
    });

    function kik_lp_init_timer() {
      const ms_sec = 1000,
            ms_min = ms_sec * 60,
            ms_hr = ms_min * 60,
            ms_day = ms_hr * 24;

      // Unique storage key per section to avoid conflicts
      const STORAGE_KEY_UNIQUE = "kik_timer_start_{{ section.id }}";
      const timerWrapper = document.querySelector(".kik_banner_timer_an.{{ section.id }}");
      
      if (!timerWrapper) return;

      const isEnabledSetTo = timerWrapper.getAttribute("data-enable-set-to") === "true";
      const hoursToSet = parseInt(timerWrapper.getAttribute("data-set-hours")) || 24;
      
      let targetTimestamp;

      if (isEnabledSetTo) {
        const localStartTime = localStorage.getItem(STORAGE_KEY_UNIQUE);
        let startTime;

        if (localStartTime) {
          startTime = parseInt(localStartTime);
        } else {
          startTime = new Date().getTime();
          localStorage.setItem(STORAGE_KEY_UNIQUE, startTime);
        }
        // Calculate end time: Start time + (User selected hours * ms in an hour)
        targetTimestamp = startTime + (hoursToSet * ms_hr);
      } else {
        const rawDate = timerWrapper.getAttribute("data-time");
        targetTimestamp = new Date(rawDate).getTime();
      }

      // Clear any existing interval for this specific section
      if (window.kik_lp_interval_{{ section.id | replace: '-', '_' }}) {
        clearInterval(window.kik_lp_interval_{{ section.id | replace: '-', '_' }});
      }

      function updateDisplay() {
        const currentTime = new Date().getTime();
        let gap = targetTimestamp - currentTime;

        if (gap < 0) {
          {% if section.settings.action_timer == "resets_itself" %}
            const newNow = new Date().getTime();
            localStorage.setItem(STORAGE_KEY_UNIQUE, newNow);
            targetTimestamp = newNow + (hoursToSet * ms_hr);
            gap = targetTimestamp - newNow;
          {% else %}
            const text_countdown = document.querySelector("#text_countdown")
            // If set to invisible or no reset action
            timerWrapper.style.display = "none";
            if(text_countdown){
              text_countdown.style.display = "none";
            }
            
            clearInterval(window.kik_lp_interval_{{ section.id | replace: '-', '_' }});
            return;
          {% endif %}
        }

        const d = Math.floor(gap / ms_day);
        const h = Math.floor((gap % ms_day) / ms_hr);
        const m = Math.floor((gap % ms_hr) / ms_min);
        const s = Math.floor((gap % ms_min) / ms_sec);

        timerWrapper.querySelectorAll(".days").forEach(el => el.innerText = d);
        timerWrapper.querySelectorAll(".hours").forEach(el => el.innerText = h);
        timerWrapper.querySelectorAll(".minutes").forEach(el => el.innerText = m);
        timerWrapper.querySelectorAll(".seconds").forEach(el => el.innerText = s);
      }

      // Start the interval and store it globally with a unique name
      window.kik_lp_interval_{{ section.id | replace: '-', '_' }} = setInterval(updateDisplay, 1000);
      updateDisplay(); // Run once immediately
    }
  });
</script>
{% endif %}
<script>
    class AnnouncementBar extends HTMLElement {
      constructor() {
        super();
      }
      connectedCallback() {
        var rootElement = document.querySelector(':root');
        rootElement.style.setProperty("--height-announcementbar", this.offsetHeight + "px");
      }
    }
    customElements.define('announcement-bar', AnnouncementBar);
    
</script>
{%- endif -%}
