{{ 'beerslider.css' | asset_url | stylesheet_tag }}
<script src="{{ 'beerslider.js' | asset_url }}" defer="defer"></script>
{%- render 'style-section' -%}
<style>
    .customstyle{{ section.id }}{
    padding-top:{{ section.settings.padding_top }}px;
    padding-bottom:{{ section.settings.padding_bottom }}px;
  }
  @media (max-width:768px){
     .customstyle{{ section.id }}{
    padding-top:{{ section.settings.mobile_padding_top }}px;
    padding-bottom:{{ section.settings.mobile_padding_bottom }}px;
  }
  }
  {%- if section.settings.aspect != 'auto' and section.settings.aspect != blank -%}
  {%- comment -%} #69: Ratio erzwingen. Nach-Bild ist bereits absolute+cover
     (beerslider.css); das Vor-Bild MUSS bei width:200% bleiben - der
     Reveal-Clip (right:50%) zeigt sonst eine gequetschte linke Haelfte
     statt derselben Bildgeometrie wie die Nach-Ebene. {%- endcomment -%}
  .beforeafter-{{ section.id }} .beer-slider{
    aspect-ratio: {{ section.settings.aspect }};
    width: 100%;
  }
  {%- comment -%} beerslider.css biegt .beer-reveal auf position:relative -
     dann waechst die Box mit der natuerlichen Bildhoehe statt mit der Ratio
     (und height:100% der Bilder loest sich nicht auf). Im Ratio-Modus die
     Vendor-Geometrie wiederherstellen; die Breite setzt beerslider.js inline. {%- endcomment -%}
  .beforeafter-{{ section.id }} .beer-slider .beer-reveal{
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
  }
  .beforeafter-{{ section.id }} .beer-slider .beer-reveal > img{
    width: 200%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
  {%- endif -%}
</style>
<div class="customstyle{{ section.id }} before-after-section beforeafter-{{ section.id }}" 
data-aos="{{ section.settings.animation }}"
 data-section-id="{{ section.id }}" 
data-section-type="beforeafter">
    <div class="{{ section.settings.section_width }}">
        <div class="section-block">
            {%- render 'section-heading' -%}
            <div class="before-after-block">
                <div id="beer-slider-{{section.id}}" class="beer-slider" data-beer-label="{%- if section.settings.after_caption != blank -%}{{ section.settings.after_caption }} {%- endif -%}">
                    {%- if section.settings.image2 != blank -%}
                        {%- capture sizes -%}
                            (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px,
                            (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)
                        {%- endcapture -%}
                        {{
                            section.settings.image2
                            | image_url: width: 1500
                            | image_tag: loading: 'lazy', sizes: sizes, widths: '165, 360, 535, 750, 1070, 1500', class: 'lazyload scale-in'
                        }}
                        {%- else -%}
                        {%- capture b1_fb -%}{% render 'brand-image', handle: 'before-after', slot: 2, width: 1500, class: 'scale-in lazyloaded' %}{%- endcapture -%}
                        {%- if b1_fb != blank -%}{{ b1_fb }}{%- else -%}{{ 'image' | placeholder_svg_tag: 'placeholder-svg svg-1' }}{%- endif -%}
                    {%- endif -%}
                <div class="beer-reveal" data-beer-label="{%- if section.settings.before_caption != blank -%}{{ section.settings.before_caption }}{%- endif -%}">
                    {%- if section.settings.image != blank -%}
                    {%- capture sizes -%}
                        (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px,
                        (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)
                    {%- endcapture -%}
                    {{
                        section.settings.image
                        | image_url: width: 1500
                        | image_tag: loading: 'lazy', sizes: sizes, widths: '165, 360, 535, 750, 1070, 1500', class: 'lazyload scale-in'
                    }}
                    {%- else -%}
                    {%- capture b1_fb -%}{% render 'brand-image', handle: 'before-after', slot: 1, width: 1500, class: 'scale-in lazyloaded' %}{%- endcapture -%}
                    {%- if b1_fb != blank -%}{{ b1_fb }}{%- else -%}{{ 'image' | placeholder_svg_tag: 'placeholder-svg svg-2' }}{%- endif -%}
                    {%- endif -%}
                </div>
                </div>
            </div>
        </div>
    </div>
</div>

