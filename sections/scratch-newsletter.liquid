    { "type": "text", "id": "regular_button", "label": "Submit button" },
    { "type": "text", "id": "regular_success_kicker", "label": "Success kicker" },

    { "type": "header", "content": "Step 2 — Email" },
    { "type": "text", "id": "email_heading_top", "label": "Heading line 1" },
    { "type": "text", "id": "email_heading", "label": "Heading line 2" },
