      "default": "scratch"
    },
    { "type": "checkbox", "id": "test_mode", "label": "Test mode", "info": "Always show the popup and ignore cookies. Disable before publishing.", "default": false },
    { "type": "range", "id": "popup_delay", "label": "Popup delay", "min": 0, "max": 15, "step": 1, "unit": "s", "default": 3 },
    { "type": "range", "id": "cookie_days_closed", "label": "Show again after closing", "info": "Days before the popup is shown again after being dismissed.", "min": 1, "max": 90, "step": 1, "unit": "d", "default": 7 },
    { "type": "range", "id": "cookie_days_subscribed", "label": "Show again after signup", "info": "Days before the popup is shown again after a successful signup.", "min": 30, "max": 365, "step": 5, "unit": "d", "default": 180 },

    { "type": "header", "content": "Appearance" },
    {
      "type": "select", "id": "popup_size", "label": "Newsletter size",
      "options": [
        { "value": "box", "label": "Box" },
        { "value": "full", "label": "Full size" }
      ],
      "default": "box"
    },
    {
      "type": "select", "id": "scratch_style", "label": "Scratch style",
      "options": [
        { "value": "silver", "label": "Silver foil" },
        { "value": "gold", "label": "Gold foil" },
        { "value": "black", "label": "Black" }
      ],
      "default": "silver"
    },
    { "type": "range", "id": "reveal_threshold", "label": "Auto-reveal threshold", "info": "Scratched area at which the remaining foil fades away.", "min": 30, "max": 85, "step": 5, "unit": "%", "default": 55 },
    { "type": "image_picker", "id": "popup_image", "label": "Popup image" },
    { "type": "checkbox", "id": "show_logo", "label": "Show shop logo", "default": true },
    { "type": "image_picker", "id": "logo_image", "label": "Logo image", "info": "Optional override. When empty, the logo from your Shopify brand settings (Settings → Brand) is used." },

    { "type": "header", "content": "Step 1 — Scratch card" },
    { "type": "paragraph", "content": "💡 Empty text fields fall back to the shop language automatically." },
    { "type": "text", "id": "scratch_heading", "label": "Heading" },
    { "type": "text", "id": "scratch_subheading", "label": "Subheading" },
    { "type": "text", "id": "card_kicker", "label": "Card kicker" },
    { "type": "text", "id": "card_prize", "label": "Card prize text" },
    { "type": "text", "id": "foil_text", "label": "Text on foil" },
    { "type": "text", "id": "claim_button", "label": "Claim button" },
    { "type": "text", "id": "hint_scratch", "label": "Hint (before reveal)" },
    { "type": "text", "id": "hint_revealed", "label": "Hint (after reveal)" },

    { "type": "header", "content": "Regular newsletter — Intro" },
    { "type": "paragraph", "content": "Shown instead of the scratch card when popup type is 'Regular newsletter'. Reuses the email placeholder, error and legal text from Step 2; phone and success steps are shared." },
    { "type": "text", "id": "regular_heading_top", "label": "Heading line 1" },
    { "type": "text", "id": "regular_heading", "label": "Heading line 2" },
