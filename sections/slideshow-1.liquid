/* Positionierungs-Basis: kam frueher aus der Slick-CSS (.slick-arrow/.slick-prev/
   .slick-next). Nach der Swiper-Migration tragen die Buttons nur noch
   .slideshow__arrow -> ohne diese Basis lagen sie unsichtbar unter den Slides. */
.slideshow {
  position: relative;
}
.slideshow .slideshow__arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
  margin: 0;
  cursor: pointer;
  overflow: hidden;
  transition: all 0.3s ease;
}
.slideshow .slideshow__arrow.swiper-button-lock {
  display: none;
}
.slideshow .slideshow__arrow.swiper-button-disabled {
  opacity: .35;
  cursor: default;
}
/* Icon = Icomoon-Glyphe wie vor der Vanilla-Migration (Slick :before \e903/\e904)
   inkl. animateIcon-Hover (Keyframes global in theme.css). Farbe erbt vom Button
   (Setting "Color Arrow"). */
.slideshow .slideshow__arrow:before {
  font-family: icomoon !important;
  font-size: 16px;
  line-height: 1;
  opacity: 1;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  display: inline-block;
}
.slideshow .slideshow__arrow--prev:before {
  content: "\e903";
}
.slideshow .slideshow__arrow--next:before {
  content: "\e904";
}
.slideshow .slideshow__arrow--prev:hover:before {
  animation: 0.4s ease-in-out reverse forwards animateIcon;
}
.slideshow .slideshow__arrow--next:hover:before {
  animation: 0.4s ease-in-out forwards animateIcon;
}

{%- if dot == 'square' -%}
  @keyframes animright {
    0%   {width: 0%;}
    100% {width: 100%;}
  }
  .dot-square.slideshow  .swiper-pagination-bullet{
    width: 48px;
    height: 32px;
    border-radius: 0;
    border:none;
    background-color: transparent;
    position: relative;
    opacity: 1;
  }
  @media (max-width:749px) {
    .dot-square.slideshow  .swiper-pagination-bullet{
      width: 32px;
    }
  }
  .dot-square.slideshow .swiper-pagination-bullet:before{
    height: 2px;
    width: 100%;
    top: calc(50% - 1px);
    background-color: rgba(var(--slide-color-dot),0.5);
    content: "";
    position: absolute;
    left: 0;
  }
  .dot-square.slideshow .swiper-pagination-bullet-active::after{
    height: 2px;
    top: calc(50% - 1px);
    background-color: rgba(var(--slide-color-dotactive), 1);
    content: "";
    position: absolute;
    left: 0;
    z-index: 1;
    {%- if rotate -%}
    animation:animright var(--slide-rotate) linear 1;
    {%- else -%}
    width:100%;
    {%- endif -%}
  }
{%- elsif dot == 'circle' -%}
.dot-circle.slideshow .swiper-pagination-bullet{
  width: 20px;
  height: 20px;
  margin:0 3px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  opacity: 1;
  background-color: rgba(var(--slide-color-dot),0.5);
  border:none;
  transform: scale(0.7);
  transition: transform 0.3s cubic-bezier(0.23, 1, 0.320, 1);
}
.dot-circle.slideshow .swiper-pagination-bullet-active{
  background-color: rgba(var(--slide-color-dotactive),1);
  transform: scale(1);
}
{%- endif -%}

