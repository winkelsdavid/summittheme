.slideshow[data-transit="slide-fade"] .slide{
}
.slideshow[data-transit="slide-fade"] .slide .slideshow__image{
  will-change: transform, opacity;
  transform: translateX(10vw);
  opacity: 0;
}
/* .slide-shown ergaenzend zu .swiper-slide-active: JS setzt sie auf Original UND
   Loop-Duplikat gleichzeitig, damit die Animation den instant loopFix-Wechsel
   (Swiper 6 Duplikate) nahtlos ueberlebt statt sichtbar neu zu starten. */
.slideshow[data-transit="slide-fade"] .slide.swiper-slide-active .slideshow__image,
.slideshow[data-transit="slide-fade"] .slide.slide-shown .slideshow__image{
  transition: transform 0.6s ease, opacity 0.6s;
  opacity: 1;
  transform: translateX(0);
}
.slideshow[data-transit="slide-fade"] .slide.slick-going .slideshow__image {
  transition: transform 0.6s ease 60ms;
  transform: translateX(-10vw);
  opacity: 1;
}

.slideshow[data-transit="zoom"] .slide .slideshow__image{
  transform: scale(1.2);
  will-change: transform;
  transition: transform 1.8s cubic-bezier(0.21, 0.6, 0.35, 1);
}
.slideshow[data-transit="zoom"] .slide.swiper-slide-active .slideshow__image,
.slideshow[data-transit="zoom"] .slide.slide-shown .slideshow__image{
  transform: scale(1);
}
