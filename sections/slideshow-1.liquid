<!-- slideshow-1.liquid -->
{%- liquid
  if section.settings.slideshow_height_adapt == 'adapt' 
  assign first_block = section.blocks[0] 
  if first_block.settings.image.aspect_ratio == blank 
  assign min_aspect_ratio = 2.0 
  else 
  assign min_aspect_ratio = first_block.settings.image.aspect_ratio 
  endif 
  assign wrapper_height = 100 | divided_by: min_aspect_ratio 
  endif 
-%}
<div class="{{ section.settings.setwidthout }}" data-section-id="{{ section.id }}" data-section-type="slideshow-section">
  {%- if section.blocks.size > 0 -%}
  <div id="SlideshowWrapper-{{ section.id }}" class="slideshow-wrapper" role="region" aria-label="slideshow" aria-describedby="slideshow-info" tabindex="-1">
    <div class="transit-{{ section.settings.anim_slideshow }} dot-{{ section.settings.slide_dot }} slideshow {% unless section.settings.slideshow_height_adapt == 'adapt' %} slideshow--desktop-{{ section.settings.slideshow_height_adapt }} {% endunless %} mobile--slideshow-{{ section.settings.slideshow_height_mobile }} "
         id="Slideshow-{{ section.id }}"
         data-arrow="{{ section.settings.e_arrow }}"
         data-dot="{{ section.settings.e_dot }}"
         data-autorotate="{{ section.settings.autorotate }}"
         data-speed="{{ section.settings.autorotate_speed | times: 1000 }}"
         data-adapt-height="{%- if section.settings.slideshow_height_adapt == 'adapt' -%}true{%- else -%}false{%- endif -%}"
         data-slide-nav-a11y="{{ 'sections.slideshow.load_slide' | t: slide_number: '[slide_number]' }}"
         data-transit="{{ section.settings.anim_slideshow }}"
         {%- if section.settings.slideshow_height_adapt == 'adapt' -%}data-min-aspect-ratio="{{ min_aspect_ratio }}"
         style="height: {{ wrapper_height }}vw"{%- endif -%}>

      {%- for block in section.blocks -%}
      {%- assign text_alignments = block.settings.text_alignment | split: ' ' -%}
      {%- assign text_horizontal_alignment = text_alignments.first -%}
      {%- assign text_vertical_alignment = text_alignments.last | strip -%}
      
      <div class="slide {% if block.settings.image2 != blank %}slideshow__slide-split {% endif %} slideshow__slide slideshow__slide--{{ block.id }}" {{ block.shopify_attributes }} style="background-color: {% if block.settings.bgwrap != blank and block.settings.bgwrap != "rgba(0,0,0,0)"%}{{ block.settings.bgwrap }}{% else %}{{ settings.color_body_bg }}{% endif %};">
         {% if block.settings.blurry_transition %}
              <div class="slideshow_blurry" style="background:linear-gradient(360deg, {% if block.settings.blurry_color != blank and block.settings.blurry_color != "rgba(0,0,0,0)"%}{{ block.settings.blurry_color }}{% else %}{{ settings.color_body_bg }}{% endif %}, #ffffff00)"></div>
            {% endif %} 
        <style>
           {% if block.settings.slide_toptitle_color != "rgba(0,0,0,0)" %}
                .slideshow__slide--{{ block.id }} .slideshow__toptitle{
                  background-clip: unset;
                  background: transparent;
                  -webkit-text-fill-color: unset;
                }
            {% endif %}
            {% if block.settings.slide_title_color != "rgba(0,0,0,0)" %}
                .slideshow__slide--{{ block.id }} .mega-title{
                  background: transparent;
                  -webkit-text-fill-color: unset;
                   background-clip: unset;
                }
            {% endif %}
            {% if block.settings.subheading_color != "rgba(0,0,0,0)"  %}
                .slideshow__slide--{{ block.id }} .slideshow__subtitle{
                  background-clip: unset;
                  background: transparent;
                  -webkit-text-fill-color: unset;
                }
            {% endif %}
