            {{ block.settings.slide_toptitle }}
          </p>
          {%- endunless -%}
             {% endif %}
          {%- unless block.settings.slide_title == blank -%}
          <h2 class="h1 mega-title slideshow__title slideshow__title--mobile mb-3"  {% if  block.settings.slide_title_color != "rgba(0,0,0,0)" and block.settings.slide_title_color != blank  %}style="--g-color-heading:{{ block.settings.slide_title_color }}"{% endif %}>
            {{ block.settings.slide_title }}
          </h2>
          {%- endunless -%}
          {%- unless block.settings.subheading == blank -%}
          <div class="mega-subtitle slideshow__subtitle slideshow__subtitle--mobile mb-3" style="color:{{ block.settings.subheading_color }}">
            {{ block.settings.subheading }} 
          </div>
          {%- endunless -%}
            <div class="mega-subtitle slideshow__subtitle slideshow__subtitle--mobile icons_cont" style="--spacing:{{ block.settings.spacing }}px">
               {% for ii in (1..3) %}
                  {% assign icon = "icon_" | append: forloop.index %}
                  {% assign c_icon = "c_icon_" | append: forloop.index %}
                  {% assign icon_text = "icon_text_" | append: forloop.index %}
                  {% if block.settings[icon] != blank or block.settings[c_icon] != blank and block.settings[icon_text] != blank %}
                    {% if block.settings[icon_text] != blank %}
                    <div class="c_icon_item" style="padding:{{ block.settings.icon_padding }}px {{ block.settings.icon_padding_left_right }}px;background:{{ block.settings.icon_background }};border-radius:{{ block.settings.icon_radius }}px;--icon-size:{{ block.settings.icons_size }}px;--icon-color:{{ block.settings.icon_color }}">
                      <div class="c_item_icon" style="display:flex;--icon-color:{{ block.settings.icon_color }}">
                      {% if block.settings[c_icon] != blank %}
                          <img src="{{ block.settings[c_icon] | image_url: width: 100 }}" alt="{{ block.settings[icon_text] }}" width="{{ block.settings.icons_size }}">
                      {% else %}
                        {% render 'list-svg',block:block, icon: block.settings[icon] %}
                      {% endif %}
                      </div>
                    <span style="--size:{{ block.settings.text_size_desktop }}px;--mobile-size:{{ block.settings.text_size_mobile }}px;--color:{{ block.settings.icons_text_color }}">{{ block.settings[icon_text] }}</span>
                    </div>
                  {% endif %}
                  {% endif %}
                {% endfor %}
            </div>

          <div class="slideshow__btn-wrapper align-items-center justify-content-center   {% if block.settings.slide_title != blank or block.settings.subheading != blank %} slideshow__btn-wrapper--push{% endif %}" >
            {%- if show_link_button-1 -%}
              <style>
                .btn-theme.slideshow__btn{{ block.id }}{
                  color:{{ block.settings.color_button }};
                  border: 1px solid {{ block.settings.bg_button }};
                  background:{{ block.settings.bg_button }};
                }
                   .btn-theme.slideshow__btn{{ block.id }}::before{
                  background:{{ block.settings.bg_button_hover }};
                }
                /*.btn-theme.slideshow__btn{{ block.id }}:after{
                  background:{{ block.settings.bg_button }};
                }*/
                .btn-outline.slideshow__btn{{ block.id }}{
                  color:{{ block.settings.color_button }};
                  border: 1px solid {{ block.settings.bg_button }};
                  background:transparent;
                }
                {% if settings.enable_button_hover %}
                      {% if settings.btn_animation == "hover_3" %}
                    .btn-theme.slideshow__btn{{ block.id }}:after{
                       background:{{ block.settings.bg_button }};
                    }
                  {% endif %}
                    {% endif %}
                {% if settings.enable_button_hover == false %}
                .btn-theme.slideshow__btn{{ block.id }}:hover{
                  color:{{ block.settings.color_button_hover }};
                  border-color:{{ block.settings.bg_button_hover }};
                  {% unless settings.enable_button_hover %}
                    background:{{ block.settings.bg_button_hover }};
                  {% endunless %}
                }
                .btn-outline.slideshow__btn{{ block.id }}:hover{
                  border-color:{{ block.settings.bg_button_hover }};
                  color:{{ block.settings.color_button_hover }};
                  {% unless settings.enable_button_hover %}
                    background:{{ block.settings.bg_button_hover }};
                  {% endunless %}
                }
              {% endif %}
                .btn-outline.slideshow__btn{{ block.id }}::before{
                  background:{{ block.settings.bg_button_hover }};
                }
                .btn-underline.slideshow__btn{{ block.id }}{
                  color:{{ block.settings.color_button }} !important;
                  border-bottom-color:  {{ block.settings.bg_button }} !important;
                }
                .btn-underline.slideshow__btn{{ block.id }}:hover{
                  color:{{ block.settings.color_button_hover }} !important;
                  border-bottom-color:  {{ block.settings.bg_button_hover }} !important;
                }
              </style>
              <div>
              <a href="{{ block.settings.button_link }}" class="btn  slideshow__btn{{ block.id }} {{ block.settings.stylebtns }}">
                <span>{{ block.settings.button_label }}</span>
              </a>
            </div>
            {%- endif -%}
            {%- if show_link_button-2 -%}
              <style>
                .btn-theme.slideshow__btn-2{{ block.id }}{
                  color:{{ block.settings.color_button_2 }};
                  border: 1px solid {{ block.settings.bg_button_2 }};
                  background:{{ block.settings.bg_button_2 }};
                }
                .btn-theme.slideshow__btn-2{{ block.id }}::before{
                  background:{{ block.settings.bg_button_hover_2 }};
                }
                .btn-outline.slideshow__btn-2{{ block.id }}{
                  color:{{ block.settings.color_button_2 }};
                  border: 1px solid {{ block.settings.bg_button_2 }};
                  background-color:transparent;
                }
                {% if settings.enable_button_hover == false %}
                .btn-theme.slideshow__btn-2{{ block.id }}:hover{
                  color:{{ block.settings.color_button_hover_2 }};
                  border-color:{{ block.settings.bg_button_hover_2 }};
                  {% unless settings.enable_button_hover %}
                    background:{{ block.settings.bg_button_hover_2 }};
                  {% endunless %}
                }
                .btn-outline.slideshow__btn-2{{ block.id }}:hover{
                  border-color:{{ block.settings.bg_button_hover_2 }};
                  color:{{ block.settings.color_button_hover_2 }};
                  {% unless settings.enable_button_hover %}
                    background:{{ block.settings.bg_button_hover_2 }};
                  {% endunless %}
                }
                {% endif %}

                .btn-outline.slideshow__btn-2{{ block.id }}::before{
                  background:{{ block.settings.bg_button_hover_2 }};
                }
                .btn-underline.slideshow__btn-2{{ block.id }}{
                  color:{{ block.settings.color_button_2 }} !important;
                  border-bottom-color:  {{ block.settings.bg_button_2 }} !important;
                }
                .btn-underline.slideshow__btn-2{{ block.id }}:hover{
                  color:{{ block.settings.color_button_hover_2 }} !important;
                  border-bottom-color:  {{ block.settings.bg_button_hover_2 }} !important;
                }
              </style>
              <div>
                <a href="{{ block.settings.button_link_2 }}" class="btn slideshow__btn-2{{ block.id }} {{ block.settings.stylebtns_2 }}">
                  <span>{{ block.settings.button_label_2 }}</span>
                </a>
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
      {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endunless -%}
  {%- endif -%}
  {%- if section.blocks.size == 0 -%}
  <div class="placeholder-noblocks">
    {{ 'homepage.onboarding.no_content' | t }}
  </div>
  {%- endif -%}
</div>
{%- endif -%}
