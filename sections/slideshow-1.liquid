              z-index: 2;
            }
            {%- if gradient -%}
            .gradient_overlay-{{ block.id }}:before{
              background:linear-gradient(180deg, rgb({{ bgoverlay }}, 0) 0%, rgb({{ bgoverlay }},{{ opoverlay }}) 100%);
