                  | image_tag: width: width, height: height, sizes: sizes, widths: widths, fetchpriority: fetch_priority,  loading: 'eager', class:'lazyload scale-in', style: object_position
                }}
              {%- else -%}
                {{
                  block.settings.image2
                  | image_url: width: 3840
                  | image_tag: loading: 'lazy',width: width, height: height, sizes: sizes, widths: widths, class:'lazyload scale-in', style: object_position
                }}
