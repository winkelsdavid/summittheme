                assign width = block.settings.image2.width | round
                assign sizes = '100vw'
                assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'  
                assign fetch_priority = 'high'
                assign object_position = 'object-position:'| append: block.settings.alignment 
              -%}
              {%- if forloop.first %}
                {{
                  block.settings.image2
