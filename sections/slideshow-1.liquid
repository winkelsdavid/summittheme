                          <div class="c_icon_item" style="padding:{{ block.settings.icon_padding }}px {{ block.settings.icon_padding_left_right }}px;border-radius:{{ block.settings.icon_radius }}px;background:{{ block.settings.icon_background }};--icon-size:{{ block.settings.icons_size }}px;--icon-color:{{ block.settings.icons_color }}">
