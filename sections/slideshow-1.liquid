                endif
                if block.settings.button_label_2 != blank and block.settings.button_link_2 != blank
                assign show_link_button-2 = true
                endif
                assign text_alignment = block.settings.text_alignment
                case text_alignment
                when 'left top'
                  assign align = 'justify-content-start'
                when 'center top'
                  assign align = 'justify-content-center'
                when 'right top'
                  assign align = 'justify-content-start'
                when 'left center'
                  assign align = 'justify-content-start'
                when 'center center'
                  assign align = 'justify-content-center'
                when 'right center'
                  assign align = 'justify-content-start'
                when 'left bottom'
                  assign align = 'justify-content-start'
                when 'center bottom'
                  assign align = 'justify-content-center'
                when 'right bottom'
                  assign align = 'justify-content-start'
                endcase
              -%}
              
              <div class="slideshow__btn-wrapper  align-items-center {{ align }}  {% if block.settings.slide_title != blank or block.settings.subheading != blank %} slideshow__btn-wrapper--push{% endif %}" >
                {%- if show_link_button-1 -%}
                  <style>
                    .btn-theme.slideshow__btn{{ block.id }}{
                      color:{{ block.settings.color_button }};
                     {% if block.settings.bg_button != "rgba(0,0,0,0)" %}
                      border: 1px solid {{ block.settings.bg_button }};
                     {% endif %}
                      {% if block.settings.bg_button != "rgba(0,0,0,0)" %}
                      background:{{ block.settings.bg_button }};
                      {% endif %}
                    }
                    {% if settings.enable_button_hover %}
                  {% if settings.btn_animation == "hover_1" %}
                      .btn-theme.slideshow__btn{{ block.id }}{
                      border:unset;
                      }
                  {% endif %}
                    {% endif %}
                    
                    .btn-outline.slideshow__btn{{ block.id }}{
                      color:{{ block.settings.color_button }};
                      border: 1px solid {{ block.settings.bg_button }};
                      background:transparent;
                    }
                    {% if settings.enable_button_hover == false %}
                      .btn-theme.slideshow__btn{{ block.id }}::before{
                      background:{{ block.settings.bg_button_hover }};
                      opacity:0;
                      display:block;
                      transition:.5s;
                    }
                    .btn-theme.slideshow__btn{{ block.id }}:hover{
                      color:{{ block.settings.color_button_hover }};
                      {% if block.settings.bg_button != "rgba(0,0,0,0)" %}
                      border-color:{{ block.settings.bg_button }};
                      {% endif %}
                      {% unless settings.enable_button_hover %}
                      /*  {% if block.settings.bg_button_hover != "rgba(0,0,0,0)"  %}
                        background:{{ block.settings.bg_button_hover }};
                        {% endif %}*/
                      {% endunless %}
                    }
                     .btn-theme.slideshow__btn{{ block.id }}:hover:before{
                      opacity:1;
                      width:100%;
                    }
                    .btn-outline.slideshow__btn{{ block.id }}:hover{
                      border-color:{{ block.settings.bg_button_hover }};
                      color:{{ block.settings.color_button_hover }};
                      {% unless settings.enable_button_hover %}
                        background:{{ block.settings.bg_button_hover }};
                      {% endunless %}
                    }
                    {% endif %}
                  
                    
                    .btn-outline.slideshow__btn{{ block.id }}::before{
                      background:{{ block.settings.bg_button_hover }};
                    }
                    .btn-underline.slideshow__btn{{ block.id }}{
                      color:{{ block.settings.color_button }} !important;
                      {% comment %} border-bottom-color:  {{ block.settings.bg_button }} !important; {% endcomment %}
                    }
                    .btn-underline.slideshow__btn{{ block.id }}:before{
                      background: {{ block.settings.bg_button }} !important;
                    }
                    .btn-underline.slideshow__btn{{ block.id }}:after{
                      background: {{ block.settings.bg_button_hover }} !important;
                    }
                    .btn-underline.slideshow__btn{{ block.id }}:hover{
                      color:{{ block.settings.color_button_hover }} !important;
                    }
                  </style>
                  <div class="pb-1">
                  <a href="{{ block.settings.button_link }}" class="btn slideshow__btn slideshow__btn{{ block.id }} {{ block.settings.stylebtns }}">
                    <span>{{ block.settings.button_label }}</span>
                  </a>
                </div>
                {%- endif -%}
                {%- if show_link_button-2 -%}
                  <style>
                    .btn-theme.slideshow__btn-2{{ block.id }}{
                      color:{{ block.settings.color_button_2 }};
                      border: 1px solid {{ block.settings.bg_button_2 }};
                      background:{{ block.settings.bg_button_2 }};
                    }
                    .btn-theme.slideshow__btn-2{{ block.id }}::before{
                      background:{{ block.settings.bg_button_hover_2 }};
                    }
                     .btn-outline.slideshow__btn-2{{ block.id }}::before{
                      background:{{ block.settings.bg_button_hover_2 }};
                    }
                    {% if settings.enable_button_hover %}
                      {% if settings.btn_animation == "hover_3" %}
                    .btn-theme.slideshow__btn-2{{ block.id }}:after{
                       background:{{ block.settings.bg_button }};
                    }
                  {% endif %}
                    {% endif %}
                    .btn-outline.slideshow__btn-2{{ block.id }}{
                      color:{{ block.settings.color_button_2 }};
                      border: 1px solid {{ block.settings.bg_button_2 }};
                      background:transparent;
                    }
                    {% if settings.enable_button_hover == false %}
                    .btn-theme.slideshow__btn-2{{ block.id }}:hover{
                      color:{{ block.settings.color_button_hover_2 }};
                      border-color:{{ block.settings.bg_button_hover_2 }};
                      {% unless settings.enable_button_hover %}
                        background:{{ block.settings.bg_button_hover_2 }};
                      {% endunless %}
                    } 
                    .btn-outline.slideshow__btn-2{{ block.id }}:hover{
                      border-color:{{ block.settings.bg_button_hover_2 }};
                      color:{{ block.settings.color_button_hover_2 }};
                      {% unless settings.enable_button_hover %}
                        background:{{ block.settings.bg_button_hover_2 }}; 
                      {% endunless %}
                    }
                  {% endif %}
                    
                    .btn-underline.slideshow__btn-2{{ block.id }}{
                      color:{{ block.settings.color_button_2 }} !important;
                      {% comment %} border-bottom-color:  {{ block.settings.bg_button }} !important; {% endcomment %}
                    }
                    .btn-underline.slideshow__btn-2{{ block.id }}:before{
                      background: {{ block.settings.bg_button_2 }} !important;
                    }
                    .btn-underline.slideshow__btn-2{{ block.id }}:after{
                      background: {{ block.settings.bg_button_hover_2 }} !important;
                    }
                    .btn-underline.slideshow__btn-2{{ block.id }}:hover{
                      color:{{ block.settings.color_button_hover_2 }} !important;
                      {% comment %} border-bottom-color:  {{ block.settings.bg_button_hover }} !important; {% endcomment %}
                    }
                  </style>
                  <div class="pb-1">
