          {%- endif -%}
        {% endif %}
        {%- endif -%}
        {%- if section.settings.show_overlay -%}<div class="slideshow__overlay {% if section.settings.gradient_overlay %} gradient_overlay {% endif %}"></div>{%- endif -%}

        <div class="slideshow__text-wrap slideshow__text-wrap--desktop mobile-align-{{ block.settings.text_alignment_mobile }}">
          <div class="slideshow__text-content slideshow__text-content--vertical-{{ text_vertical_alignment }} text-{{ text_horizontal_alignment }} mob-text-center">
            <div class="{{ section.settings.section_width }}" data-aos="fade" data-aos-anchor-placement="top-bottom"  data-aos-once="true">
              
              <div class="d-inline-block text-{% if text_horizontal_alignment == 'left' %}left{% else %}{{text_horizontal_alignment}}{% endif %} ">
              <ul class="list-unstyled"  >
                {% if block.settings.replace_reviews %}
                   <li class="mb-1 mb-lg-3">
                      {%  render 'rating-custom', section: block , align : text_horizontal_alignment %}
                </li>
              {% else %}
                {%- unless block.settings.slide_toptitle == blank -%}
                <li class="mb-3">
                  <p class="slideshow__toptitle subtop" style="{% if block.settings.slide_toptitle_color != "rgba(0,0,0,0)" %}color:{{ block.settings.slide_toptitle_color }}{% endif %}">
                    {{ block.settings.slide_toptitle }}
                  </p>
                </li>
                {%- endunless -%}
                 {% endif %}
                {%- unless block.settings.slide_title == blank -%}
                <li class="slideshow_title" style="--margin-bottom:{{ block.settings.margin_title | append:'rem' }};--margin-mobile:{{ block.settings.margin_title_mobile }}rem">
                  <h2 class="h1 mega-title slideshow__title font-family-1" {% if  block.settings.slide_title_color != "rgba(0,0,0,0)" and block.settings.slide_title_color != blank  %}style="--g-color-heading:{{ block.settings.slide_title_color }}"{% endif %}>
                    {{ block.settings.slide_title }}
                  </h2>
                  
                </li>
                {%- endunless -%}
                {%- unless block.settings.subheading == blank -%}
                <li class="mb-lg-3 mb-3">
                  <div class="mega-subtitle slideshow__subtitle  d-lg-block fz-2" {% if  block.settings.subheading_color != "rgba(0,0,0,0)" %}style="color:{{ block.settings.subheading_color }}"{% endif %}>
                    {{ block.settings.subheading }}
                  </div>
                </li>
                {%- endunless -%}
                <li class="pb-1 mb-lg-4 icons_cont slideshow__title" style="--spacing:{{ block.settings.spacing }}px">
