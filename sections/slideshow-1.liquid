          </div>
        </div>
        {%- endif -%}
        {%- else -%}
        <div class="{% if block.settings.image_mobile != blank %} d-none d-lg-block {% endif %} {% if block.settings.image2 != blank %} w-50 slide_img_left {% endif %} slideshow__image box ratio-container">
             {%- liquid
              assign height = block.settings.image.width | divided_by: block.settings.image.aspect_ratio | round
              assign width = block.settings.image.width | round
