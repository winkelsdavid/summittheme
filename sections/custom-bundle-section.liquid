{% comment %} bundle_selection section {% endcomment %}

{%- liquid
  assign section_id = section.id
  assign min_items   = section.settings.min_items
  assign max_items   = section.settings.max_items
-%}

<style>
/* ── Section shell ───────────────────────────────────────── */
.bns-section-{{ section_id }} {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  background: {{ section.settings.background }};
}
@media (max-width: 991px) {
  .bns-section-{{ section_id }} {
    padding-top: {{ section.settings.mobile_padding_top }}px;
    padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
  }
}

/* ── Two-column layout ───────────────────────────────────── */
.bns-layout {
  display: flex;
  flex-direction: column;
  gap: 4rem;
}
@media (min-width: 768px) {
  .bns-layout {
    flex-direction: row;
    gap: clamp(3rem, 5.848vw - 1.485rem, 6rem);
    align-items: flex-start;
  }
}

/* ── Sticky sidebar ──────────────────────────────────────── */
.bns-sidebar {
  width: 100%;
}
@media (min-width: 768px) {
 .bns-section-{{ section_id }} .bns-sidebar {
    width: 320px;
    flex-shrink: 0;
    position: sticky;
    top: 200px;
   /* height: 100vh;
    display: flex;
    align-items: center;*/
  }
}
@media (min-width: 1200px) {
  .bns-sidebar {
    width: 360px;
  }
}

.bns-sidebar-inner {
  display: flex;
  flex-direction: column;
  gap: 2.4rem;
}

/* ── Header text ─────────────────────────────────────────── */
.bns-section-{{ section_id }} .bns-eyebrow {
  margin: 0 0 .8rem;
  color: {{ section.settings.eyebrow_color }};
}
.bns-section-{{ section_id }} .bns-heading {
  margin: 0 0 1.2rem;
  font-size: {{ section.settings.heading_size }}px;
  line-height: 1.15;
  {% if section.settings.heading_color != blank and section.settings.heading_color != "rgba(0,0,0,0)" %}
  --g-color-heading: {{ section.settings.heading_color }};
  {% endif %}
}
.bns-section-{{ section_id }} .bns-desc {
  margin: 0;
  {% if section.settings.desc_color != blank and section.settings.desc_color != "rgba(0,0,0,0)" %}
  color: {{ section.settings.desc_color }};
  {% endif %}
}

/* ── Selected-items tray ─────────────────────────────────── */
.bns-section-{{ section_id }} .bns-tray-label {
  font-size: 1.4rem;
  font-weight: 600;
  line-height:1;
  {% if section.settings.heading_color != blank and section.settings.heading_color != "rgba(0,0,0,0)" %}
  color: {{ section.settings.heading_color }};
  {% endif %}
  display: flex;
  align-items: center;
  gap: .8rem;
  margin-bottom:8px;
}
.bns-section-{{ section_id }} .bns-tray-count {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 24px;
  width:24px;
  height: 24px;
  padding: 0 .6rem;
  border-radius: 100px;
  font-size: 14px;
  font-weight: 700;
   {% if section.settings.badge_bg != blank and section.settings.badge_bg != "rgba(0,0,0,0)" %}
    background: {{ section.settings.badge_bg }};
   {% else %}
    background: {{ settings.branding_color }};
   {% endif %}
  color: {{ section.settings.badge_color }};
}

.bns-tray {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
}

.bns-section-{{ section_id }} .bns-tray-slot {
  position: relative;
  width: calc(33.33% - 1rem*2/3);
  height:90px;
  border-radius: calc(0.2rem * {{ settings.radius_allimg_range }});
  overflow: hidden;
  background: {{ section.settings.slot_empty_bg }};
  border: 1px dashed {{ section.settings.slot_empty_border }};
  flex-shrink: 0;
}
.bns-section-{{ section_id }} .bns-tray-slot.is-filled {
  border-style: solid;
  border-color: {{ section.settings.slot_filled_border }};
}
.bns-tray-slot img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.bns-tray-slot__placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.bns-tray-slot__placeholder svg {
  width: 32px;
  height: 32px;
  opacity: .25;
}
.bns-tray-slot__remove {
  position: absolute;
  top: 4px;
  right: 4px;
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: #fff;
  border: none;
  cursor: pointer;
  display: none;
  align-items: center;
  justify-content: center;
  padding: 0;
  box-shadow: 0 1px 4px rgba(0,0,0,.2);
}
.bns-tray-slot.is-filled .bns-tray-slot__remove {
  display: flex;
}
.bns-tray-slot__remove svg {
  width: 10px;
  height: 10px;
}

/* ── CTA button ──────────────────────────────────────────── */
.bns-cta {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}
/*.bns-add-btn {
  width: 100%;
  padding: 1.4rem 2rem;
  border-radius: calc(0.2rem * {{ settings.radius_allimg_range }});
  border: none;
  cursor: pointer;
  font-size: 1.5rem;
  font-weight: 600;
  transition: opacity .2s ease, background .2s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: .8rem;
  background: {{ section.settings.btn_bg }};
  color: {{ section.settings.btn_color }};
}*/
.bns-section-{{ section_id }} .bns-add-btn {
  background: {{ section.settings.btn_bg }};
  color: {{ section.settings.btn_color }};
}
.bns-add-btn:disabled {
  opacity: .45;
  cursor: not-allowed;
}
.bns-add-btn:not(:disabled):hover {
  opacity: .88;
}
.bns-error {
  font-size: 1.3rem;
  color: #c0392b;
  display: none;
}
.bns-error.is-visible {
  display: block;
}

/* ── Product grid ────────────────────────────────────────── */
.bns-grid-wrap {
  flex: 1;
  min-width: 0;
}
.bns-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: clamp(.8rem, 2vw, 2.4rem);
}
@media (min-width: 768px) {
  .bns-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}
@media (min-width: 1024px) {
  .bns-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

/* ── Product card ────────────────────────────────────────── */
.bns-section-{{ section_id }} .bns-card {
  display: flex;
  flex-direction: column;
  border-radius: calc(0.2rem * {{ settings.radius_allimg_range }});
  overflow: hidden;
  background: {{ section.settings.card_bg }};
  border: 1px solid {{ section.settings.card_border }};
  transition: box-shadow .2s ease;
}
/*.bns-card:hover {
  box-shadow: 0 4px 20px rgba(0,0,0,.08);
}
.bns-section-{{ section_id }} .bns-card.is-selected {
  border-color: {{ section.settings.card_selected_border }};
  box-shadow: 0 0 0 2px {{ section.settings.card_selected_border }};
}*/
.bns-card__add-btn.is-added{
cursor: not-allowed;
}
.bns-card__add-btn.is-added:before{
content:unset!important;
}
.bns-section-{{ section_id }} .bns-card__media {
  position: relative;
  aspect-ratio: 1;
  overflow: hidden;
  background: {{ section.settings.card_img_bg }};
}
.bns-card__media img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform .5s cubic-bezier(.16,1,.3,1);
}
.bns-card:hover .bns-card__media img:first-child {
  transform: scale(1.04);
}
.bns-card__media img.bns-card__img-secondary {
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity .4s ease, transform .5s cubic-bezier(.16,1,.3,1);
}
.bns-card:hover .bns-card__media img.bns-card__img-secondary {
  opacity: 1;
}

.bns-card__body {
  display: flex;
  flex-direction: column;
  gap: .6rem;
  padding: 1.2rem;
  flex: 1;
  align-items:center;
}
.bns-section-{{ section_id }} .bns-card__title {
  font-size: 16px;
  font-weight: 600;
  line-height: 1.3;
  color: {{ section.settings.card_title_color }};
  text-align:center;
}
.bns-section-{{ section_id }} .bns-card__price {
  font-size: 16px;
  color: {{ section.settings.card_price_color }};
  display: flex;
  align-items: center;
  gap: .6rem;
  flex-wrap: wrap;
  justify-content:center;
}
.bns-card__price--compare {
  text-decoration: line-through;
  opacity: .5;
}

.bns-card__form {
  display: flex;
  flex-direction: column;
  gap: .6rem;
  padding: 0 1.2rem 1.2rem;
}
@media (min-width: 480px) {
  .bns-card__form {
    flex-direction: row;
    align-items: center;
  }
}

.bns-section-{{ section_id }} .bns-card__select {
  flex: 1;
  border-radius: calc(0.2rem * {{ settings.radius_allimg_range }});
  border: 1px solid {{ section.settings.select_border }};
  background: {{ section.settings.select_bg }};
  color: {{ section.settings.select_color }};
  font-size: 16px;
  cursor: pointer;
  appearance: auto;
      max-width: calc(100% - 76px);
    height: 100%;
}
@media (max-width:768px){
.bns-section-{{ section_id }} .bns-card__select {
    max-width: 100%;
}
}

.bns-section-{{ section_id }} .bns-card__add-btn {
  padding: var(--g-padding-ver-btn) 16px;
  border-radius: calc(0.2rem * {{ settings.radius_allimg_range }});
  border: none;
  cursor: pointer;
  white-space: nowrap;
  transition: opacity .2s ease;
  background: {{ section.settings.add_btn_bg }};
  color: {{ section.settings.add_btn_color }};
  width:100%;
}
.bns-card__add-btn:hover { opacity: .85; }
.bns-section-{{ section_id }} .bns-card__add-btn.is-added {
  background: {{ section.settings.added_btn_bg }};
  color: {{ section.settings.added_btn_color }};
}
</style>

<section
  class="bns-section-{{ section_id }}"
  id="bns-{{ section_id }}"
  data-aos="{{ section.settings.animation }}"
>
<div class="{{ section.settings.section_width }}">
  <div
    class="bns-layout"
    id="bns-app-{{ section_id }}"
    data-min="{{ min_items }}"
    data-max="{{ max_items }}"
    data-dup-msg="{{ section.settings.duplicate_caption }}"
    data-limit-msg="{{ section.settings.limit_caption }}"
  >

    <!-- ── Sidebar ── -->
    <div class="bns-sidebar">
      <div class="bns-sidebar-inner">

        <!-- Header -->
        <div>
          {% if section.settings.eyebrow_subheading != blank %}
            <div class="subtop text-top mb-2 bns-eyebrow aos-init aos-animate" data-aos="fade-up">{{ section.settings.eyebrow_subheading }}</div>
          {% endif %}
          {% if section.settings.heading != blank %}
            <h2 class="bns-heading">{{ section.settings.heading }}</h2>
          {% endif %}
          {% if section.settings.description != blank %}
            <p class="bns-desc">{{ section.settings.description }}</p>
          {% endif %}
        </div>

        <!-- Tray -->
        <div>
          <div class="bns-tray-label">
            Your bundle
            <span class="bns-tray-count" id="bns-count-{{ section_id }}">0</span>
          </div>
          <div class="bns-tray" id="bns-tray-{{ section_id }}">
            {% for i in (1..max_items) %}
              <div class="bns-tray-slot" id="bns-slot-{{ section_id }}-{{ i }}" data-slot="{{ i }}">
                <div class="bns-tray-slot__placeholder">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M12 8v8M8 12h8"/></svg>
                </div>
                <button class="bns-tray-slot__remove" data-remove-slot="{{ i }}" aria-label="Remove item">
                  <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M15.625 4.375L4.375 15.625M15.625 15.625L4.375 4.375"/></svg>
                </button>
              </div>
            {% endfor %}
          </div>
        </div>

        <!-- CTA -->
        <div class="bns-cta">
          <button
            class="button btn btn-theme"
            id="bns-submit-{{ section_id }}"
            disabled
          >
            {{ section.settings.add_bundle_label }}
          </button>
          <p class="bns-error" id="bns-error-{{ section_id }}"></p>
        </div>

      </div>
    </div>

    <!-- ── Product grid ── -->
    <div class="bns-grid-wrap">
      <div class="bns-grid">
        {% for product in section.settings.products %}
          {%- assign first_variant = product.first_available_variant | default: product.variants.first -%}
          <div
            class="bns-card"
            data-bns-card
            data-product-id="{{ product.id }}"
            data-product-url="{{ product.url }}"
          >
            <!-- Image -->
            <a class="bns-card__media" href="{{ product.url }}">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  loading="lazy"
                  width="600"
                  height="600"
                >
                {% if product.images[1] %}
                  <img
                    class="bns-card__img-secondary"
                    src="{{ product.images[1] | image_url: width: 600 }}"
                    alt="{{ product.images[1].alt | escape }}"
                    loading="lazy"
                    width="600"
                    height="600"
                  >
                {% endif %}
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'w-full h-full object-cover' }}
              {% endif %}
              {%- render 'product-label', product: product , showlabel : true -%}
            </a>

            <!-- Body -->
            <div class="bns-card__body">
              <a class="bns-card__title" href="{{ product.url }}">{{ product.title }}</a>
              <div class="bns-card__price">
                <span>{{ first_variant.price | money }}</span>
                {% if first_variant.compare_at_price > first_variant.price %}
                  <span class="bns-card__price--compare">{{ first_variant.compare_at_price | money }}</span>
                {% endif %}
              </div>
            </div>

            <!-- Form -->
            <div class="bns-card__form">
              {% if product.variants.size > 1 %}
                <select class="bns-card__select" data-bns-variant-select>
                  {% for variant in product.variants %}
                    <option
                      value="{{ variant.id }}"
                      data-price="{{ variant.price }}"
                      {% unless variant.available %}disabled{% endunless %}
                    >
                      {{ variant.title }}
                    </option>
                  {% endfor %}
                </select>
              {% else %}
                <input type="hidden" data-bns-variant-select value="{{ first_variant.id }}">
              {% endif %}

              <button
                class="bns-card__add-btn btn-theme"
                data-bns-add
                type="button"
              >
                Add
              </button>
            </div>

          </div>
        {% else %}
          <p style="grid-column:1/-1;opacity:.5;font-size:1.4rem;">No products selected — add products in the section settings.</p>
        {% endfor %}
      </div>
    </div>

  </div>
</div>
</section>

<script>
(function () {
  var ROOT     = document.getElementById('bns-app-{{ section_id }}');
  if (!ROOT) return;

  var MAX      = parseInt(ROOT.dataset.max)      || 3;
  var MIN      = parseInt(ROOT.dataset.min)      || 1;
  var DUP_MSG  = ROOT.dataset.dupMsg  || 'This product is already in the bundle.';
  var LIM_MSG  = ROOT.dataset.limitMsg || 'You can only add ' + MAX + ' products.';
  var SECTION  = '{{ section_id }}';

  var bundle   = [];   // [{variantId, productId, imageUrl, cardEl}]

  var countEl  = document.getElementById('bns-count-'  + SECTION);
  var submitEl = document.getElementById('bns-submit-' + SECTION);
  var errorEl  = document.getElementById('bns-error-'  + SECTION);

  /* ── helpers ── */
  function showError(msg) {
  /*  errorEl.textContent = msg;
    errorEl.classList.add('is-visible');
    setTimeout(function () { errorEl.classList.remove('is-visible'); }, 3000);*/
  }

  function getSlot(n) {
    return document.getElementById('bns-slot-' + SECTION + '-' + n);
  }

  function updateUI() {
    countEl.textContent = bundle.length;
    submitEl.disabled   = bundle.length < MIN;

    /* tray slots */
    for (var i = 1; i <= MAX; i++) {
      var slot  = getSlot(i);
      var item  = bundle[i - 1];
      var ph    = slot.querySelector('.bns-tray-slot__placeholder');
      var img   = slot.querySelector('.bns-tray-slot__img');

      if (item) {
        if (!img) {
          img = document.createElement('img');
          img.className = 'bns-tray-slot__img';
          img.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;';
          slot.insertBefore(img, ph);
        }
        img.src = item.imageUrl;
        img.alt = '';
        ph.style.display = 'none';
        slot.classList.add('is-filled');
      } else {
        if (img) img.remove();
        ph.style.display = '';
        slot.classList.remove('is-filled');
      }
    }

    /* card state */
    ROOT.querySelectorAll('[data-bns-card]').forEach(function (card) {
      var pid  = card.dataset.productId;
      var inBundle = bundle.some(function (b) { return b.productId === pid; });
      var btn  = card.querySelector('[data-bns-add]');
      card.classList.toggle('is-selected', inBundle);
      if (btn) {
        btn.textContent = inBundle ? 'Add' : 'Add';
        btn.classList.toggle('is-added', inBundle);
      }
    });
  }

  /* ── add ── */
  ROOT.addEventListener('click', function (e) {
    var addBtn = e.target.closest('[data-bns-add]');
    if (!addBtn) return;

    var card      = addBtn.closest('[data-bns-card]');
    var pid       = card.dataset.productId;
    var sel       = card.querySelector('[data-bns-variant-select]');
    var variantId = sel ? sel.value : null;
    var imgEl     = card.querySelector('.bns-card__media img');
    var imageUrl  = imgEl ? imgEl.src : '';

    /* if already in bundle → remove */
    var existIdx = bundle.findIndex(function (b) { return b.productId === pid; });
    /*if (existIdx !== -1) {
      bundle.splice(existIdx, 1);
      updateUI();
      return;
    }*/

    if (bundle.length >= MAX) { showError(LIM_MSG); return; }

    bundle.push({ variantId: variantId, productId: pid, imageUrl: imageUrl, cardEl: card });
    updateUI();
  });

  /* ── remove via tray ── */
  ROOT.addEventListener('click', function (e) {
    var removeBtn = e.target.closest('[data-remove-slot]');
    if (!removeBtn) return;
    var slotNum = parseInt(removeBtn.dataset.removeSlot);
    bundle.splice(slotNum - 1, 1);
    updateUI();
  });

  /* ── variant change → update image ── */
  ROOT.addEventListener('change', function (e) {
    if (!e.target.matches('[data-bns-variant-select]')) return;
    /* no-op for tray image; could be extended */
  });

  /* ── submit ── */
  submitEl.addEventListener('click', function () {
    if (bundle.length < MIN) return;

    var items = bundle.map(function (b, idx) {
      return 'items[' + idx + '][id]=' + b.variantId + '&items[' + idx + '][quantity]=1';
    });

    submitEl.disabled = true;
    submitEl.textContent = 'Adding…';

    fetch('/cart/add.js', {
      method:  'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body:    items.join('&')
    })
    .then(function (r) { return r.json(); })
    .then(function () {
      bundle = [];
      updateUI();
      submitEl.textContent = '{{ section.settings.add_bundle_label }}';
      /* open cart drawer if theme supports it */
      theme.miniCart.updateElements();
      theme.miniCart.generateCart();
    })
    .catch(function () {
      showError('Something went wrong. Please try again.');
      submitEl.disabled = false;
      submitEl.textContent = '{{ section.settings.add_bundle_label }}';
    });
  });

  updateUI();
})();
</script>

