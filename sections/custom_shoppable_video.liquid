<script>
document.addEventListener('DOMContentLoaded', () => {
  initCustomVideoSlider('{{ section.id }}');
});

document.addEventListener('shopify:section:load', (event) => {
  const sectionId = event.detail.sectionId;
  initCustomVideoSlider(sectionId);
});

function initCustomVideoSlider(sectionId) {
  const container = document.querySelector(`.custom_video_items-${sectionId}`);
  if (!container) return;

  const videos = container.querySelectorAll('.custom_video_items_1 video');
  const playButtons = container.querySelectorAll('.custom_video_items_1 .shoppable-video_control-button');
  const muteButtons = container.querySelectorAll('.custom_video_items_1 .video__sound-toggle');
  let globalMuted = true;

  const swiper = new Swiper(`.custom_video_items-${sectionId}`, {
    slidesPerView: 1.5,
    spaceBetween: 24,
    loop: true,
    centeredSlides: true,
    navigation: {
      nextEl: `.swiper-button-next-${sectionId}`,
      prevEl: `.swiper-button-prev-${sectionId}`,
    },
    breakpoints: {
      999: { slidesPerView: 4.5 },
      600: { slidesPerView: 2.5 }
    },
    on: {
      slideChange: function () {
        handleSlideChange(this, videos, playButtons);
      }
    }
  });

  // Initial mute state
  videos.forEach(v => v.muted = globalMuted);
  handleSlideChange(swiper, videos, playButtons);

  // Play/Pause button logic
  playButtons.forEach((btn, index) => {
    btn.addEventListener('click', () => {
      const vid = videos[index];
      if (vid.paused) {
        videos.forEach((v, i) => {
          if (i !== index) {
            v.pause();
            playButtons[i].classList.remove('playing');
          }
        });
        vid.play();
        btn.classList.add('playing');
      } else {
        vid.pause();
        btn.classList.remove('playing');
      }
    });
  });

  // Mute/Unmute logic
  muteButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      globalMuted = !globalMuted;
      videos.forEach(v => v.muted = globalMuted);
      muteButtons.forEach(b => b.classList.toggle('unmuted', !globalMuted));
    });
  });
}

function handleSlideChange(swiper, videos, playButtons) {
  videos.forEach((vid, index) => {
    if (index === swiper.realIndex) {
      vid.play();
      playButtons[index]?.classList.add('playing');
    } else {
      vid.pause();
      playButtons[index]?.classList.remove('playing');
    }
  });
}
</script>



