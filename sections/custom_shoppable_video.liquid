<style>
  .custom_reviews_slider-{{ section.id }}{
    background:{{ section.settings.background }};
     padding-top:{{ section.settings.padding_top }}px;
    padding-bottom:{{ section.settings.padding_bottom }}px;
    {% if section.settings.color != blank %}
      {% if section.settings.color != "rgba(0,0,0,0)" %}
    --g-color-heading:{{ section.settings.color   }};
    --g-font-color-subtop:{{ section.settings.color   }};
      {% endif %}
    {% endif %}
  }
  .c_testimonial-header-review {
    display: flex;
    align-items: center;
    gap: 10px;   
}
  .justify-left{
    justify-content:flex-start;
  }
  .justify-center{
    justify-content:center;
  }
    .justify-right{
    justify-content:flex-end;
  }
 .c_testimonial-header-review span{
   font-size:14px;
 } 
  .c_testimonial-header-review svg{
    width:auto;
  }
  .custom_video_items {
    width: 100%;
    height: unset;
    padding-block: 20px;
    overflow: hidden;
    background-color: unset;
}
.c_video-wrapper{
    position: relative;
    overflow: hidden;
    max-width: 100%;
    width:100%;
    padding-bottom: 166%;
    height: 0;
   /* border-radius:10px;*/
    height: auto;
    margin-bottom:10px;
}
.video_product{
    opacity: 0;
    transition: opacity .3s ease-out;
    transform-origin: top;
    box-shadow: none;
    pointer-events: none;
}
.c_video_item_c{
  position:absolute;
  height:100%;
  width:100%;
  display:flex;
  align-items:center;
}
.wt-video__movie{
  transition: height .3s ease-out;
  overflow:hidden;
  height:80%;
  position:relative;
  width:100%;
  {% if settings.enable_radius_allimg %}
  border-radius: calc(0.2rem * {{ settings.radius_allimg_range }});
  {% endif %}
}
.custom_reviews_slider-{{ section.id }} .c_product_info p,
.custom_reviews_slider-{{ section.id }} .product-card__regular-price,
.custom_reviews_slider-{{ section.id }} .product-card__price{
  {% if section.settings.color != blank and  section.settings.color != "rgba(0,0,0,0)" %}
  color:{{ section.settings.color }};
  {% endif %}
}
{% if section.settings.hide_products %}
   .custom_reviews_slider-{{ section.id }} .video_product{
        display:none!important;
    }
{% endif %}
.custom_shoppable_video.swiper-slide-active .video_product{
        opacity: 1;
    pointer-events: auto;
}    
.custom_shoppable_video.swiper-slide-active .wt-video__movie{
  height:100%;
}
.custom_shoppable_video video,
.custom_shoppable_video .svg_video svg{
    width: 100%;
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    transition: height .3s ease-out;
}
/*.custom_shoppable_video.swiper-slide-active video{
height:100%;
}*/
  .custom_video_items .swiper-button-next_r, .custom_video_items .swiper-button-prev_r {
    position: absolute;
    top: var(--swiper-navigation-top-offset,50%);
    width: 50px;
    height: 50px;
    margin-top: -20px;
    z-index: 10;
    cursor: pointer;
    display: flex;
    box-shadow: rgba(0, 0, 0, 0.1) 0px 10px 50px;
    align-items: center;
    justify-content: center;
    background-color: white;
    border-radius: 50%;
    border: 1px solid #21212117;
}
   .custom_video_items .swiper-button-prev_r {
    left: 10px;
    right: auto;
}
  .custom_video_items .swiper-button-next_r {
    right: 10px;
    left: auto;
}
.video_product{
    border: 1px solid #e7e7e7;
    padding:8px;
    border-radius: 10px;
    display:flex;
    justify-content:space-between;
    gap:10px;
}
.video_product .product_info{
    display:flex;
    gap:10px;
}
.video_product .product_info img,
.video_product .product_info svg{
width:90px;
height:auto;
object-fit:cover;
}
.quick_buy{
display:flex;
align-items:center;
height:auto;
}
.quick_buy a{
    height:32px;
    width:32px;
    display:flex;
    align-items:center;
    justify-content:center;
    border: 1px solid #e7e7e7;
    border-radius:50%;
    background:{{ section.settings.cta_color }};
    {% if section.settings.cta_text_color != blank and section.settings.cta_text_color != "rgba(0,0,0,0)" %}
    color:{{ section.settings.cta_text_color }};
    {% endif %}
}
.shoppable-video_control-button{
        position: absolute;
    z-index: 6;
    top: 16px;
    left: 16px;
    display: flex;
    justify-content: center;
    color:white;
    align-items: center;
    width: 40px;
    height: 40px;
    padding: 0;
    background-color: #00000040;
    border: none;
    border-radius:7px;
}
.shoppable-video_control-button .icon-pause:before{
color:white;
}
.shoppable-video_control-button .icon-pause{
    display:none;
}
.shoppable-video_control-button.playing .icon-pause{
    display:block;
}
.shoppable-video_control-button.playing .icon-play{
    display:none;
}
.video__sound-toggle{
    background-color: #00000040;
    -webkit-backdrop-filter: blur(3px);
    backdrop-filter: blur(3px);
    color: #fff;
    border: none;
    position: absolute;
    bottom: 16px;
    right: 16px;
    z-index: 6;
    display: flex;
    border-radius:7px;
    justify-content: center;
    align-items: center;
    width: 40px;
    height: 40px;
    padding: 0;
    transition: scale .2s ease-out,opacity .2s ease-out;
}
.video__sound-toggle .svg-icon--volume{
    display:none;
}
.video__sound-toggle.unmuted .svg-icon--volume{
    display:block;
}
.video__sound-toggle.unmuted .svg-icon--volume-muted{
    display:none;
}
.video__sound-toggle,
.shoppable-video_control-button{
    display:none;
}
.custom_shoppable_video.swiper-slide-active .video__sound-toggle,
.custom_shoppable_video.swiper-slide-active .shoppable-video_control-button{
display:flex;
}

  @media (max-width:768px){
      .custom_reviews_slider-{{ section.id }}{
         padding-top:{{ section.settings.mobile_padding_top }}px;
          padding-bottom:{{ section.settings.mobile_padding_bottom }}px;
      }   
  }
</style>
