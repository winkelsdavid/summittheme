<style>
   #custom-faq-{{ section.id }} {
    {% if section.settings.bg_color != blank and section.settings.bg_color != "rgba(0,0,0,0)" %}
    --section-bg: {{ section.settings.bg_color }};
    {% endif %}
    {% if section.settings.text_color != blank and section.settings.text_color != "rgba(0,0,0,0)" %}
    --text-main: {{ section.settings.text_color }};
    {% endif %}
     {% if section.settings.h_color != blank and section.settings.h_color != "rgba(0,0,0,0)" %}
    --g-color-heading:{{ section.settings.h_color }};
    {%  endif %}
    {% if section.settings.text_muted_color != blank and section.settings.text_muted_color != "rgba(0,0,0,0)" %}
    --text-muted: {{ section.settings.text_muted_color }};
    {%  endif %}
    --card-bg: {{ section.settings.card_bg_color }};
    --accordion-border: {{ section.settings.border_color }};
    {% if section.settings.chevron_bg_color != blank and section.settings.chevron_bg_color != "rgba(0,0,0,0)" %}
    --chevron-bg: {{ section.settings.chevron_bg_color }};
    {% else %}
    --chevron-bg: {{ settings.branding_color }};
    {% endif %}
    --chevron-icon: {{ section.settings.chevron_icon_color }};
  }
    #custom-faq-{{ section.id }}{
    padding-top:{{ section.settings.padding_top }}px;
    padding-bottom:{{ section.settings.padding_bottom }}px;
    background-color: var(--section-bg, transparent);
  color: var(--text-main);
  }
  @media (max-width:768px){
     #custom-faq-{{ section.id }}{
    padding-top:{{ section.settings.mobile_padding_top }}px;
    padding-bottom:{{ section.settings.mobile_padding_bottom }}px;
  }
  }
.section-stack--horizontal {
  display: flex;
  flex-direction: column;
  gap: 40px;
}

@media (min-width: 1024px) {
  .section-stack--horizontal {
    flex-direction: row;
    justify-content: space-between;
  }
  .section-stack__intro { width: 35%; }
  .section-stack__main { width: 60%; }
  .hidden { display: none; }
  .lg\:block { display: block; }
  .lg\:hidden { display: none; }
}

.v-stack { display: flex; flex-direction: column; }
.gap-4 { gap: 1rem; }
.gap-10 { gap: 2.5rem; }
.bold { font-weight: 600; }

.h2 { 
  margin-top: 0; 
  margin-bottom: 1rem; 
}

.prose p, .availability-text {
  color: var(--text-main);
}

.text-subdued { 
  color: var(--text-muted); 
  font-size: 0.9em; 
  margin-top: 4px; 
}

/* Accordion Wrapper styling using custom variable variables */
#custom-faq-{{ section.id }} .accordion-box {
  background-color: var(--card-bg);
  border-radius: calc(0.2rem * {{ settings.radius_allimg_range }});
  padding: 10px 24px;
}

.accordion {
  border-bottom: 1px solid var(--accordion-border);
}
.accordion:last-child {
  border-bottom: none;
}

.accordion__summary {
  list-style: none;
  cursor: pointer;
  padding: 20px 0;
}
.accordion__summary::-webkit-details-marker { display: none; }

.accordion__toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 1.1rem;
  color: var(--text-main);
}

/* Dynamic Chevron Color Styles */
.circle-chevron {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  background-color: var(--chevron-bg);
  color: var(--chevron-icon);
  border-radius: 50%;
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), background-color 0.2s;
}
.circle-chevron svg{
height:6px;
width:8px;
fill:transparent
}
.circle-chevron svg.icon path{
stroke:currentColor;
}
.accordion[open] .circle-chevron {
  transform: rotate(180deg);
  opacity: 0.85;
}

/* Dropdown Animation Engine */
.accordion__content-wrapper {
  display: grid;
  grid-template-rows: 0fr;
  transition: grid-template-rows 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  overflow: hidden;
}
.accordion[open] .accordion__content-wrapper {
  grid-template-rows: 1fr;
}

.accordion__content .prose {
  padding-bottom: 20px;
  line-height: 1.6;
  font-size: 1rem;
  opacity: 0;
  transform: translateY(-8px);
  transition: opacity 0.3s ease, transform 0.3s ease;
}
.accordion[open] .accordion__content .prose {
  opacity: 1;
  transform: translateY(0);
  transition-delay: 0.05s;
}
.avatar_team_image img{
max-width: {{  section.settings.team_image_width }}px;
}
/* ==========================================================================
   Mobile Adaptive Styles
   ========================================================================== */
@media (max-width: 1023px) {
  .section-stack--horizontal { gap: 32px; }
  
  .h2 { margin-bottom: 12px; }
  #custom-faq-{{ section.id }} .accordion-box { padding: 8px 16px; }
  .accordion__summary { padding: 16px 0; }
  .accordion__toggle { font-size: 1rem; gap: 12px; }
  .accordion__toggle span:first-child { flex: 1; }

  .lg\:hidden .faq-availability {
    margin-top: 8px;
  }
  .lg\:hidden .v-stack.gap-4 {
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align:center;
  }
  
  .hidden { display: none !important; }
  .lg\:block { display: none !important; }
  .lg\:hidden { display: block !important; }
  .avatar_team_image img{
max-width: {{  section.settings.team_image_width_mobile }}px;
}
}
</style>
<div id="custom-faq-{{ section.id }}" class="section section-boxed custom-faq-section" data-aos="{{ section.settings.animation }}">
<div class="{{ section.settings.section_width }}">
  <div class="section-stack section-stack--horizontal">
    
    <!-- Intro Block -->
    <div class="section-stack__intro">
      <div class="v-stack gap-10">
        <div class="prose">
          <h3 class="h3">{{ section.settings.heading }}</h3>
          <p>{{ section.settings.subheading }}</p>
        </div>
        
        <!-- Desktop Availability Details -->
        <div class="hidden lg:block">
          <div class="faq-availability">
            <div class="v-stack gap-4 avatar_team_image">
              {%- if section.settings.team_image != blank -%}
                <img src="{{ section.settings.team_image | image_url: width: 346 }}" 
                     alt="{{ section.settings.team_image.alt | escape }}" 
                     width="{{  section.settings.team_image_width }}" 
                     loading="lazy" >
              {%- endif -%}
              <div class="v-stack">
                <span class="availability-text">{{ section.settings.availability_caption }}</span>
                <span class="text-subdued">{{ section.settings.response_time_caption }}</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Accordion/FAQ Block -->
    <div class="section-stack__main">
      <div class="accordion-box">
        {%- for block in section.blocks -%}
          {%- if block.type == 'faq_item' -%}
            <details class="accordion group" aria-expanded="false">
              <summary class="accordion__summary">
                <div class="accordion__toggle bold">
                  <span>{{ block.settings.question_heading }}</span>
                  <span class="circle-chevron">
                    <svg role="presentation" focusable="false" width="8" height="6" class="icon icon-chevron-bottom-small" viewBox="0 0 8 6">
                        <path d="m1 1.5 3 3 3-3" fill="none" stroke="currentColor" stroke-width="1.5"></path>
                    </svg>
                  </span>
                </div>
              </summary>
              <div class="accordion__content-wrapper">
                <div class="accordion__content">
                  <div class="prose">
                    {{ block.settings.answer_body }}
                  </div>
                </div>
              </div>
            </details>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <!-- Mobile Availability Details -->
    <div class="lg:hidden">
      <div class="faq-availability">
        <div class="v-stack gap-4 avatar_team_image">
          {%- if section.settings.team_image != blank -%}
            <img src="{{ section.settings.team_image | image_url: width: 346 }}" 
                 alt="{{ section.settings.team_image.alt | escape }}" 
                 width="{{  section.settings.team_image_width }}" 
                 loading="lazy">
          {%- endif -%}
          <div class="v-stack">
            <span class="availability-text">{{ section.settings.availability_caption }}</span>
            <span class="text-subdued">{{ section.settings.response_time_caption }}</span>
          </div>
        </div>
      </div>
    </div>

  </div>
  </div>
</div>

