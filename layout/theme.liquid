<!doctype html>
<html class="no-js " lang="{{ shop.locale }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="theme-color" content="{{ settings.color_header_bg }}">
    <meta name="format-detection" content="telephone=no">
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="dns-prefetch" href="https://{{shop.domain }}" crossorigin>
    <link rel="dns-prefetch" href="https://{{shop.permanent_domain }}" crossorigin>
    <link rel="dns-prefetch" href="https://cdn.shopify.com" crossorigin>
    <link rel="dns-prefetch" href="https://fonts.shopifycdn.com" crossorigin>
  	<link rel="preconnect" href="https://fonts.shopifycdn.com/" crossorigin>
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    
    <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- unless settings.font_family.system? -%}
    <link rel="preload" as="font" href="{{ settings.font_family | font_url }}" type="font/woff2" crossorigin>
    <link rel="preload" as="font" href="{{ settings.font_family | font_url: 'woff' }}" type="font/woff" crossorigin>
  {%- endunless -%}
  {%- if settings.font_family2.system? == false and settings.font_family2 != settings.font_family -%}
    <link rel="preload" as="font" href="{{ settings.font_family2 | font_url }}" type="font/woff2" crossorigin>
    <link rel="preload" as="font" href="{{ settings.font_family2 | font_url: 'woff' }}" type="font/woff" crossorigin>
  {%- endif -%}
    {%- if settings.favicon != blank -%}
      <link rel="shortcut icon" href="{{ settings.favicon | image_url: width: 32, height: 32 }}" type="image/png">
    {%- endif -%}

    <title>
      {{ page_title }}
      {% if current_tags %}
        {% assign meta_tags = current_tags | join: ', ' %}
        &ndash;
        {{ 'general.meta.tags' | t: tags: meta_tags }}
      {% endif %}
      {% if current_page != 1 %}
        &ndash;
        {{ 'general.meta.page' | t: page: current_page }}
      {% endif %}
      {% unless page_title contains shop.name %}
        &ndash;
        {{ shop.name }}
      {% endunless %}
    </title>
   
    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
      {% else %}
      <meta name="description" content="{{ settings.meta_description | escape }}">
    {%- endif -%}
    <style>
   /* body:has(.loading-overlay_x:not(.faded_out)){
      overflow:hidden!important;
    }*/
    </style>
    {%- render 'social-meta-tags' -%}
    {%- render 'header-css' -%}
    {%- comment -%} Perf-Gate: AOS-Initialzustand neutralisieren. AOS setzt [data-aos] auf
        opacity:0 bis das JS feuert -> auf Mobil-Drosselung erst ~13s -> Hero-Text (LCP-Element)
        unsichtbar -> LCP 13s. Beim Einanimieren verschiebt sich Layout -> Desktop-CLS 0.426.
        Override: Content sofort sichtbar + an Endposition -> behebt Mobile-LCP + Desktop-CLS.
        Trade-off: Scroll-Fade-In-Animationen entfallen. {%- endcomment -%}
    <style>[data-aos]{opacity:1!important;transform:none!important;transition:none!important;}</style>
      <link rel="preload" href="{{ 'lazysizes.min.js' | asset_url }}" as="script">
      <link rel="preload" href="{{ 'vendor.js' | asset_url }}" as="script">
       {{- 'swiper-bundle.min.css' | asset_url | stylesheet_tag: preload: true -}}
      <link rel="preload" href="{{ 'swiper-bundle.min.js' | asset_url }}" as="script">
      <script src="{{ 'global.js' | asset_url }}" defer="defer"></script>
    {{ content_for_header }}




<style>
  body.has_sepia {
    background-image: url({{ "sepia-pattern.png" | asset_url }});
    background-repeat: repeat;
}
  .price-inline {
  display: inline-flex;  /* instead of flex */
  flex-wrap: nowrap;
  align-items: baseline;
  gap: 6px;
  max-width: 220px; /* adjust as needed */
  font-size: clamp(12px, 1.8vw, 16px);
}
.price-inline .js-cart-total {
  white-space: nowrap;
  text-overflow: ellipsis;
  overflow: hidden;
}

</style>
<style>
  html.lenis { height: auto; }
  .lenis.lenis-smooth { scroll-behavior: auto; }
  .lenis.lenis-smooth [data-lenis-prevent] { overscroll-behavior: contain; }
  .lenis.lenis-stopped { overflow: hidden; }
  .rating-custom{
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        border:1px solid var(--border-color);
        background:var(--background);
        border-radius:var(--radius);
    margin-bottom:.5rem;
    width:fit-content;
  }
  .rating-excellent *{
      font-size: var(--font_size);
    line-height:1;
    color:var(--color);
  }
  .trustpilot-block-rating-text{

          margin: 0;
          padding: 4px 7px;
          display: flex;
          align-items: center;
          flex-wrap: wrap;
    }
  .trustpilot-star-five {
          height:var(--height) ;
          width: auto;
          margin: 0 8px 0 0;
          vertical-align: middle;
      }

  .rating-custom-2{
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      {%  if settings.t2_border_color != blank and settings.t2_border_color != "rgba(0,0,0,0)" %}
      border:1px solid var(--border-color, transparent);
      {% endif %}
      background:var(--background);
      border-radius:var(--radius);
      margin-bottom:.5rem;
      width:fit-content;
}
.rating-excellent-2 p{
    font-size: var(--font_size);
    line-height:1;
    color:var(--color);
}
.trustpilot-block-rating-text-2{
    margin: 0;
    padding: 5px 16px;
    display: flex;
    align-items: center;
  }
  .stars {
    display: flex;
    gap: 0;
    font-size: 0;
    align-items: center;
    margin: 0 8px 0 0;
    }
.stars svg{
    color:var(--stars-color)!important;
    height: var(--height);
    width: auto;
    vertical-align: middle;
    }
@media (max-width:768px){
  .rating-excellent-2 p{
    font-size: var(--mobile-font_size);
}
}

.reviews_images{
display:flex;
gap:10px;
flex-wrap:wrap;
align-items:center;
width:fit-content;
}
.reviews_images_r{
display:flex;
align-items:center;
}
.reviews_images_r img{
width:var(--width);
height:var(--width);
object-fit:cover;
border:3px solid white;
border-radius:50%!important;
}
.reviews_images p{
color:var(--font-color);
}

.reviews_images_r img:nth-child(2){
margin-left:var(--margin);
}
.reviews_images_r img:nth-child(3){
margin-left:var(--margin);
}
.reviews_text{
  padding: 2px 0;
  padding-right: 25px;
  flex:1;
}
.review-excellent-2 p,
.reviews_image_title,
.review_images_content p{
font-size:var(--size);
}
.review-block-rating-text-2{
display:flex;
align-items:center;
flex-wrap:wrap;
}
.review_images_content{
text-align:left;
}
@media (max-width:768px){
.reviews_images_r img{
width:var(--width-mobile);
height:var(--width-mobile);
}
  .review-excellent-2 p,
.reviews_image_title,
.review_images_content p{
font-size:var(--size-mobile);
}
}
.reviews-block.text-center{
  margin-right:auto;
  margin-left:auto;
}
.reviews-block.text-right,
.reviews-block.text-end{
  margin-left:auto;
      flex-direction: row-reverse;
}
.reviews-block.text-right .reviews_text,
.reviews-block.text-end .reviews_text{
    padding-right: 0;
    padding-left: 25px;
}
.reviews-block.text-right *,
.reviews-block.text-end *{
text-align:right;
}
.h1.text-right,
.h2.text-right,
.h3.text-right,
.h4.text-right,
.h5.text-right,
.h6.text-right{
padding-right:5px;
}
{% if settings.slideshow_white %}
[data-section-type="slideshow-section"] .reviews_images *,
[data-section-type="slideshow-section"] .rating-custom *,
[data-section-type="slideshow-section"] .rating-custom-2 *{
  color:white!important;
}
{% endif %}
.progress-bar-animated {
    -webkit-animation: progress-bar-stripes 1s linear infinite;
    animation: progress-bar-stripes 1s linear infinite;
}
@keyframes progress-bar-stripes{
0% {
    background-position: 1rem 0;
}

100% {
    background-position: 0 0;
}
}
</style>

  </head>
  <body class="template-{{ template | replace: '.', ' ' | truncatewords: 1, '' | handle }} body-theme {% if settings.has_sepia %} has_sepia {% endif %} {% if settings.productpage == 'product-2' or settings.productpage == 'product-6' or settings.productpage == 'product-7' %} product-hide-breadcrumb {% endif %}">
   {% assign lazy = false %}
    <img {% if lazy %} loading = "lazy" {% endif %} width="99998" height="99999" alt="index" style="pointer-events: none; position: absolute; top: 0; left: 0; width: 99vw; height: 99vh; max-width: 99vw; max-height: 99vh;" src="data:image/svg+xml;base64,">
    {% comment %}
    {%- render 'loading' -%}
    {% endcomment %}
    {% if settings.loading_enable %}
      {% if settings.loading_homepage %}
        {% if template.name == "index" %}
        {% render "loading_animation" %}
        {% endif %}
      {% else %}
      {% render "loading_animation" %}
    {% endif %}
    {% endif %}
    {%- sections 'header-group' -%}
    <div class="page-container page-element is-moved-by-drawer">
      {%- render 'breadcrumb' -%}
      <main class="main-content" id="MainContent" role="main">
        {%- if settings.enable_animationscroll -%}
          <div id="js-scroll">
          {% endif %}
          {%- if settings.enable_animationscroll -%}
            <div data-scroll-section>
            {% endif %}
            {%- render 'slideshow' -%}
            {%- if settings.enable_animationscroll -%}
            </div>
          {% endif %}
          {{ content_for_layout }}
          {%- if settings.enable_animationscroll -%}
          </div>
        {% endif %}
      </main>
    {%- sections 'footer-group' -%}
     {%- liquid
      section 'sticky_video_section'
      section 'pnewsletter'
      section 'product-suggest'
      section 'cookie-policy'
     -%}
    </div>
    {% comment %}
     render 'back-to-top'
     {% endcomment %}
    {%- liquid 
      render 'whatsapp'
      render 'menu-mobile' 
      render 'bottom-contents' 
      render 'quickview' 
      render 'popup-compare' 
      render 'header-js' 
    -%}
   
  </body>
  <script>
  document.addEventListener("DOMContentLoaded", function () {
    document.querySelectorAll('a[href="#"]').forEach(function (anchor) {
      anchor.addEventListener("click", function (e) {
        e.preventDefault();
        window.scrollTo({
          top: 0,
          behavior: "smooth"
        });
      });
    });
  });
</script>
{% if settings.enable_smoothness %}
<script src="https://unpkg.com/lenis@1.3.23/dist/lenis.min.js"></script>
<script>
  const lenis = new Lenis({
    lerp: 0.{{ settings.smoothness_intensity }},              // smoothness (0 = instant, 1 = very slow)
    wheelMultiplier: 0.7,   // scroll speed
    gestureOrientation: "vertical",
    normalizeWheel: false,
    smoothTouch: false      // keep native touch on mobile
  });

  function raf(time) {
    lenis.raf(time);
    requestAnimationFrame(raf);
  }
  requestAnimationFrame(raf);
</script>
{% endif %}
<script>
  window.theme = window.theme || {};
  theme.strings = theme.strings || {};
  theme.strings.you_are_saving = {{ 'cart.general.you_are_saving' | t | json }};
</script>


</html>