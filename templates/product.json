20,"padding_bottom":80,"mobile_padding_top":20,"mobile_padding_bottom":40}},"custom_reviews_marquee_NecxRp":{"type":"custom_reviews_marquee","blocks":{"first_row_8MYfRA":{"type":"review_left","settings":{"title":"Glow Upgrade!","date":"March 10, 2026","content":"<p>I’ve tried countless moisturizers, but this collagen jelly cream actually keeps my skin hydrated all day. My face feels softer, looks brighter, and makeup sits beautifully afterward. Honestly, such a good surprise for my sensitive skin.<\/p><h3><\/h3>","name":"Amelie R.","add_verified":true,"verified_color":"#34bf49"}},"first_row_T8wUA4":{"type":"review_left","settings":{"title":"Lowkey Amazing","date":"March 10, 2026","content":"<p>Lowkey obsessed with this cream already. The texture feels lightweight but deeply nourishing, and my dry patches disappeared within days. My skin looks smoother every morning, especially around my cheeks and forehead.<\/p>","name":"Amelie R.","add_verified":true,"verified_color":"#34bf49"}},"first_row_ai9aaJ":{"type":"review_left","settings":{"title":"Actually Works","date":"March 10, 2026","content":"<p>After two weeks of using ORELLA Collagen Jelly Cream nightly, my skin feels firmer and noticeably healthier. I love the fresh glow it gives without feeling greasy or heavy. Definitely repurchasing because it genuinely works.<\/p>","name":"Amelie R.","add_verified":true,"verified_color":"#34bf49"}},"second_row_KpeBx6":{"type":"review_right","settings":{"title":"Super Hydrating","date":"March 10, 2026","content":"<p>This moisturizer made my skin look hydrated and plump after only several applications, which honestly impressed me. The jar feels slightly smaller than expected, but the formula itself works beautifully and lasts throughout the night.<\/p>","name":"Amelie R.","add_verified":true,"verified_color":"#34bf49"}},"second_row_YKEV36":{"type":"review_right","settings":{"title":"Soothing Glow","date":"March 10, 2026","content":"<p>My skin usually reacts badly to new products, yet this jelly cream felt soothing immediately. The hydration lasts for hours, and my complexion looks clearer, softer, and more radiant lately. Kinda feels like a luxury facial.<\/p>","name":"Amelie R.","add_verified":true,"verified_color":"#34bf49"}},"second_row_W8V7aB":{"type":"review_right","settings":{"title":"Fresh Radiance","date":"March 10, 2026","content":"<p>This collagen cream gives my skin the smoothest glow ever without clogging pores or causing irritation. The jelly texture absorbs quickly, feels refreshing, and leaves my face looking healthy, bouncy, and naturally radiant every day.<\/p>","name":"Amelie R.","add_verified":true,"verified_color":"#34bf49"}}},"block_order":["first_row_8MYfRA","first_row_T8wUA4","first_row_ai9aaJ","second_row_KpeBx6","second_row_YKEV36","second_row_W8V7aB"],"name":"Testimonials Slider","settings":{"animation":"","setwidth":"container","background":"","animated":true,"show_stars":true,"stars_color":"","stars_rating":4.5,"reviews_count_caption":"Rated 4.8\/5.0 on","reviews_cout_color":"","show_truspilot":true,"trust_icon":"ebay","title":"Real Results, Real Reviews","title_color":"","content":"<p>Thousands are loving ORELLA Collagen Jelly Cream for smoother, brighter, deeply hydrated skin with visible daily improvements.<\/p>","content_color":"","show_quotes":true,"quote_box_color":"#ffffff","quote_title_color":"#2e0128","quote_date_color":"","quote_content_color":"","quote_name_color":"","enable_overlay_edges":true,"overlay_color":"#fff2f4","section_height_desktop":750,"animation_speed":20,"animation_speed_mobile":20,"boxes_radius":20,"padding_top":40,"padding_bottom":60,"mobile_padding_top":20,"mobile_padding_bottom":40}},"custom_image_bullets_F7wqRn":{"type":"custom-image-bullets","blocks":{"bullet_DUVPxX":{"type":"bullet","settings":{"icon":"checkmark-2","icon_color":"","title":"Deep Collagen Hydration","body":"Hydrolyzed collagen delivers intense moisture while helping skin appear softer, smoother, and visibly healthie